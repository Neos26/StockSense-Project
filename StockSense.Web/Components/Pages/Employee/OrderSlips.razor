@page "/admin/orderslips"
@layout AdminLayout
@using StockSense.Domain.Entities
@inject OrderSlipService OrderService
@inject Infrastructure.Data.ApplicationDbContext Context
@inject NavigationManager NavManager
@rendermode InteractiveServer

<PageTitle>Order Slips</PageTitle>

<div style="animation: fadeIn 0.4s ease-in;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: var(--text-2xl); font-weight: bold; margin: 0;">Order Slips</h1>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Manual and rule-based inventory restock.</p>
        </div>
        <BbButton Variant="ButtonVariant.Default" OnClick="GenerateSlips" Disabled="@isLoading">
            Scan Low Stock
        </BbButton>
    </div>

    @* --- SLIPS LIST --- *@
    @foreach (var slip in slips)
    {
        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 1.5rem; padding: 1rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
                <h2 style="font-size: var(--text-base); font-weight: bold;">Supplier: @slip.Supplier?.Name</h2>
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="() => slips.Remove(slip)" style="color: var(--destructive);">Discard</BbButton>
            </div>

            <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm);">
                <thead>
                    <tr style="text-align: left; color: var(--muted-foreground);">
                        <th style="padding: 0.5rem;">Product</th>
                        <th style="padding: 0.5rem; text-align: center;">Current Stock</th>
                        <th style="padding: 0.5rem; text-align: center;">Target</th>
                        <th style="padding: 0.5rem; text-align: center; width: 100px;">Order Qty</th>
                        <th style="width: 50px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in slip.Items)
                    {
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 0.5rem;">@item.ProductName (@item.Brand)</td>
                            <td style="padding: 0.5rem; text-align: center;">@item.CurrentStock</td>
                            <td style="padding: 0.5rem; text-align: center;">@item.ReorderTarget</td>
                            <td style="padding: 0.5rem;">
                                <input type="number" @bind="item.Quantity" style="width: 100%; padding: 4px; border: 1px solid var(--border); text-align: center; border-radius: 4px;" />
                            </td>
                            <td style="padding: 0.5rem; text-align: center;">
                                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="() => slip.Items.Remove(item)">&times;</BbButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div style="display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1rem;">
                <BbButton Variant="ButtonVariant.Outline" OnClick="() => OrderService.SaveOrderSlipToDbAsync(slip)">Save Draft</BbButton>
                <BbButton OnClick="() => SendEmailAndSave(slip)">Email Supplier</BbButton>
            </div>
        </div>
    }
</div>

@code {
    private List<OrderSlip> slips = new();
    private List<Product> allProducts = new();
    private bool isLoading, isSaving;

    protected override async Task OnInitializedAsync()
    {
        allProducts = await Context.Products.Include(p => p.Supplier).AsNoTracking().ToListAsync();
        await GenerateSlips();
    }

    private async Task GenerateSlips()
    {
        isLoading = true;
        var supplierOrders = new Dictionary<int, OrderSlip>();

        foreach (var product in allProducts.Where(p => p.CurrentStock < p.ReorderTarget))
        {
            // Plain Heuristic: Order the difference between Target and Current
            int finalQty = product.ReorderTarget - product.CurrentStock;

            if (finalQty > 0)
            {
                if (!supplierOrders.ContainsKey(product.SupplierId))
                {
                    supplierOrders[product.SupplierId] = new OrderSlip
                    {
                        SlipNumber = $"ORD-{DateTime.Now:yyyyMMdd}-{product.SupplierId}",
                        SupplierId = product.SupplierId,
                        Supplier = product.Supplier,
                        DateGenerated = DateTime.Now,
                        Items = new List<OrderSlipItem>()
                    };
                }

                supplierOrders[product.SupplierId].Items.Add(new OrderSlipItem
                {
                    ProductName = product.Name,
                    Brand = product.Brand,
                    CurrentStock = product.CurrentStock,
                    ReorderTarget = product.ReorderTarget,
                    Quantity = finalQty
                });
            }
        }
        slips = supplierOrders.Values.ToList();
        isLoading = false;
    }

    private async Task SendEmailAndSave(OrderSlip slip)
    {
        isSaving = true;
        try
        {
            var bytes = await OrderService.GeneratePdfBytesAsync(slip);
            await OrderService.SendEmailAsync(slip.Supplier.Email, bytes, slip.SlipNumber);
            await OrderService.SaveOrderSlipToDbAsync(slip);
            slips.Remove(slip);
        }
        finally { isSaving = false; }
    }
}