@page "/Account/Manage/ChangePassword"
@layout SettingsLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using StockSense.Web.Components.Account
@using StockSense.Domain.Entities
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityUserAccessor UserAccessor
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ChangePassword> Logger

<PageTitle>Change password</PageTitle>

<h1 style="font-size: var(--text-2xl); font-weight: var(--font-semibold); color: var(--foreground); margin: 0;">Password</h1>
<h2 style="font-size: var(--text-base); font-weight: var(--font-normal); color: var(--muted-foreground); margin: 0;">Update your account password.</h2>
<div style="border-top: 1px solid var(--border); margin: var(--space-3) 0;"></div>

@* --- CUSTOM STATUS MESSAGE --- *@
@if (!string.IsNullOrEmpty(message))
{
    var isError = message.StartsWith("Error");

    <div style="margin-bottom: var(--space-6); padding: var(--space-3); border-radius: var(--radius); border: 1px solid; display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm);
                    @(isError ? "background-color: var(--destructive-muted); border-color: var(--destructive-border); color: var(--destructive-muted-foreground);"
                                   : "background-color: var(--success-muted); border-color: var(--success-border); color: var(--success-muted-foreground);")" role="alert">

        @if (isError)
        {
            <LucideIcon Name="triangle-alert" Size="18" style="flex-shrink: 0;" />
        }
        else
        {
            <LucideIcon Name="check" Size="18" style="flex-shrink: 0;" />
        }
        <span style="font-weight: var(--font-medium);">@message</span>
    </div>
}

<EditForm Model="Input" FormName="change-password" OnValidSubmit="OnValidSubmitAsync" method="post">
    <DataAnnotationsValidator />

    @* --- VALIDATION SUMMARY --- *@
    <ValidationSummary style="margin-bottom: var(--space-6); font-size: var(--text-sm); color: var(--destructive); background-color: var(--destructive-muted); padding: var(--space-3); border: 1px solid var(--destructive-border); border-radius: var(--radius);" role="alert" />

    <div style="display: flex; flex-direction: column; gap: var(--space-4);">

        <div style="display: flex; flex-direction: column; gap: var(--space-2);">
            <label style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">Current password</label>
            <InputText type="password" @bind-Value="Input.OldPassword" autocomplete="current-password" aria-required="true"
                       style="width: 100%; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size); outline: none; box-sizing: border-box;" />
            <ValidationMessage For="() => Input.OldPassword" style="font-size: var(--text-sm); color: var(--destructive);" />
        </div>

        <div style="display: flex; flex-direction: column; gap: var(--space-2);">
            <label style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">New password</label>
            <InputText type="password" @bind-Value="Input.NewPassword" autocomplete="new-password" aria-required="true"
                       style="width: 100%; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size); outline: none; box-sizing: border-box;" />
            <ValidationMessage For="() => Input.NewPassword" style="font-size: var(--text-sm); color: var(--destructive);" />
        </div>

        <div style="display: flex; flex-direction: column; gap: var(--space-2);">
            <label style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">Confirm new password</label>
            <InputText type="password" @bind-Value="Input.ConfirmPassword" autocomplete="new-password" aria-required="true"
                       style="width: 100%; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size); outline: none; box-sizing: border-box;" />
            <ValidationMessage For="() => Input.ConfirmPassword" style="font-size: var(--text-sm); color: var(--destructive);" />
        </div>

        <button type="submit"
                style="width: 100%; margin-top: var(--space-2); padding: var(--btn-padding-y) var(--btn-padding-x); border-radius: var(--radius); background-color: var(--primary); color: var(--primary-foreground); font-size: var(--btn-font-size); font-weight: var(--btn-font-weight); border: none; cursor: pointer;">
            Update password
        </button>

    </div>
</EditForm>
@code {
    private string? message;
    private ApplicationUser user = default!;
    private bool hasPassword;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        hasPassword = await UserManager.HasPasswordAsync(user);
        if (!hasPassword)
        {
            RedirectManager.RedirectTo("Account/Manage/SetPassword");
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var changePasswordResult = await UserManager.ChangePasswordAsync(user, Input.OldPassword, Input.NewPassword);
        if (!changePasswordResult.Succeeded)
        {
            message = $"Error: {string.Join(",", changePasswordResult.Errors.Select(error => error.Description))}";
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        Logger.LogInformation("User changed their password successfully.");
        RedirectManager.RedirectToCurrentPageWithStatus("Your password has been changed", HttpContext);
    }

    private sealed class InputModel
    {
        [Required]
        [DataType(DataType.Password)]
        [Display(Name = "Current password")]
        public string OldPassword { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        [Display(Name = "New password")]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm new password")]
        [Compare("NewPassword", ErrorMessage = "The new password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}