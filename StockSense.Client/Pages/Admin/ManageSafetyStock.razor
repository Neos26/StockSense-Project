@page "/admin/stock"
@layout AdminLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Domain.Entities
@using System.Net.Http.Json
@using StockSense.Client.Layout
@inject HttpClient Http

<PageTitle>Inventory & Pricing</PageTitle>

<div style="max-width: 1200px; margin: 0 auto; padding: var(--space-6);">

    @* --- Dashboard Header --- *@
    <header class="page-header">
        <div>
            <h1 style="font-size: 2.25rem; font-weight: 800; letter-spacing: -0.025em; margin: 0; color: var(--foreground);">Stocks & Pricing</h1>
            <p style="color: var(--muted-foreground); margin-top: var(--space-1); font-size: var(--text-lg);">Manage unit costs and inventory thresholds for automated procurement.</p>
        </div>

        @if (products != null)
        {
            <div class="kpi-group">
                <div class="kpi-card">
                    <span class="kpi-label">At Risk</span>
                    <span class="kpi-value destructive">@products.Count(p => p.CurrentStock <= p.ReorderTarget)</span>
                </div>
                <div class="kpi-card">
                    <span class="kpi-label">Healthy</span>
                    <span class="kpi-value healthy">@products.Count(p => p.CurrentStock > p.ReorderTarget)</span>
                </div>
            </div>
        }
    </header>

    @* --- Search and Filter Bar --- *@
    <div class="filter-bar">
        <div class="search-wrapper">
            <div class="search-icon">
                <LucideIcon Name="search" Size="18" />
            </div>
            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Search product name or brand..." class="search-input" />
        </div>

        <select @bind="categoryFilter" class="filter-select">
            <option value="All">All Categories</option>
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <option value="@cat">@cat</option>
                }
            }
        </select>

        <select @bind="statusFilter" class="filter-select status-select">
            <option value="All">All Statuses</option>
            <option value="AtRisk">At Risk</option>
            <option value="Healthy">Healthy</option>
        </select>
    </div>

    @if (products == null)
    {
        <div style="display: grid; place-items: center; min-height: 40vh;">
            <div style="text-align: center;">
                <BbSpinner Size="SpinnerSize.Large" />
                <p style="margin-top: var(--space-4); color: var(--muted-foreground);">Analyzing inventory levels...</p>
            </div>
        </div>
    }
    else
    {
        @* --- Product Table --- *@
        <div style="background: var(--card); border: 1px solid var(--border); border-radius: calc(var(--radius) * 1.5); box-shadow: var(--shadow-sm); overflow: hidden;">
            <div class="table-container">
                <table class="responsive-table">
                    <thead>
                        <tr style="background: var(--muted)/30; border-bottom: 1px solid var(--border);">
                            <th style="text-align: left; padding: var(--space-4) var(--space-6); font-weight: 600; color: var(--muted-foreground);">Product Details</th>
                            <th style="text-align: left; padding: var(--space-4); font-weight: 600; color: var(--muted-foreground);">Stock Status</th>
                            <th style="text-align: center; padding: var(--space-4); font-weight: 600; color: var(--muted-foreground);">Unit Price</th>
                            <th style="text-align: center; padding: var(--space-4); font-weight: 600; color: var(--muted-foreground);">Safety Target</th>
                            <th style="text-align: right; padding: var(--space-4) var(--space-6);"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in FilteredProducts)
                        {
                            var isLow = p.CurrentStock <= p.ReorderTarget;
                            var stockPercentage = p.ReorderTarget == 0 ? 100 : (Math.Min((double)p.CurrentStock / (p.ReorderTarget * 1.5), 1.0) * 100);

                            <tr class="stock-row" style="border-bottom: 1px solid var(--border); transition: background 0.2s;">
                                <td style="padding: var(--space-5) var(--space-6);">
                                    <div style="font-weight: 700; color: var(--foreground); font-size: var(--text-base);">@p.Name</div>
                                    <div style="display: flex; gap: 8px; align-items: center; margin-top: 4px;">
                                        <span style="font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.025em;">@p.Brand</span>
                                        <span style="height: 4px; width: 4px; background: var(--border); border-radius: 50%;"></span>
                                        <span style="font-size: var(--text-xs); color: var(--primary); font-weight: 600;">@p.Category</span>
                                    </div>
                                </td>
                                <td style="padding: var(--space-5) var(--space-4); width: 240px;">
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: var(--text-sm);">
                                        <span style="font-weight: 600; color: @(isLow ? "var(--destructive)" : "var(--foreground)")">
                                            @p.CurrentStock units
                                        </span>
                                        <span style="color: var(--muted-foreground);">Min: @p.ReorderTarget</span>
                                    </div>
                                    <div style="height: 8px; width: 100%; background: var(--muted); border-radius: 10px; overflow: hidden;">
                                        <div style="height: 100%; width: @stockPercentage%; background: @(isLow ? "var(--destructive)" : "#10b981"); transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);"></div>
                                    </div>
                                </td>
                                <td style="padding: var(--space-5) var(--space-4); text-align: center;">
                                    <span style="font-weight: 600; color: var(--foreground); font-size: var(--text-sm);">
                                        $@p.Price.ToString("F2")
                                    </span>
                                </td>
                                <td style="padding: var(--space-5) var(--space-4); text-align: center;">
                                    <span style="background: var(--background); padding: 6px 12px; border-radius: 8px; border: 1px solid var(--border); font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: var(--text-sm);">
                                        @p.ReorderTarget
                                    </span>
                                </td>
                                <td style="padding: var(--space-5) var(--space-6); text-align: right;">
                                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="() => OpenEditModal(p)">
                                        <LucideIcon Name="sliders-horizontal" Size="16" style="margin-right: 8px;" /> Adjust
                                    </BbButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* --- Edit Modal (Safety Stock & Price) --- *@
@if (showModal && selectedProduct != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(6px); display: flex; justify-content: center; align-items: center; z-index: 1000; animation: modalAppear 0.25s ease-out; padding: 20px;">
        <div style="background: var(--card); width: 100%; max-width: 480px; border-radius: 24px; border: 1px solid var(--border); box-shadow: var(--shadow-2xl); padding: var(--space-8); position: relative;">

            <div style="text-align: center; margin-bottom: var(--space-8);">
                <div style="width: 56px; height: 56px; background: var(--primary)/10; color: var(--primary); border-radius: 16px; display: grid; place-items: center; margin: 0 auto var(--space-4) auto;">
                    <LucideIcon Name="settings-2" Size="28" />
                </div>
                <h3 style="margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--foreground);">Update Product</h3>
                <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin-top: 6px;">@selectedProduct.Name — @selectedProduct.Brand</p>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-bottom: var(--space-8);">
                <div>
                    <label style="display: block; font-size: var(--text-xs); font-weight: 800; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 10px; letter-spacing: 0.05em;">Unit Price ($)</label>
                    <input type="number" step="0.01" @bind="tempPrice"
                           style="width: 100%; padding: 14px; border-radius: 12px; border: 2px solid var(--border); background: var(--background); font-size: 1.15rem; font-weight: 700; text-align: center; color: var(--foreground); outline: none;"
                           class="focus-input" />
                </div>
                <div>
                    <label style="display: block; font-size: var(--text-xs); font-weight: 800; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 10px; letter-spacing: 0.05em;">Safety Level</label>
                    <input type="number" @bind="tempSafetyStock"
                           style="width: 100%; padding: 14px; border-radius: 12px; border: 2px solid var(--border); background: var(--background); font-size: 1.15rem; font-weight: 700; text-align: center; color: var(--foreground); outline: none;"
                           class="focus-input" />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3);">
                <BbButton Variant="ButtonVariant.Ghost" OnClick="CloseModal" style="height: 48px; font-weight: 600;">Cancel</BbButton>
                <BbButton Variant="ButtonVariant.Default" OnClick="SaveSettings" Disabled="isSaving" style="height: 48px; font-weight: 600;">
                    @if (isSaving)
                    {
                        <BbSpinner Size="SpinnerSize.Small" />
                    }
                    else
                    {
                        <span>Save Changes</span>
                    }
                </BbButton>
            </div>
        </div>
    </div>
}

<style>
    .stock-row:hover {
        background-color: var(--muted)/30;
    }

    .focus-input:focus {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 4px var(--primary)/15;
    }

    @@keyframes modalAppear {
        from {
            opacity: 0;
            transform: translateY(20px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: var(--space-8);
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .kpi-group {
        display: flex;
        gap: var(--space-4);
    }

    .kpi-card {
        background: var(--card);
        padding: var(--space-3) var(--space-5);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        text-align: center;
        min-width: 120px;
    }

    .kpi-label {
        display: block;
        font-size: var(--text-xs);
        color: var(--muted-foreground);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .kpi-value {
        font-size: var(--text-2xl);
        font-weight: 800;
    }

        .kpi-value.destructive {
            color: var(--destructive);
        }

        .kpi-value.healthy {
            color: #10b981;
        }

    .filter-bar {
        display: flex;
        gap: var(--space-3);
        margin-bottom: var(--space-6);
        align-items: center;
        flex-wrap: wrap;
    }

    .search-wrapper {
        position: relative;
        flex: 2;
        min-width: 250px;
    }

    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted-foreground);
    }

    .search-input {
        width: 100%;
        padding: 10px 10px 10px 40px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--foreground);
    }

    .filter-select {
        flex: 1;
        padding: 10px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--foreground);
        min-width: 140px;
    }

    .table-container {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .responsive-table {
        width: 100%;
        min-width: 750px;
        border-collapse: collapse;
    }

    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .kpi-group {
            width: 100%;
            justify-content: space-between;
        }

        .filter-bar {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

@code {
    private List<Product>? products;
    private List<string>? categories;
    private Product? selectedProduct;
    private int tempSafetyStock;
    private decimal tempPrice;
    private bool showModal = false;
    private bool isSaving = false;

    private string searchQuery = "";
    private string statusFilter = "All";
    private string categoryFilter = "All";

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        try
        {
            products = await Http.GetFromJsonAsync<List<Product>>("api/products");
            if (products != null)
            {
                categories = products
                    .Where(p => !string.IsNullOrEmpty(p.Category))
                    .Select(p => p.Category)
                    .Distinct()
                    .OrderBy(c => c)
                    .ToList();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Fetch error: {ex.Message}"); }
    }

    private IEnumerable<Product> FilteredProducts => products?
        .Where(p => string.IsNullOrWhiteSpace(searchQuery) ||
                    p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Brand.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(p => categoryFilter == "All" || p.Category == categoryFilter)
        .Where(p => statusFilter == "All" ||
                   (statusFilter == "AtRisk" && p.CurrentStock <= p.ReorderTarget) ||
                   (statusFilter == "Healthy" && p.CurrentStock > p.ReorderTarget))
        ?? Enumerable.Empty<Product>();

    private void OpenEditModal(Product p)
    {
        selectedProduct = p;
        tempSafetyStock = p.ReorderTarget;
        tempPrice = p.Price;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedProduct = null;
    }

    private async Task SaveSettings()
    {
        // Ensure the decimal is captured correctly
        selectedProduct.Price = tempPrice;
        selectedProduct.ReorderTarget = tempSafetyStock;

        var response = await Http.PutAsJsonAsync($"api/products/{selectedProduct.Id}", selectedProduct);

        if (response.IsSuccessStatusCode)
        {
            // Success logic
        }
    }
}