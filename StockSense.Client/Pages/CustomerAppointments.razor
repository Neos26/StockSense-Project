@page "/my-bookings"
@layout PublicLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using StockSense.Client.Layout
@inject HttpClient Http

@attribute [Authorize]

<PageTitle>My Appointments</PageTitle>

<div style="width: 100%; max-width: 900px; margin: 0 auto; padding: var(--space-8) var(--space-4);">

    <div style="margin-bottom: var(--space-6);">
        <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">My Appointments</h1>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Your booking history and appointment status.</p>
    </div>

    @if (isLoading)
    {
        <div style="display: flex; align-items: center; gap: var(--space-3); color: var(--muted-foreground); padding: var(--space-8); justify-content: center;">
            <span style="font-size: var(--text-sm);">Loading your records...</span>
        </div>
    }
    else if (myAppointments == null || !myAppointments.Any())
    {
        <div style="text-align: center; padding: var(--space-8); background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); display: flex; flex-direction: column; align-items: center; gap: var(--space-4);">
            <div>
                <p style="font-size: var(--text-base); font-weight: var(--font-medium); color: var(--foreground); margin: 0 0 var(--space-1) 0;">No appointments yet</p>
                <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">You have no booking history yet.</p>
            </div>
            <a href="/appointment" style="padding: 10px 20px; background: var(--primary); color: white; border-radius: var(--radius); text-decoration: none; font-weight: bold;">Book your first appointment</a>
        </div>
    }
    else
    {
        @* --- ARCHIVE TOGGLE --- *@
        <div style="display: flex; justify-content: flex-end; margin-bottom: var(--space-3); align-items: center; gap: 8px;">
            <input type="checkbox" @bind="showAllHistory" id="bookingArchiveToggle" />
            <label for="bookingArchiveToggle" style="font-size: var(--text-xs); color: var(--muted-foreground); cursor: pointer;">Show older history</label>
        </div>

        <div style="display: flex; flex-direction: column; gap: var(--space-3);">
            @foreach (var appt in FilteredAppointments)
            {
                <div style="background-color: var(--card); border: 1px solid var(--border); border-left: 4px solid @GetStatusColor(appt.Status); border-radius: var(--radius); padding: var(--space-4) var(--space-5); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.01)'" onmouseout="this.style.transform='scale(1)'">

                    @* HEADER *@
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-3); flex-wrap: wrap; gap: var(--space-2);">
                        <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground);">
                            @appt.AppointmentDate.ToString("MMM dd, yyyy") at @appt.TimeSlot
                        </span>
                        <span style="padding: 2px 10px; border-radius: 9999px; font-size: 0.7rem; font-weight: bold; text-transform: uppercase; background: rgba(255,255,255,0.05); color: @GetStatusColor(appt.Status); border: 1px solid @GetStatusColor(appt.Status);">
                            @appt.Status
                        </span>
                    </div>

                    @* BODY *@
                    <div style="display: flex; flex-direction: column; gap: 6px;">
                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">
                            <span style="font-weight: bold; color: var(--foreground);">Mechanic:</span>
                            @(string.IsNullOrEmpty(appt.MechanicName) ? "Unassigned" : appt.MechanicName)
                        </p>

                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">
                            <span style="font-weight: bold; color: var(--foreground);">Services:</span> @appt.ServicesRequested
                        </p>

                        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 8px; border-top: 1px solid var(--border); margin-top: 4px;">
                            <span style="font-size: var(--text-xs); color: var(--muted-foreground);">Duration: @appt.DurationMinutes mins</span>
                            <span style="font-size: var(--text-sm); font-weight: bold; color: var(--primary);">₱@appt.TotalAmount.ToString("N2")</span>
                        </div>

                        <p style="font-size: 0.65rem; color: var(--muted-foreground); margin: 4px 0 0 0; font-style: italic;">
                            Ref: Booked on @appt.CreatedAt.ToString("MM/dd/yy h:mm tt")
                        </p>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private List<Appointment>? myAppointments;
    private bool isLoading = true;
    private bool showAllHistory = false;

    // --- FILTER LOGIC ---
    private IEnumerable<Appointment> FilteredAppointments
    {
        get
        {
            if (myAppointments == null) return Enumerable.Empty<Appointment>();

            // 1. Always show active ones
            var active = myAppointments.Where(a => a.Status == "Pending" || a.Status == "Confirmed");

            // 2. Filter history based on 30-day rule
            var history = myAppointments.Where(a => a.Status == "Completed" || a.Status == "Cancelled");

            if (!showAllHistory)
            {
                var limitDate = DateTime.Now.AddDays(-30);
                history = history.Where(a => a.AppointmentDate >= limitDate);
            }

            return active.Concat(history).OrderByDescending(a => a.AppointmentDate);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                string customerName = user.Identity.Name ?? "User";

                try
                {
                    var profile = await Http.GetFromJsonAsync<UserProfile>("api/user/profile");
                    if (profile != null) customerName = $"{profile.FirstName} {profile.LastName}".Trim();
                }
                catch { }

                try
                {
                    myAppointments = await Http.GetFromJsonAsync<List<Appointment>>($"api/appointments/my-bookings?name={Uri.EscapeDataString(customerName)}");
                }
                catch
                {
                    myAppointments = new();
                }
            }
        }
        isLoading = false;
    }

    private string GetStatusColor(string status) => status switch
    {
        "Pending" => "#f59e0b",
        "Confirmed" => "#3b82f6",
        "Completed" => "#10b981",
        "Cancelled" => "#ef4444",
        _ => "#888888"
    };
}
