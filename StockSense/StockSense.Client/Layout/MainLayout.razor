@inherits LayoutComponentBase

<div class="min-h-screen" style="background-color: var(--background); color: var(--foreground); font-family: var(--font-sans);">
    <div class="flex">
        <aside style="width: 16rem; min-height: 100vh; background-color: var(--sidebar); border-right: 1px solid var(--sidebar-border);">
            <NavMenu />
        </aside>

        <main class="flex-1 flex flex-col">
            <div style="padding: 0.5rem 1rem; border-bottom: 1px solid var(--border); display: flex; justify-content: flex-end;">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" style="color: var(--muted-foreground); font-size: 0.875rem;">About</a>
            </div>
    <main>


            <article style="padding: 1.5rem; flex: 1;">
                @Body
            </article>
        </main>
    </div>
</div>

<BbPortalHost />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    // Check if the current URL contains "Account/Manage"
    private bool IsAccountManagePage =>
        NavigationManager.ToBaseRelativePath(NavigationManager.Uri).StartsWith("Account/Manage", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        // Tell the layout to listen for URL changes so it can hide/show the bar dynamically
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Re-evaluate the page and update the layout
        StateHasChanged();
    }

    public void Dispose()
    {
        // Clean up the listener to prevent memory leaks
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}