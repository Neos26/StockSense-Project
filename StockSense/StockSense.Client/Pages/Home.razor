@page "/"
@layout EmptyLayout
@using BlazorBlueprint.Components
@inject NavigationManager NavigationManager

<div style="min-height: 100%; background-color: var(--background); display: flex; align-items: center; justify-content: center; font-family: var(--font-sans);">
    <div style="text-align: center; display: flex; flex-direction: column; align-items: center; gap: var(--space-6); padding: var(--space-8);">

        <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: var(--font-extrabold); color: var(--foreground); line-height: 1.15; letter-spacing: -0.02em; margin: 0;">
            Turning your<br />
            2-wheeled dreams<br />
            into <span style="color: var(--primary);">reality.</span>
        </h1>

        <p style="font-size: var(--text-lg); font-weight: var(--font-medium); color: var(--muted-foreground); margin: 0;">
            Appoint your next visit today.
        </p>

        <BbButton Href="/appointment" Size="ButtonSize.Large">
            Book now
        </BbButton>

    </div>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
    }
}