@page "/build"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout EmptyLayout
@using StockSense.Shared
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Nav

@attribute [Authorize]

@* --- FULL PAGE LOADING OVERLAY --- *@
@if (isLoading)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
                    background: #000; display: flex; flex-direction: column;
                    justify-content: center; align-items: center; z-index: 9999;">

        <div class="spinner-grow text-danger" role="status" style="width: 3rem; height: 3rem;"></div>

        <h3 style="color: white; margin-top: 20px; font-family: 'Segoe UI', sans-serif; letter-spacing: 3px; font-weight: 200;">
            <span style="font-weight: 700; color: #d32f2f;">SAP</span>SHOP
        </h3>
        <p style="color: #666; font-size: 0.8rem; text-transform: uppercase; margin-top: 10px;">Loading Inventory...</p>
    </div>
}

<div class="page-fade-in" style="display: @(isLoading ? "none" : "flex"); height: calc(100vh - 60px); background-color: #000; color: white; overflow: hidden;">

    @* --- LEFT SIDEBAR --- *@
    <div style="width: 350px; background-color: #111; padding: 20px; display: flex; flex-direction: column; border-right: 1px solid #333;">
        <h2 style="color: #ff3e3e; margin-bottom: 20px; font-style: italic;">SAP SHOP</h2>

        @* CATEGORY FILTERS *@
        <div style="flex: 1; overflow-y: auto; margin-bottom: 20px;">
            <h3 style="font-size: 1.1rem; margin-bottom: 15px; border-bottom: 1px solid #333; padding-bottom: 10px;">Select your parts</h3>
            @foreach (var category in UniqueCategories)
            {
                <div style="margin-bottom: 10px;">
                    <button @onclick="() => ToggleCategory(category)"
                            style="width: 100%; text-align: left; background: #1a1a1a; border: none; color: white; padding: 12px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; border-radius: 5px;">
                        <span style="font-weight: bold;">@category</span>
                        <span style="color: #666;">@(expandedCategory == category ? "▲" : "▼")</span>
                    </button>
                    @if (expandedCategory == category)
                    {
                        <div style="background: #111; padding: 10px; border-left: 2px solid #333;">
                            <button @onclick="() => selectedBrand = null" style="display: block; width: 100%; text-align: left; background: none; border: none; color: @(selectedBrand == null ? "#ff3e3e" : "#aaa"); cursor: pointer; padding: 5px 0;">All Brands</button>
                            @foreach (var brand in GetBrandsByCategory(category))
                            {
                                <button @onclick="() => selectedBrand = brand" style="display: block; width: 100%; text-align: left; background: none; border: none; color: @(selectedBrand == brand ? "white" : "#aaa"); cursor: pointer; padding: 5px 0;">@brand</button>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* --- SUMMARY SECTION --- *@
        <div style="background: #1a1a1a; padding: 20px; border-radius: 10px; border: 1px solid #333;">
            <h3 style="margin-top: 0;">Your current build</h3>
            <div style="max-height: 150px; overflow-y: auto; margin-bottom: 15px; border-bottom: 1px solid #333; padding-bottom: 10px;">
                @if (!selectedParts.Any())
                {
                    <p style="color: #555; font-size: 0.9em;">Select parts to generate a quote or submit a build.</p>
                }
                else
                {
                    @foreach (var part in selectedParts)
                    {
                        <div style="display: flex; justify-content: space-between; font-size: 0.9em; margin-bottom: 8px; align-items: center;">
                            <div style="flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 10px;">@part.Name</div>
                            <button @onclick="() => TogglePart(part)" style="background: none; border: none; color: #555; cursor: pointer;">✕</button>
                        </div>
                    }
                }
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div style="margin-bottom: 10px; padding: 10px; border-radius: 5px; background: @(isSuccess ? "#1b5e20" : "#b71c1c"); color: white; font-size: 0.9em;">@statusMessage</div>
            }

            <div style="display: flex; flex-direction: column; gap: 10px;">
                <button @onclick="SendEmailQuote" disabled="@isProcessing" style="width: 100%; padding: 12px; background: #333; color: white; font-weight: bold; border: 1px solid #555; border-radius: 5px; cursor: pointer;">SEND QUOTE TO EMAIL</button>
                <button @onclick="SubmitBuildToAdmin" disabled="@isProcessing" style="width: 100%; padding: 12px; background: #ff3e3e; color: white; font-weight: bold; border: none; border-radius: 5px; cursor: pointer;">SUBMIT BUILD TO SHOP</button>
                <button @onclick='() => Nav.NavigateTo("/my-builds")' style="width: 100%; padding: 12px; background: transparent; color: #ff3e3e; font-weight: bold; border: 2px solid #ff3e3e; border-radius: 5px; cursor: pointer; margin-top: 10px;">
                    VIEW MY BUILDS
                </button>
            </div>
        </div>
    </div>

    @* --- RIGHT CONTENT --- *@
    <div style="flex: 1; padding: 30px; overflow-y: auto;">
        <h2 style="margin-bottom: 10px;">@(selectedBrand ?? "All") @expandedCategory</h2>
        @if (products != null)
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;">
                @foreach (var product in FilteredProducts)
                {
                    bool isSelected = selectedParts.Any(p => p.Id == product.Id);
                    <div @onclick="() => TogglePart(product)" style="cursor: pointer; background: #111; border: 2px solid @(isSelected ? "#ff3e3e" : "#333"); padding: 15px; border-radius: 8px;">
                        <img src="@product.ImageUrl" style="width:100%; height:120px; object-fit:cover; background:#222;" />
                        <h4 style="margin: 10px 0;">@product.Name</h4>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .page-fade-in {
        animation: fadeIn 0.4s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private List<Product>? products;
    private List<Product> selectedParts = new();
    private string expandedCategory = "Genuine Parts";
    private string? selectedBrand = null;
    private bool isProcessing = false;
    private string statusMessage = "";
    private bool isSuccess = false;
    private bool isLoading = true; // New loading state

    private IEnumerable<string> UniqueCategories => products?.Select(p => p.Category).Distinct() ?? Array.Empty<string>();
    private IEnumerable<Product> FilteredProducts => products?.Where(p => (string.IsNullOrEmpty(expandedCategory) || p.Category == expandedCategory) && (string.IsNullOrEmpty(selectedBrand) || p.Brand == selectedBrand)) ?? Array.Empty<Product>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            products = await Http.GetFromJsonAsync<List<Product>>("api/products");

            if (products != null && products.Any())
                expandedCategory = products.First().Category;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            statusMessage = "Could not load inventory.";
        }
        finally
        {
            // Small delay for a smooth UI transition
            await Task.Delay(200);
            isLoading = false;
        }
    }

    private void ToggleCategory(string category) { expandedCategory = category; selectedBrand = null; }
    private IEnumerable<string> GetBrandsByCategory(string category) => products?.Where(p => p.Category == category).Select(p => p.Brand).Distinct() ?? Array.Empty<string>();
    private void TogglePart(Product product) { if (selectedParts.Any(p => p.Id == product.Id)) selectedParts.RemoveAll(p => p.Id == product.Id); else selectedParts.Add(product); }

    private async Task SendEmailQuote()
    {
        if (!selectedParts.Any()) { statusMessage = "Please select parts first."; isSuccess = false; return; }

        var authState = await AuthStateTask!;
        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            Nav.NavigateTo($"/Account/Login?returnUrl={Uri.EscapeDataString(Nav.Uri)}", true);
            return;
        }

        isProcessing = true;
        statusMessage = "Sending email quote...";

        try
        {
            var userEmail = authState.User.Identity.Name ?? "test@example.com";
            var response = await Http.PostAsJsonAsync("api/products/send-quote", new
            {
                UserEmail = userEmail,
                ProductIds = selectedParts.Select(p => p.Id).ToList()
            });

            if (response.IsSuccessStatusCode) { statusMessage = "Quote sent to your email!"; isSuccess = true; }
            else { statusMessage = "Failed to send email."; isSuccess = false; }
        }
        catch (Exception ex) { statusMessage = $"Error: {ex.Message}"; isSuccess = false; }
        isProcessing = false;
    }

    private async Task SubmitBuildToAdmin()
    {
        var authState = await AuthStateTask!;
        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            Nav.NavigateTo($"Account/Login?returnUrl={Uri.EscapeDataString(Nav.Uri)}", true);
            return;
        }

        if (!selectedParts.Any()) { statusMessage = "Please select parts first."; return; }

        isProcessing = true;
        statusMessage = "Submitting to admin...";

        try
        {
            var userName = authState.User.Identity.Name ?? "Guest";
            var jsonString = JsonSerializer.Serialize(selectedParts);

            var buildRequest = new BuildRequest
            {
                CustomerName = userName,
                SelectedPartsJson = jsonString,
                TotalPrice = selectedParts.Sum(p => p.Price),
                Status = "Pending",
                CreatedAt = DateTime.Now
            };

            var response = await Http.PostAsJsonAsync("api/builds", buildRequest);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Build submitted successfully!";
                isSuccess = true;
                selectedParts.Clear();
            }
            else { statusMessage = "Failed to submit build."; isSuccess = false; }
        }
        catch (Exception ex) { statusMessage = $"Error: {ex.Message}"; isSuccess = false; }
        isProcessing = false;
    }
}