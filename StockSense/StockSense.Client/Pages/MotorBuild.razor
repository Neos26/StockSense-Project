@page "/build"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout PublicLayout
@using StockSense.Shared
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager Nav

@attribute [Authorize]

<PageTitle>Build Your Motor</PageTitle>

<AuthorizeView>
    <Authorized>

        @if (isLoading)
        {
            <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 9999; gap: var(--space-4);">
                <BbSpinner Size="SpinnerSize.Large" />
                <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-1);">
                    <span style="font-weight: 800; font-style: italic; font-size: 1.5rem; color: var(--primary); letter-spacing: 0.05em;">SAP<br />SHOP</span>
                    <p style="color: var(--muted-foreground); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">Loading Inventory...</p>
                </div>
            </div>
        }

        <div style="display: @(isLoading ? "none" : "flex"); height: calc(100vh - 3.5rem); overflow: hidden; animation: fadeIn 0.4s ease-in;">

            @* --- LEFT SIDEBAR --- *@
            <div style="width: 300px; flex-shrink: 0; display: flex; flex-direction: column; background-color: var(--card); border-right: 1px solid var(--border); overflow: hidden;">

                <div style="padding: var(--space-4); border-bottom: 1px solid var(--border); flex-shrink: 0;">
                    <h2 style="font-size: var(--text-lg); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">Build Your Motor</h2>
                    <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0;">Select parts by category and brand.</p>
                </div>

                <div style="flex: 1; overflow-y: auto; padding: var(--space-3) var(--space-2);">
                    @foreach (var category in UniqueCategories)
                    {
                        <div style="margin-bottom: var(--space-1);">
                            <button @onclick="() => ToggleCategory(category)"
                                    style="width: 100%; display: flex; justify-content: space-between; align-items: center; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); background-color: @(expandedCategory == category ? "var(--accent)" : "transparent"); color: var(--foreground); border: none; cursor: pointer; font-family: var(--font-sans);">
                                <span>@category</span>
                                <LucideIcon Name="@(expandedCategory == category ? "chevron-up" : "chevron-down")" Size="14" />
                            </button>
                            @if (expandedCategory == category)
                            {
                                <div style="padding: var(--space-1) var(--space-2) var(--space-2) var(--space-4);">
                                    <button @onclick="() => selectedBrand = null"
                                            style="display: block; width: 100%; text-align: left; background: none; border: none; font-size: var(--text-sm); cursor: pointer; padding: var(--space-1) var(--space-2); border-radius: var(--radius); color: @(selectedBrand == null ? "var(--primary)" : "var(--muted-foreground)"); font-family: var(--font-sans);">
                                        All Brands
                                    </button>
                                    @foreach (var brand in GetBrandsByCategory(category))
                                    {
                                        <button @onclick="() => selectedBrand = brand"
                                                style="display: block; width: 100%; text-align: left; background: none; border: none; font-size: var(--text-sm); cursor: pointer; padding: var(--space-1) var(--space-2); border-radius: var(--radius); color: @(selectedBrand == brand ? "var(--foreground)" : "var(--muted-foreground)"); font-family: var(--font-sans);">
                                            @brand
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Build Summary *@
                <div style="padding: var(--space-4); border-top: 1px solid var(--border); flex-shrink: 0; background-color: var(--background);">
                    <p style="font-size: var(--text-xs); font-weight: var(--font-semibold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-2) 0;">Your Build</p>

                    <div style="max-height: 120px; overflow-y: auto; margin-bottom: var(--space-3);">
                        @if (!selectedParts.Any())
                        {
                            <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0;">Select parts to generate a quote or submit a build.</p>
                        }
                        else
                        {
                            @foreach (var part in selectedParts)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-1);">
                                    <span style="font-size: var(--text-xs); color: var(--foreground); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; padding-right: var(--space-2);">@part.Name</span>
                                    <button @onclick="() => TogglePart(part)" style="background: none; border: none; cursor: pointer; color: var(--muted-foreground); padding: 0; display: flex; align-items: center;">
                                        <LucideIcon Name="x" Size="12" />
                                    </button>
                                </div>
                            }
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div style="margin-bottom: var(--space-3); padding: var(--space-2) var(--space-3); border-radius: var(--radius); background-color: @(isSuccess ? "var(--success-muted)" : "var(--destructive-muted)"); border: 1px solid @(isSuccess ? "var(--success-border)" : "var(--destructive-border)"); color: @(isSuccess ? "var(--success-muted-foreground)" : "var(--destructive-muted-foreground)"); font-size: var(--text-xs);">
                            @statusMessage
                        </div>
                    }

                    <div style="display: flex; flex-direction: column; gap: var(--space-2);">
                        <BbButton Variant="ButtonVariant.Outline" Class="w-full" OnClick="SendEmailQuote" Disabled="@isProcessing">
                            Send Quote to Email
                        </BbButton>
                        <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="SubmitBuildToAdmin" Disabled="@isProcessing">
                            Submit Build to Shop
                        </BbButton>
                        <BbButton Variant="ButtonVariant.Ghost" Class="w-full" OnClick='() => Nav.NavigateTo("/my-builds", forceLoad: true)'>
                            View My Builds
                        </BbButton>
                    </div>
                </div>
            </div>

            @* --- RIGHT CONTENT --- *@
            <div style="flex: 1; overflow-y: auto; padding: var(--space-6);">
                <h2 style="font-size: var(--text-xl); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0;">
                    @(selectedBrand ?? "All") @expandedCategory
                </h2>
                @if (products != null)
                {
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: var(--space-4);">
                        @foreach (var product in FilteredProducts)
                        {
                            bool isSelected = selectedParts.Any(p => p.Id == product.Id);
                            <div @onclick="() => TogglePart(product)"
                                 style="cursor: pointer; background-color: var(--card); border: 2px solid @(isSelected ? "var(--primary)" : "var(--border)"); padding: var(--space-3); border-radius: var(--radius); transition: border-color 0.15s;">
                                <img src="@product.ImageUrl" style="width: 100%; height: 100px; object-fit: cover; border-radius: calc(var(--radius) - 2px); background-color: var(--muted); margin-bottom: var(--space-2);" />
                                <div style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">@product.Name</div>
                                <div style="font-size: var(--text-xs); color: var(--muted-foreground);">@product.Brand</div>
                                <div style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--primary); margin-top: var(--space-1);">₱@product.Price.ToString("N0")</div>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>

    </Authorized>

    <NotAuthorized>
        <div style="height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; color: var(--foreground); gap: var(--space-4);">
            <BbSpinner Size="SpinnerSize.Large" />
            <h2 style="color: var(--destructive); font-weight: var(--font-bold); letter-spacing: 0.1em;">SESSION EXPIRED</h2>
            <p style="color: var(--muted-foreground); font-size: var(--text-sm);">Securing your build data... Redirecting to Home.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private List<Product>? products;
    private List<Product> selectedParts = new();
    private string expandedCategory = "Genuine Parts";
    private string? selectedBrand = null;
    private bool isProcessing = false;
    private string statusMessage = "";
    private bool isSuccess = false;
    private bool isLoading = true;

    private IEnumerable<string> UniqueCategories => products?.Select(p => p.Category).Distinct() ?? Array.Empty<string>();
    private IEnumerable<Product> FilteredProducts => products?.Where(p => (string.IsNullOrEmpty(expandedCategory) || p.Category == expandedCategory) && (string.IsNullOrEmpty(selectedBrand) || p.Brand == selectedBrand)) ?? Array.Empty<Product>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            products = await Http.GetFromJsonAsync<List<Product>>("api/products");
            if (products != null && products.Any())
                expandedCategory = products.First().Category;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            statusMessage = "Could not load inventory.";
        }
        finally
        {
            await Task.Delay(200);
            isLoading = false;
        }
    }

    private void ToggleCategory(string category) { expandedCategory = category; selectedBrand = null; }
    private IEnumerable<string> GetBrandsByCategory(string category) => products?.Where(p => p.Category == category).Select(p => p.Brand).Distinct() ?? Array.Empty<string>();
    private void TogglePart(Product product) { if (selectedParts.Any(p => p.Id == product.Id)) selectedParts.RemoveAll(p => p.Id == product.Id); else selectedParts.Add(product); }

    private async Task SendEmailQuote()
    {
        if (!selectedParts.Any()) { statusMessage = "Please select parts first."; isSuccess = false; return; }

        isProcessing = true;
        statusMessage = "Sending email quote...";

        try
        {
            var authState = await AuthStateTask!;
            var userEmail = authState.User.Identity?.Name ?? "User";
            var response = await Http.PostAsJsonAsync("api/products/send-quote", new
            {
                UserEmail = userEmail,
                ProductIds = selectedParts.Select(p => p.Id).ToList()
            });

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Nav.NavigateTo("/", forceLoad: true);
                return;
            }

            if (response.IsSuccessStatusCode) { statusMessage = "Quote sent to your email!"; isSuccess = true; }
            else { statusMessage = "Failed to send email."; isSuccess = false; }
        }
        catch { statusMessage = "Connection Error."; isSuccess = false; }
        finally { isProcessing = false; }
    }

    private async Task SubmitBuildToAdmin()
    {
        if (!selectedParts.Any()) { statusMessage = "Please select parts first."; return; }

        isProcessing = true;
        statusMessage = "Submitting to admin...";

        try
        {
            var authState = await AuthStateTask!;
            var userName = authState.User.Identity?.Name ?? "Guest";
            var jsonString = JsonSerializer.Serialize(selectedParts);

            var buildRequest = new BuildRequest
            {
                CustomerName = userName,
                SelectedPartsJson = jsonString,
                TotalPrice = selectedParts.Sum(p => p.Price),
                Status = "Pending",
                CreatedAt = DateTime.Now
            };

            var response = await Http.PostAsJsonAsync("api/builds", buildRequest);

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Nav.NavigateTo("/", forceLoad: true);
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Build submitted successfully!";
                isSuccess = true;
                selectedParts.Clear();
            }
            else { statusMessage = "Failed to submit build."; isSuccess = false; }
        }
        catch { statusMessage = "Connection Error."; isSuccess = false; }
        finally { isProcessing = false; }
    }
}