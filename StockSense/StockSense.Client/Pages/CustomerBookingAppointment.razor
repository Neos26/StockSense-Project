@page "/appointment"
@layout PublicLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using StockSense.Shared
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager NavigationManager

@attribute [Authorize]
<AuthorizeView>
    <Authorized>
        <PageTitle>Book Appointment</PageTitle>

        @if (isLoading)
        {
            <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 9999; gap: var(--space-4);">
                <div class="spinner-border text-danger" role="status"></div>
                <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-1);">
                    <span style="font-weight: 800; font-style: italic; font-size: 1.5rem; color: #ff3e3e; letter-spacing: 0.05em;">SAP<br />SHOP</span>
                    <p style="color: #888; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">Syncing with Server...</p>
                </div>
            </div>
        }

        <div style="display: @(isLoading ? "none" : "block"); animation: fadeIn 0.4s ease-in;">
            <div class="appt-layout">

                @* --- LEFT: Mechanic & Services --- *@
                <div class="appt-services">

                    @* --- MECHANIC SELECTION --- *@
                    <div style="margin-bottom: var(--space-5);">
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">Select Mechanic</h2>
                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0 0 var(--space-3) 0;">Choose your preferred technician.</p>

                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: var(--space-2);">
                            @foreach (var mech in availableMechanics)
                            {
                                bool isMechSelected = selectedMechanic == mech;
                                <button @onclick="() => SelectMechanic(mech)"
                                        style="padding: var(--space-2); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); border: 1px solid @(isMechSelected ? "var(--primary)" : "var(--border)"); background-color: @(isMechSelected ? "rgba(255,62,62,0.1)" : "var(--card)"); color: @(isMechSelected ? "var(--primary)" : "var(--foreground)"); cursor: pointer; transition: 0.2s;">
                                    @mech
                                </button>
                            }
                        </div>
                    </div>

                    @* --- SERVICE SELECTION --- *@
                    <div style="margin-bottom: var(--space-4);">
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">Select Services</h2>
                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Total Estimated Time: <span style="color: var(--primary); font-weight: bold;">@TotalDurationMinutes mins</span></p>
                    </div>

                    @* Category filter pills *@
                    <div style="display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4);">
                        <button @onclick='() => selectedCategory = "All"'
                                style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == "All" ? "var(--primary)" : "var(--border)"); background-color: @(selectedCategory == "All" ? "var(--primary)" : "transparent"); color: @(selectedCategory == "All" ? "var(--primary-foreground)" : "var(--foreground)"); cursor: pointer;">
                            All
                        </button>
                        @foreach (var cat in availableServices.Select(s => s.Category).Distinct().OrderBy(c => c))
                        {
                            <button @onclick="() => selectedCategory = cat"
                                    style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == cat ? "var(--primary)" : "var(--border)"); background-color: @(selectedCategory == cat ? "var(--primary)" : "transparent"); color: @(selectedCategory == cat ? "var(--primary-foreground)" : "var(--foreground)"); cursor: pointer;">
                                @cat
                            </button>
                        }
                    </div>

                    @* Service list *@
                    <div style="display: flex; flex-direction: column; gap: var(--space-2);">
                        @foreach (var service in FilteredServices)
                        {
                            <div @onclick="() => ToggleService(service)"
                                 style="display: flex; align-items: center; justify-content: space-between; padding: var(--space-3) var(--space-4); background-color: var(--card); border: 1.5px solid @(service.IsSelected ? "var(--primary)" : "var(--border)"); border-radius: var(--radius); cursor: pointer; transition: border-color 0.15s;">
                                <div style="display: flex; align-items: center; gap: var(--space-3);">
                                    <div style="width: 1.25rem; height: 1.25rem; border-radius: 50%; border: 2px solid @(service.IsSelected ? "var(--primary)" : "var(--border)"); background-color: @(service.IsSelected ? "var(--primary)" : "transparent"); display: flex; align-items: center; justify-content: center; transition: 0.15s;">
                                        @if (service.IsSelected)
                                        {
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--primary-foreground)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        }
                                    </div>
                                    <div>
                                        <div style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">@service.Name</div>
                                        <div style="font-size: var(--text-xs); color: var(--muted-foreground);">@service.Category • ⏱ @service.EstimatedMinutes mins</div>
                                    </div>
                                </div>
                                <span style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--primary);">₱@service.Price.ToString("N0")</span>
                            </div>
                        }
                    </div>
                </div>

                @* --- RIGHT: Calendar + Timeslots + Summary --- *@
                <div class="appt-right">
                    <div style="display: flex; flex-direction: row; gap: var(--space-2)">

                        @* Calendar *@
                        <div style="width: 65%; background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-5); margin-bottom: var(--space-4);">
                            <h3 style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0;">Choose a Date</h3>

                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-3);">
                                <button @onclick="PrevMonth" style="background: none; border: none; cursor: pointer; color: var(--foreground);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
                                <span style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground);">@calendarMonth.ToString("MMMM yyyy")</span>
                                <button @onclick="NextMonth" style="background: none; border: none; cursor: pointer; color: var(--foreground);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
                            </div>

                            <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: var(--space-1); margin-bottom: var(--space-2);">
                                @foreach (var day in new[] { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" })
                                {
                                    <div style="text-align: center; font-size: var(--text-xs); color: var(--muted-foreground); padding: var(--space-1) 0;">@day</div>
                                }
                            </div>

                            <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: var(--space-1);">
                                @foreach (var cell in CalendarCells)
                                {
                                    if (cell == null)
                                    {
                                        <div></div>
                                    }
                                    else
                                    {
                                        var d = cell.Value;
                                        bool isPast = d < DateTime.Today;
                                        bool isSelected = newAppt.AppointmentDate.Date == d.Date;
                                        bool isToday = d.Date == DateTime.Today;

                                        <button @onclick="() => SelectDate(d)" disabled="@isPast"
                                                style="aspect-ratio: 1; border-radius: var(--radius); border: 1px solid @(isSelected ? "var(--primary)" : "transparent"); background-color: @(isSelected ? "var(--primary)" : (isToday ? "#333" : "transparent")); color: @(isSelected ? "var(--primary-foreground)" : (isPast ? "var(--muted-foreground)" : "var(--foreground)")); font-size: var(--text-xs); cursor: @(isPast ? "not-allowed" : "pointer"); opacity: @(isPast ? "0.4" : "1");">
                                            @d.Day
                                        </button>
                                    }
                                }
                            </div>
                        </div>

                        @* Time Slots *@
                        <div style="display: flex; flex-direction: column; width: 35%; background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-2); margin-bottom: var(--space-4);">
                            <h3 style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-3) 0; text-align: center;">
                                @newAppt.AppointmentDate.ToString("MMM dd")
                            </h3>

                            @if (TotalDurationMinutes == 0)
                            {
                                <p style="font-size: 0.8rem; color: #888; text-align: center; padding: 10px;">Select services first to see available times.</p>
                            }
                            else
                            {
                                <div style="display: grid; grid-template-columns: 1fr; gap: var(--space-2); max-height: 220px; overflow-y: auto; padding-right: 5px;">
                                    @foreach (var time in GenerateAllTimeSlots())
                                    {
                                        bool isAvailable = IsTimeSlotAvailable(time);
                                        bool isSelected = newAppt.TimeSlot == time;

                                        <button @onclick="@(() => { if (isAvailable) { newAppt.TimeSlot = time; errorMessage = string.Empty; } })"
                                                style='padding: var(--space-2); border-radius: var(--radius); font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(isSelected ? "var(--primary)" : "var(--border)"); background-color: @(isSelected ? "var(--primary)" : "transparent"); color: @(isSelected ? "var(--primary-foreground)" : (isAvailable ? "var(--foreground)" : "var(--muted-foreground)")); cursor: @(isAvailable ? "pointer" : "not-allowed"); text-decoration: @(isAvailable ? "none" : "line-through"); opacity: @(isAvailable ? "1" : "0.3"); transition: 0.1s;'>
                                            @time
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @* Summary + Submit *@
                    <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-5);">
                        <h3 style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0; padding-bottom: var(--space-3); border-bottom: 1px solid var(--border);">Booking Summary</h3>

                        <div style="display: flex; justify-content: space-between; margin-bottom: var(--space-3);">
                            <div>
                                <p style="font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-1) 0;">Customer</p>
                                <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); margin: 0;">@newAppt.CustomerName</p>
                            </div>
                            <div style="text-align: right;">
                                <p style="font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-1) 0;">Mechanic</p>
                                <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--primary); margin: 0;">@selectedMechanic</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(newAppt.TimeSlot))
                        {
                            <div style="margin-bottom: var(--space-3); background: rgba(255,62,62,0.1); padding: 10px; border-radius: 5px; border-left: 3px solid var(--primary);">
                                <p style="font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-1) 0;">Schedule</p>
                                <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); margin: 0;">@newAppt.AppointmentDate.ToString("MMM dd, yyyy") at @newAppt.TimeSlot</p>
                                <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 4px 0 0 0;">Duration: Approx. @TotalDurationMinutes mins</p>
                            </div>
                        }

                        @* ADDED: max-height: 160px; overflow-y: auto; padding-right: 8px; *@
                        <div style="display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-4); max-height: 160px; overflow-y: auto; padding-right: 8px;">
                            @if (!SelectedServices.Any())
                            {
                                <p style="font-size: var(--text-sm); color: var(--muted-foreground); font-style: italic; margin: 0;">No services selected yet.</p>
                            }
                            @foreach (var selected in SelectedServices)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: var(--space-2); border-bottom: 1px solid var(--border);">
                                    <span style="font-size: var(--text-sm); color: var(--foreground);">@selected.Name</span>
                                    <span style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">₱@selected.Price.ToString("N0")</span>
                                </div>
                            }
                        </div>

                        <div style="display: flex; justify-content: space-between; align-items: center; padding: var(--space-3); background-color: #1a1a1a; border-radius: var(--radius); margin-bottom: var(--space-4);">
                            <span style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground);">Total</span>
                            <span style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--primary);">₱@TotalPrice.ToString("N0")</span>
                        </div>

                        @if (showSuccessMessage)
                        {
                            <div style="margin-bottom: var(--space-3); padding: var(--space-3); border-radius: var(--radius); background-color: rgba(76, 175, 80, 0.2); border: 1px solid #4CAF50; color: #81c784; font-size: var(--text-sm);">
                                Appointment booked successfully!
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div style="margin-bottom: var(--space-3); padding: var(--space-3); border-radius: var(--radius); background-color: rgba(244, 67, 54, 0.2); border: 1px solid #f44336; color: #e57373; font-size: var(--text-sm);">
                                @errorMessage
                            </div>
                        }

                        <button @onclick="HandleSubmit" disabled="@isProcessing" style="width: 100%; padding: 12px; background-color: var(--primary); color: var(--primary-foreground); border: none; border-radius: var(--radius); font-weight: bold; cursor: @(isProcessing ? "not-allowed" : "pointer");">
                            @(isProcessing ? "Processing..." : "Confirm Booking")
                        </button>

                        @* --- NEW VIEW MY APPOINTMENTS BUTTON --- *@
                        <button @onclick='() => NavigationManager.NavigateTo("/my-bookings")' type="button" style="width: 100%; padding: 12px; background-color: transparent; color: var(--primary); border: 2px solid var(--primary); border-radius: var(--radius); font-weight: bold; cursor: pointer; margin-top: 10px; transition: 0.2s;">
                            View My Appointments
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div style="height: 100vh; background: #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white;">
            <h2 style="margin-top: 20px; color: #ff3e3e;">Session Expired</h2>
            <p style="color: #666;">Redirecting to Login...</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    /* Ensure you have these CSS variables in your app.css or layout */
    :root {
        --background: #000;
        --foreground: #fff;
        --card: #111;
        --border: #333;
        --muted: #1a1a1a;
        --muted-foreground: #888;
        --primary: #ff3e3e;
        --primary-foreground: #fff;
        --radius: 8px;
        --space-1: 4px;
        --space-2: 8px;
        --space-3: 12px;
        --space-4: 16px;
        --space-5: 24px;
        --space-6: 32px;
        --text-xs: 0.75rem;
        --text-sm: 0.875rem;
        --text-base: 1rem;
        --text-xl: 1.25rem;
        --font-medium: 500;
        --font-semibold: 600;
        --font-bold: 700;
        --font-sans: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .appt-layout {
        display: flex;
        gap: var(--space-6);
        padding: var(--space-6);
        min-height: calc(100vh - 3.5rem);
        align-items: flex-start;
    }

    .appt-services {
        flex: 1;
        min-width: 0;
    }

    .appt-right {
        width: 450px;
        flex-shrink: 0;
        position: sticky;
        top: var(--space-6);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@code {
    private bool isLoading = true;
    private Appointment newAppt = new() { AppointmentDate = DateTime.Now, TimeSlot = "" };
    private bool showSuccessMessage = false;
    private bool isProcessing = false;
    private string errorMessage = "";
    private string selectedCategory = "All";

    // --- MECHANIC STATE ---
    // Start with ONLY "Any Available" as the default option
    private List<string> availableMechanics = new() { "Any Available" };
    private string selectedMechanic = "Any Available";

    public class ServiceOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public string Category { get; set; } = "General";
        public int EstimatedMinutes { get; set; } // NEW: Used for blocking out time
        public bool IsSelected { get; set; }
    }

    private List<ServiceOption> availableServices = new();
    private List<string> bookedTimeSlots = new(); // Kept up to date by the backend

    private IEnumerable<ServiceOption> FilteredServices => selectedCategory == "All" ? availableServices : availableServices.Where(s => s.Category == selectedCategory);
    private IEnumerable<ServiceOption> SelectedServices => availableServices.Where(s => s.IsSelected);

    private decimal TotalPrice => SelectedServices.Sum(s => s.Price);
    private int TotalDurationMinutes => SelectedServices.Sum(s => s.EstimatedMinutes);

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            await Task.WhenAll(LoadUserProfile(), LoadServices(), LoadMechanics(), FetchBookedSlots());
        }
        catch { errorMessage = "Connection error."; }
        finally { isLoading = false; }
    }

    private async Task LoadUserProfile()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                // 1. Set email as the default fallback
                newAppt.CustomerName = authState.User.Identity.Name ?? "User";

                // 2. Try to fetch their actual First and Last name
                try
                {
                    var profile = await Http.GetFromJsonAsync<UserProfile>("api/user/profile");
                    if (profile != null)
                    {
                        newAppt.CustomerName = $"{profile.FirstName ?? ""} {profile.LastName ?? ""}".Trim();
                    }
                }
                catch { /* Silent fallback if profile doesn't exist yet */ }
            }
        }
    }

    private async Task LoadServices()
    {
        try
        {
            var dbServices = await Http.GetFromJsonAsync<List<StoreService>>("api/services");
            if (dbServices != null)
            {
                availableServices = dbServices.Select(s => new ServiceOption
                {
                    Id = s.Id,
                    Name = s.Name,
                    Price = s.Price,
                    Category = s.Category,
                    // FALLBACK: If your DB doesn't have EstimatedMinutes yet, we default to 30 mins
                    // Change `30` to `s.EstimatedMinutes` once you add it to the backend.
                    EstimatedMinutes = 30,
                    IsSelected = false
                }).ToList();
            }
        }
        catch { errorMessage = "Failed to load services."; }
    }

    private async Task LoadMechanics()
    {
        try
        {
            var mechs = await Http.GetFromJsonAsync<List<Mechanic>>("api/mechanics");
            if (mechs != null && mechs.Any())
            {
                // Keep "Any Available" as the first button, then add all the real names from the database
                availableMechanics = new List<string> { "Any Available" };
                availableMechanics.AddRange(mechs.Select(m => m.Name));
            }
        }
        catch
        {
            Console.WriteLine("Failed to load mechanics from database.");
        }
    }

    private async Task FetchBookedSlots()
    {
        try
        {
            var dateStr = newAppt.AppointmentDate.ToString("yyyy-MM-dd");
            var mechanicQuery = Uri.EscapeDataString(selectedMechanic);

            // 👇 Now we ask the server for THIS specific mechanic's blocked times
            var slots = await Http.GetFromJsonAsync<List<string>>($"api/appointments/booked-slots?date={dateStr}&mechanic={mechanicQuery}");

            bookedTimeSlots = slots ?? new();
        }
        catch { Console.WriteLine("Booking fetch failed."); }
    }

    // --- NEW: DYNAMIC TIME SLOT GENERATION & VALIDATION ---
    private List<string> GenerateAllTimeSlots()
    {
        var slots = new List<string>();
        var start = new TimeSpan(9, 0, 0);  // Shop opens 9:00 AM
        var end = new TimeSpan(17, 0, 0);   // Shop closes 5:00 PM

        while (start < end)
        {
            slots.Add(start.ToString(@"hh\:mm"));
            start = start.Add(TimeSpan.FromMinutes(15));
        }
        return slots;
    }

    private bool IsTimeSlotAvailable(string timeStr)
    {
        if (!TimeSpan.TryParse(timeStr, out var startTime)) return false;

        // --- THE NEW TIME CHECK ---
        // If the selected date is today, block any time slots that have already passed.
        if (newAppt.AppointmentDate.Date == DateTime.Today)
        {
            // We add a 1-hour buffer. So if it's 10:00 AM, the earliest they can book is 11:00 AM.
            // If you want exact time, change it to just: if (startTime < DateTime.Now.TimeOfDay)
            if (startTime < DateTime.Now.TimeOfDay.Add(TimeSpan.FromHours(1)))
            {
                return false;
            }
        }

        // How many 15-minute blocks do we need?
        int slotsNeeded = (int)Math.Ceiling(TotalDurationMinutes / 15.0);

        for (int i = 0; i < slotsNeeded; i++)
        {
            var checkTime = startTime.Add(TimeSpan.FromMinutes(i * 15));

            // 1. If the required time pushes past closing (5:00 PM), slot is invalid
            if (checkTime >= new TimeSpan(17, 0, 0)) return false;

            // 2. If any 15-min block inside the required duration is already booked, slot is invalid
            if (bookedTimeSlots.Contains(checkTime.ToString(@"hh\:mm"))) return false;
        }

        return true;
    }

    private void SelectMechanic(string mechanic)
    {
        selectedMechanic = mechanic;
        newAppt.TimeSlot = ""; // Reset time slot on mechanic change
        _ = FetchBookedSlots(); // Re-fetch slots for this specific mechanic
    }

    private void ToggleService(ServiceOption service)
    {
        service.IsSelected = !service.IsSelected;

        // If the current selected time slot is no longer valid (because duration increased), clear it
        if (!string.IsNullOrEmpty(newAppt.TimeSlot) && !IsTimeSlotAvailable(newAppt.TimeSlot))
        {
            newAppt.TimeSlot = "";
        }

        showSuccessMessage = false;
        errorMessage = "";
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(newAppt.TimeSlot)) { errorMessage = "Please select an available time slot."; return; }
        if (TotalDurationMinutes == 0) { errorMessage = "Please select at least one service."; return; }

        isProcessing = true;
        newAppt.ServicesRequested = string.Join(", ", SelectedServices.Select(s => s.Name));
        newAppt.TotalAmount = TotalPrice;
        newAppt.Category = SelectedServices.FirstOrDefault()?.Category ?? "General";

        // 👇 ADD THESE TWO LINES:
        newAppt.MechanicName = selectedMechanic;
        newAppt.DurationMinutes = TotalDurationMinutes;

        newAppt.Status = "Pending";

        try
        {
            var response = await Http.PostAsJsonAsync("api/appointments", newAppt);

            if (response.IsSuccessStatusCode)
            {
                showSuccessMessage = true;
                errorMessage = "";
                newAppt = new() { AppointmentDate = DateTime.Now, CustomerName = newAppt.CustomerName };
                availableServices.ForEach(s => s.IsSelected = false);
                await FetchBookedSlots();
            }
            else { errorMessage = "Booking failed."; }
        }
        catch { errorMessage = "Connection error."; }
        finally { isProcessing = false; }
    }

    // --- CALENDAR LOGIC ---
    private DateTime calendarMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

    private IEnumerable<DateTime?> CalendarCells
    {
        get
        {
            var cells = new List<DateTime?>();
            var firstDay = (int)calendarMonth.DayOfWeek;
            for (int i = 0; i < firstDay; i++) cells.Add(null);
            var daysInMonth = DateTime.DaysInMonth(calendarMonth.Year, calendarMonth.Month);
            for (int d = 1; d <= daysInMonth; d++) cells.Add(new DateTime(calendarMonth.Year, calendarMonth.Month, d));
            return cells;
        }
    }

    private void PrevMonth() => calendarMonth = calendarMonth.AddMonths(-1);
    private void NextMonth() => calendarMonth = calendarMonth.AddMonths(1);

    private async Task SelectDate(DateTime date)
    {
        newAppt.AppointmentDate = date;
        newAppt.TimeSlot = "";
        await FetchBookedSlots();
    }
}