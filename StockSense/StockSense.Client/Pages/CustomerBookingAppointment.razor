@page "/appointment"
@layout PublicLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using StockSense.Shared
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager NavigationManager

@attribute [Authorize]

<PageTitle>Book Appointment</PageTitle>

<AuthorizeView>
    <Authorized>

        @if (isLoading)
        {
            <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 9999; gap: var(--space-4);">
                <BbSpinner Size="SpinnerSize.Large" />
                <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-1);">
                    <span style="font-weight: 800; font-style: italic; font-size: 1.5rem; color: var(--primary); letter-spacing: 0.05em;">SAP<br />SHOP</span>
                    <p style="color: var(--muted-foreground); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">Syncing with Server...</p>
                </div>
            </div>
        }

        <div class="appt-layout" style="display: @(isLoading ? "none" : "flex"); height: calc(100vh - 3.5rem); overflow: hidden; animation: fadeIn 0.4s ease-in;">

            @* --- LEFT SIDEBAR --- *@
            <div class="appt-sidebar" style="width: 300px; flex-shrink: 0; display: flex; flex-direction: column; background-color: var(--card); border-right: 1px solid var(--border); overflow: hidden;">

                @* Header *@
                <div style="padding: var(--space-4); border-bottom: 1px solid var(--border); flex-shrink: 0;">
                    <h2 style="font-size: var(--text-lg); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">Schedule Service</h2>
                    <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0;">Step @currentStep of 4 — @Steps.First(s => s.Number == currentStep).Label</p>
                </div>

                @* Step Indicators *@
                <div style="padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; gap: 0;">
                    @foreach (var step in Steps)
                    {
                        bool isActive = currentStep == step.Number;
                        bool isCompleted = currentStep > step.Number;

                        <div style="display: flex; align-items: center;">
                            <div @onclick="() => GoToStep(step.Number)"
                                 style="width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: var(--text-xs); font-weight: var(--font-bold); cursor: @(isCompleted ? "pointer" : "default"); transition: all 0.2s;
                                                   background-color: @(isActive || isCompleted ? "var(--primary)" : "var(--muted)");
                                                   color: @(isActive || isCompleted ? "var(--primary-foreground)" : "var(--muted-foreground)");
                                                   box-shadow: @(isActive ? "0 0 0 3px color-mix(in oklch, var(--primary) 20%, transparent)" : "none");">
                                @if (isCompleted)
                                {
                                    <LucideIcon Name="check" Size="13" />
                                }
                                else
                                {
                                    @step.Number
                                }
                            </div>
                            @if (step.Number < Steps.Count)
                            {
                                <div style="width: 24px; height: 2px; background-color: @(isCompleted ? "var(--primary)" : "var(--border)"); transition: background-color 0.2s;"></div>
                            }
                        </div>
                    }
                </div>

                @* Order Summary *@
                <div style="flex: 1; overflow-y: auto; padding: var(--space-4);">
                    <p style="font-size: var(--text-xs); font-weight: var(--font-semibold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-3) 0;">Order Summary</p>

                    @if (!SelectedServices.Any())
                    {
                        <div style="text-align: center; padding: var(--space-6) 0; color: var(--muted-foreground);">
                            <LucideIcon Name="shopping-cart" Size="28" />
                            <p style="font-size: var(--text-xs); margin: var(--space-2) 0 0 0; font-style: italic;">No services selected</p>
                        </div>
                    }
                    else
                    {
                        <div style="display: flex; flex-direction: column; gap: var(--space-3); margin-bottom: var(--space-4);">
                            @foreach (var s in SelectedServices)
                            {
                                <div>
                                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                        <span style="font-size: var(--text-xs); font-weight: bold; color: var(--foreground); flex: 1; padding-right: var(--space-2);">@s.Name</span>
                                        <span style="font-size: var(--text-xs); font-weight: var(--font-bold); color: var(--primary); flex-shrink: 0;">₱@s.TotalServicePrice.ToString("N0")</span>
                                    </div>
                                    @if (s.RequiredProducts.Any())
                                    {
                                        <div style="font-size: 10px; color: var(--muted-foreground); margin-top: 2px;">
                                            Includes @s.RequiredProducts.Count parts
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div style="padding: var(--space-3); border-radius: var(--radius); background-color: var(--muted); margin-bottom: var(--space-3); display: flex; flex-direction: column; gap: var(--space-2);">
                            @if (!string.IsNullOrEmpty(selectedMechanic))
                            {
                                <div style="display: flex; justify-content: space-between;">
                                    <span style="font-size: var(--text-xs); color: var(--muted-foreground);">Mechanic</span>
                                    <span style="font-size: var(--text-xs); font-weight: var(--font-bold); color: var(--foreground);">@selectedMechanic</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(newAppt.TimeSlot))
                            {
                                <div style="display: flex; justify-content: space-between;">
                                    <span style="font-size: var(--text-xs); color: var(--muted-foreground);">Date</span>
                                    <span style="font-size: var(--text-xs); font-weight: var(--font-bold); color: var(--foreground);">@newAppt.AppointmentDate.ToString("MMM dd")</span>
                                </div>
                                <div style="display: flex; justify-content: space-between;">
                                    <span style="font-size: var(--text-xs); color: var(--muted-foreground);">Time</span>
                                    <span style="font-size: var(--text-xs); font-weight: var(--font-bold); color: var(--foreground);">@newAppt.TimeSlot</span>
                                </div>
                            }
                        </div>

                        <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: var(--space-3);">
                            <span style="font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--foreground);">Total Amount</span>
                            <span style="font-size: var(--text-xl); font-weight: 900; color: var(--primary); letter-spacing: -0.03em;">₱@TotalPrice.ToString("N0")</span>
                        </div>
                    }
                </div>

                @* Error + Actions *@
                <div style="padding: var(--space-4); border-top: 1px solid var(--border); flex-shrink: 0; background-color: var(--background); display: flex; flex-direction: column; gap: var(--space-2);">

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="padding: var(--space-2) var(--space-3); border-radius: var(--radius); background-color: var(--destructive-muted); border: 1px solid var(--destructive-border); color: var(--destructive-muted-foreground); font-size: var(--text-xs); margin-bottom: var(--space-1);">
                            <LucideIcon Name="alert-circle" Size="12" />
                            @errorMessage
                        </div>
                    }

                    <BbButton Variant="ButtonVariant.Ghost" Class="w-full" OnClick="PrevStep" Disabled="@(currentStep == 1 || isProcessing)">
                        <LucideIcon Name="arrow-left" Size="14" />
                        Back
                    </BbButton>

                    @if (currentStep < 4)
                    {
                        <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="NextStep" Disabled="@(!CanProceed)">
                            Next Step
                            <LucideIcon Name="arrow-right" Size="14" />
                        </BbButton>
                    }
                    else
                    {
                        <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="HandleSubmit" Disabled="@(isProcessing || !CanProceed)">
                            @if (isProcessing)
                            {
                                <BbSpinner Size="SpinnerSize.Small" />
                            }
                            else
                            {
                                <span>Confirm & Book</span>
                            }
                        </BbButton>
                    }

                    <div style="margin-top: var(--space-2); padding-top: var(--space-3); border-top: 1px dashed var(--border);">
                        <BbButton Variant="ButtonVariant.Outline" Class="w-full" OnClick='() => NavigationManager.NavigateTo("/my-bookings")'>
                            <LucideIcon Name="calendar-days" Size="16" style="margin-right: 6px;" />
                            View My Appointments
                        </BbButton>
                    </div>
                </div>
            </div>

            @* --- RIGHT CONTENT --- *@
            <div style="flex: 1; overflow-y: auto; padding: var(--space-6);">

                @* STEP 1: SERVICES *@
                @if (currentStep == 1)
                {
                    @if (showSuccessNote)
                    {
                        <div style="margin-bottom: var(--space-4); padding: var(--space-3); background-color: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; border-radius: var(--radius); display: flex; align-items: center; gap: var(--space-2); animation: fadeIn 0.3s ease;">
                            <LucideIcon Name="check-circle" Size="16" />
                            <span style="font-size: var(--text-sm); font-weight: 600;">Booking successful!</span>
                        </div>
                    }

                    <div>
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0;">Select Services</h2>

                        @* Category filter pills *@
                        <div style="display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-5);">
                            <button @onclick='() => selectedCategory = "All"'
                                    style="padding: var(--space-1) var(--space-4); border-radius: 999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == "All" ? "var(--primary)" : "var(--border)"); background-color: @(selectedCategory == "All" ? "var(--primary)" : "var(--background)"); color: @(selectedCategory == "All" ? "var(--primary-foreground)" : "var(--foreground)"); cursor: pointer; font-family: var(--font-sans); transition: all 0.15s;">
                                All
                            </button>
                            @foreach (var cat in availableServices.Select(s => s.Category).Distinct().OrderBy(c => c))
                            {
                                <button @onclick="() => selectedCategory = cat"
                                        style="padding: var(--space-1) var(--space-4); border-radius: 999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == cat ? "var(--primary)" : "var(--border)"); background-color: @(selectedCategory == cat ? "var(--primary)" : "var(--background)"); color: @(selectedCategory == cat ? "var(--primary-foreground)" : "var(--foreground)"); cursor: pointer; font-family: var(--font-sans); transition: all 0.15s;">
                                    @cat
                                </button>
                            }
                        </div>

                        @* Service cards *@
                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-4);">
                            @foreach (var service in FilteredServices)
                            {
                                <div @onclick="() => ToggleService(service)"
                                     style="cursor: pointer; background-color: var(--card); border: 2px solid @(service.IsSelected ? "var(--primary)" : "var(--border)"); border-radius: var(--radius); transition: border-color 0.15s; display: flex; flex-direction: column; overflow: hidden;">

                                    <div style="padding: var(--space-3);">
                                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-1);">
                                            <span style="font-size: var(--text-md); font-weight: var(--font-bold); color: var(--foreground); line-height: 1.3; flex: 1; padding-right: var(--space-2);">@service.Name</span>
                                            <div style="width: 20px; height: 20px; border-radius: 50%; border: 2px solid @(service.IsSelected ? "var(--primary)" : "var(--border)"); background-color: @(service.IsSelected ? "var(--primary)" : "transparent"); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.15s;">
                                                @if (service.IsSelected)
                                                {
                                                    <LucideIcon Name="check" Size="12" />
                                                }
                                            </div>
                                        </div>
                                        <p style="font-size: 10px; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-2) 0;">@service.Category • @service.EstimatedMinutes min</p>
                                    </div>

                                    @* Required Products Breakdown *@
                                    @if (service.RequiredProducts.Any())
                                    {
                                        <div style="background-color: var(--muted); padding: var(--space-2) var(--space-3); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
                                            <p style="font-size: 10px; font-weight: bold; color: var(--muted-foreground); text-transform: uppercase; margin: 0 0 6px 0;">Required Parts</p>
                                            @foreach (var part in service.RequiredProducts)
                                            {
                                                <div style="display: flex; justify-content: space-between; font-size: var(--text-xs); margin-bottom: 2px;">
                                                    <span style="color: var(--foreground);">@part.Name</span>
                                                    <span style="color: var(--muted-foreground);">₱@part.Price.ToString("N0")</span>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <div style="padding: var(--space-3); margin-top: auto; display: flex; flex-direction: column; gap: 4px; background-color: color-mix(in oklch, var(--card) 80%, var(--muted));">
                                        <div style="display: flex; justify-content: space-between; font-size: var(--text-xs); color: var(--muted-foreground);">
                                            <span>Labor Fee:</span>
                                            <span>₱@service.Price.ToString("N0")</span>
                                        </div>
                                        @if (service.RequiredProducts.Any())
                                        {
                                            <div style="display: flex; justify-content: space-between; font-size: var(--text-xs); color: var(--muted-foreground);">
                                                <span>Parts Total:</span>
                                                <span>₱@service.RequiredProducts.Sum(p => p.Price).ToString("N0")</span>
                                            </div>
                                        }
                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 4px; padding-top: 4px; border-top: 1px dashed var(--border);">
                                            <span style="font-size: var(--text-sm); font-weight: bold; color: var(--foreground);">Total Cost</span>
                                            <span style="font-size: var(--text-lg); font-weight: 900; color: var(--primary);">₱@service.TotalServicePrice.ToString("N0")</span>
                                        </div>
                                    </div>

                                </div>
                            }
                        </div>
                    </div>
                }

                @* STEP 2: MECHANIC *@
                @if (currentStep == 2)
                {
                    <div>
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0;">Choose Your Technician</h2>
                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: var(--space-4);">
                            @foreach (var mech in availableMechanics)
                            {
                                bool isMechSelected = selectedMechanic == mech;
                                <div @onclick="() => SelectMechanic(mech)"
                                     style="cursor: pointer; display: flex; flex-direction: column; align-items: center; padding: var(--space-5) var(--space-3); border-radius: var(--radius); border: 2px solid @(isMechSelected ? "var(--primary)" : "var(--border)"); background-color: @(isMechSelected ? "color-mix(in oklch, var(--primary) 5%, var(--card))" : "var(--card)"); transition: border-color 0.15s;">
                                    <div style="width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: var(--space-3); background-color: @(isMechSelected ? "var(--primary)" : "var(--muted)"); color: @(isMechSelected ? "var(--primary-foreground)" : "var(--muted-foreground)"); transition: all 0.15s;">
                                        <LucideIcon Name="user" Size="28" />
                                    </div>
                                    <span style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground); text-align: center; line-height: 1.3;">@mech</span>
                                    @if (isMechSelected)
                                    {
                                        <span style="font-size: 10px; color: var(--primary); font-weight: var(--font-bold); text-transform: uppercase; margin-top: var(--space-1);">Selected</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                @* STEP 3: DATE & TIME *@
                @if (currentStep == 3)
                {
                    <div>
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0;">Pick a Date & Time</h2>

                        <div class="step3-container" style="display: flex; align-items: stretch; background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; max-height: 50vh;">

                            @* Calendar panel *@
                            <div class="step3-calendar" style="flex-shrink: 0; padding: var(--space-4); border-right: 1px solid var(--border); overflow-y: auto;">

                                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-3);">
                                    <button @onclick="PrevMonth"
                                            style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: none; background: none; cursor: pointer; color: var(--foreground); transition: background-color 0.15s;"
                                            onmouseover="this.style.backgroundColor='var(--muted)'" onmouseout="this.style.backgroundColor='transparent'">
                                        <LucideIcon Name="chevron-left" Size="16" />
                                    </button>
                                    <span style="font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--foreground);">
                                        @calendarMonth.ToString("MMMM")
                                        <span style="font-weight: var(--font-normal); color: var(--muted-foreground);">@calendarMonth.Year</span>
                                    </span>
                                    <button @onclick="NextMonth"
                                            style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: none; background: none; cursor: pointer; color: var(--foreground); transition: background-color 0.15s;"
                                            onmouseover="this.style.backgroundColor='var(--muted)'" onmouseout="this.style.backgroundColor='transparent'">
                                        <LucideIcon Name="chevron-right" Size="16" />
                                    </button>
                                </div>

                                <table style="border-collapse: collapse; width: 100%;">
                                    <thead>
                                        <tr>
                                            @foreach (var h in new[] { "M", "T", "W", "T", "F", "S", "S" })
                                            {
                                                <th style="border: none; text-align: center; padding: 0;">
                                                    <span style="display: flex; height: 28px; align-items: center; justify-content: center; font-size: var(--text-xs); font-weight: var(--font-semibold); color: var(--muted-foreground); width: 100%;">@h</span>
                                                </th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var days = GetCalendarDays().ToList();
                                            for (int row = 0; row < 6; row++)
                                            {
                                                <tr>
                                                    @for (int col = 0; col < 7; col++)
                                                    {
                                                        var date = days[row * 7 + col];
                                                        bool isCurrentMonth = date.Month == calendarMonth.Month;
                                                        bool isPast = date.Date < DateTime.Today;
                                                        bool isSelected = newAppt.AppointmentDate.Date == date.Date;
                                                        bool isToday = date.Date == DateTime.Today;
                                                        bool isDisabled = isPast || !isCurrentMonth;

                                                        string bg = isSelected ? "var(--primary)" : "transparent";
                                                        string color = isSelected ? "var(--primary-foreground)"
                                                        : isDisabled ? "color-mix(in oklch, var(--muted-foreground) 40%, transparent)"
                                                        : isToday ? "var(--primary)"
                                                        : "var(--foreground)";
                                                        string border = isToday && !isSelected ? "1px dashed var(--primary)" : "1px solid transparent";
                                                        string fontWeight = isSelected || isToday ? "var(--font-bold)" : "var(--font-normal)";
                                                        string textDecoration = isDisabled && !isSelected ? "line-through" : "none";

                                                        <td style="border: none; text-align: center; padding: 0;">
                                                            <span style="display: flex; align-items: center; justify-content: center; padding: 3px 5px;">
                                                                <button @onclick="() => SelectDate(date)"
                                                                        disabled="@isDisabled"
                                                                        style="width: 28px; height: 28px; border-radius: 6px; border: @border; background-color: @bg; color: @color; font-size: var(--text-xs); font-weight: @fontWeight; cursor: @(isDisabled ? "default" : "pointer"); display: flex; align-items: center; justify-content: center; transition: background-color 0.15s; font-family: var(--font-sans); text-decoration: @textDecoration;">
                                                                    @date.Day
                                                                </button>
                                                            </span>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @* Time Slots panel *@
                            <div class="step3-slots" style="flex: 1; display: flex; flex-direction: column; min-width: 0; overflow: hidden;">
                                <div style="padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border); flex-shrink: 0;">
                                    <span style="font-size: var(--text-xs); font-weight: var(--font-bold); color: var(--foreground);">
                                        @newAppt.AppointmentDate.ToString("dddd d MMMM") - @selectedMechanic
                                    </span>
                                </div>

                                <div style="flex: 1; overflow-y: auto; padding: var(--space-3) var(--space-4);">
                                    @if (TotalDurationMinutes == 0)
                                    {
                                        <div style="padding: var(--space-4); border-radius: var(--radius); background-color: var(--muted); border: 1px dashed var(--border); text-align: center; font-size: var(--text-xs); color: var(--muted-foreground);">
                                            Select services first to see available slots.
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2);">
                                            @foreach (var time in GenerateAllTimeSlots())
                                            {
                                                bool isAvailable = IsTimeSlotAvailable(time);
                                                bool isSlotSelected = newAppt.TimeSlot == time;

                                                TimeSpan.TryParse(time, out var ts);
                                                var displayHour = ts.Hours > 12 ? ts.Hours - 12 : (ts.Hours == 0 ? 12 : ts.Hours);
                                                var ampm = ts.Hours >= 12 ? "PM" : "AM";
                                                var displayTime = $"{displayHour}:{ts.Minutes:D2}";

                                                <button @onclick="@(() => { if (isAvailable) { newAppt.TimeSlot = time; errorMessage = ""; } })"
                                                        disabled="@(!isAvailable)"
                                                        style="height: 36px; padding: 0 var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-normal); text-align: center; cursor: @(isAvailable ? "pointer" : "not-allowed"); font-family: var(--font-sans); transition: all 0.15s; display: flex; align-items: center; justify-content: center; gap: 3px;
                                                                           border: 1px solid @(isSlotSelected ? "var(--primary)" : "var(--border)");
                                                                           background-color: @(isSlotSelected ? "var(--primary)" : "var(--muted)");
                                                                           color: @(isSlotSelected ? "var(--primary-foreground)" : isAvailable ? "var(--foreground)" : "var(--muted-foreground)");
                                                                           opacity: @(isAvailable ? "1" : "0.35");
                                                                           text-decoration: @(isAvailable ? "none" : "line-through");">
                                                    <span style="font-size: var(--text-sm);">@displayTime</span>
                                                    <span style="font-size: var(--text-xs); color: @(isSlotSelected ? "var(--primary-foreground)" : "var(--muted-foreground)");">@ampm</span>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>
                }

                @* STEP 4: REVIEW *@
                @if (currentStep == 4)
                {
                    <div>
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">Review Your Booking</h2>
                        <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0 0 var(--space-5) 0;">Double-check everything before confirming.</p>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); margin-bottom: var(--space-4);">
                            <div style="padding: var(--space-4); border-radius: var(--radius); background-color: var(--card); border: 1px solid var(--border);">
                                <span style="font-size: 10px; font-weight: var(--font-bold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em;">Customer</span>
                                <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); margin: var(--space-1) 0 0 0;">@newAppt.CustomerName</p>
                            </div>
                            <div style="padding: var(--space-4); border-radius: var(--radius); background-color: var(--card); border: 1px solid var(--border);">
                                <span style="font-size: 10px; font-weight: var(--font-bold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em;">Mechanic</span>
                                <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--primary); margin: var(--space-1) 0 0 0;">@selectedMechanic</p>
                            </div>
                            <div style="padding: var(--space-4); border-radius: var(--radius); background-color: var(--card); border: 1px solid var(--border); grid-column: 1 / -1;">
                                <span style="font-size: 10px; font-weight: var(--font-bold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em;">Schedule</span>
                                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: var(--space-1);">
                                    <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); margin: 0;">@newAppt.AppointmentDate.ToString("MMMM dd, yyyy") at @newAppt.TimeSlot</p>
                                    <span style="font-size: var(--text-xs); font-weight: var(--font-bold); color: var(--primary); background-color: color-mix(in oklch, var(--primary) 10%, transparent); padding: 2px 10px; border-radius: 999px;">~@TotalDurationMinutes mins</span>
                                </div>
                            </div>
                        </div>

                        <p style="font-size: 10px; font-weight: var(--font-bold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-2) 0;">Selected Services & Parts</p>
                        <div style="border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background-color: var(--card);">
                            @foreach (var s in SelectedServices)
                            {
                                <div style="padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border);">
                                    <div style="display: flex; justify-content: space-between; align-items: center;">
                                        <span style="font-size: var(--text-sm); font-weight: bold; color: var(--foreground);">@s.Name (Labor)</span>
                                        <span style="font-size: var(--text-sm); color: var(--muted-foreground);">₱@s.Price.ToString("N0")</span>
                                    </div>
                                    @if (s.RequiredProducts.Any())
                                    {
                                        <div style="margin-top: var(--space-2); padding-left: var(--space-2); border-left: 2px solid var(--border);">
                                            @foreach (var part in s.RequiredProducts)
                                            {
                                                <div style="display: flex; justify-content: space-between; font-size: var(--text-xs); color: var(--muted-foreground); margin-bottom: 2px;">
                                                    <span>+ @part.Name</span>
                                                    <span>₱@part.Price.ToString("N0")</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: var(--space-2); padding-top: var(--space-2); border-top: 1px dashed var(--border);">
                                        <span style="font-size: var(--text-xs); font-weight: bold; color: var(--foreground);">Subtotal</span>
                                        <span style="font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--primary);">₱@s.TotalServicePrice.ToString("N0")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>

        @* SUCCESS DIALOG *@
        <BbDialog @bind-Open="showSuccessModal">
            <BbDialogContent Class="max-w-sm">
                <div style="display: flex; flex-direction: column; align-items: center; text-align: center; padding: var(--space-4) var(--space-2) var(--space-2);">

                    <div style="width: 72px; height: 72px; border-radius: 50%; background-color: color-mix(in oklch, var(--primary) 10%, transparent); color: var(--primary); display: flex; align-items: center; justify-content: center; margin-bottom: var(--space-4);">
                        <LucideIcon Name="calendar-check" Size="36" />
                    </div>

                    <BbDialogTitle>Booking Confirmed!</BbDialogTitle>
                    <BbDialogDescription style="margin-bottom: var(--space-5);">
                        Your appointment has been successfully scheduled. You can now view it in your dashboard.
                    </BbDialogDescription>

                    <div style="width: 100%; display: flex; flex-direction: column; gap: var(--space-2);">
                        <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick='() => NavigationManager.NavigateTo("/my-bookings")'>
                            View My Bookings
                        </BbButton>
                        <BbButton Variant="ButtonVariant.Ghost" Class="w-full" OnClick="CloseSuccessModal">
                            Book Another
                        </BbButton>
                    </div>
                </div>
            </BbDialogContent>
        </BbDialog>

    </Authorized>

    <NotAuthorized>
        <div style="height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; gap: var(--space-4);">
            <LucideIcon Name="lock" Size="40" />
            <h2 style="font-weight: var(--font-bold); font-size: var(--text-xl); color: var(--foreground); margin: 0;">Access Restricted</h2>
            <p style="color: var(--muted-foreground); font-size: var(--text-sm); margin: 0;">Please sign in to book an appointment.</p>
            <BbButton Variant="ButtonVariant.Default" OnClick='() => NavigationManager.NavigateTo("/login")'>Go to Login</BbButton>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@code {
    private bool isLoading = true;
    private Appointment newAppt = new() { AppointmentDate = DateTime.Today, TimeSlot = "" };
    private bool showSuccessModal = false;
    private bool showSuccessNote = false;
    private bool isProcessing = false;
    private string errorMessage = "";
    private string selectedCategory = "All";
    private int currentStep = 1;

    private List<(int Number, string Label)> Steps = new()
    {
        (1, "Services"),
        (2, "Mechanic"),
        (3, "Schedule"),
        (4, "Confirm")
    };

    private bool CanProceed => currentStep switch
    {
        1 => SelectedServices.Any(),
        2 => !string.IsNullOrEmpty(selectedMechanic),
        3 => !string.IsNullOrEmpty(newAppt.TimeSlot),
        _ => true
    };

    private void NextStep()
    {
        if (CanProceed && currentStep < 4)
        {
            currentStep++;
            showSuccessNote = false; // Hide success note when moving forward
        }
    }
    private void PrevStep() { if (currentStep > 1) currentStep--; }
    private void GoToStep(int step) { if (step < currentStep) currentStep = step; }

    private List<string> availableMechanics = new() { "Any Available" };
    private string selectedMechanic = "Any Available";

    public class RequiredProduct
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
    }

    public class ServiceOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public string Category { get; set; } = "General";
        public int EstimatedMinutes { get; set; }
        public bool IsSelected { get; set; }

        // NEW: Products required for this service
        public List<RequiredProduct> RequiredProducts { get; set; } = new();

        // NEW: Dynamic total price (Labor + Parts)
        public decimal TotalServicePrice => Price + RequiredProducts.Sum(p => p.Price);
    }

    private List<ServiceOption> availableServices = new();
    private List<string> bookedTimeSlots = new();

    private IEnumerable<ServiceOption> FilteredServices =>
        selectedCategory == "All" ? availableServices : availableServices.Where(s => s.Category == selectedCategory);

    private IEnumerable<ServiceOption> SelectedServices => availableServices.Where(s => s.IsSelected);

    // UPDATED: Now calculates the total of all parts AND labor.
    private decimal TotalPrice => SelectedServices.Sum(s => s.TotalServicePrice);
    private int TotalDurationMinutes => SelectedServices.Sum(s => s.EstimatedMinutes);

    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            await Task.WhenAll(LoadUserProfile(), LoadServices(), LoadMechanics(), FetchBookedSlots());
        }
        catch { errorMessage = "Connection error."; }
        finally { isLoading = false; }
    }

    private async Task LoadUserProfile()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                newAppt.CustomerName = authState.User.Identity.Name ?? "User";
                try
                {
                    var profile = await Http.GetFromJsonAsync<UserProfile>("api/user/profile");
                    if (profile != null) newAppt.CustomerName = $"{profile.FirstName} {profile.LastName}".Trim();
                }
                catch { }
            }
        }
    }

    private async Task LoadServices()
    {
        try
        {
            // 1. Fetch real services from the DB.
            // Note: The backend controller now uses .Include(s => s.RequiredProducts)
            var dbServices = await Http.GetFromJsonAsync<List<StoreService>>("api/services");

            if (dbServices != null)
            {
                availableServices = dbServices.Select(s => new ServiceOption
                {
                    Id = s.Id,
                    Name = s.Name,
                    Price = s.Price, // Labor Fee
                    Category = s.Category,
                    EstimatedMinutes = s.EstimatedMinutes > 0 ? s.EstimatedMinutes : 30,
                    IsSelected = false,

                    // 2. Map the REAL products linked in the database to the UI model
                    RequiredProducts = s.RequiredProducts.Select(p => new RequiredProduct
                    {
                        Name = p.Name,
                        Price = p.Price
                    }).ToList()
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading services: {ex.Message}");
            errorMessage = "Failed to load services.";
        }
    }

    private async Task LoadMechanics()
    {
        try
        {
            var mechs = await Http.GetFromJsonAsync<List<Mechanic>>("api/mechanics");
            if (mechs != null && mechs.Any())
            {
                availableMechanics = new List<string> { "Any Available" };
                availableMechanics.AddRange(mechs.Select(m => m.Name));
            }
        }
        catch { }
    }

    private async Task FetchBookedSlots()
    {
        try
        {
            var dateStr = newAppt.AppointmentDate.ToString("yyyy-MM-dd");
            var mechanicQuery = Uri.EscapeDataString(selectedMechanic);
            var slots = await Http.GetFromJsonAsync<List<string>>($"api/appointments/booked-slots?date={dateStr}&mechanic={mechanicQuery}");
            bookedTimeSlots = slots ?? new();
        }
        catch { }
    }

    private IEnumerable<DateTime> GetCalendarDays()
    {
        var firstDay = new DateTime(calendarMonth.Year, calendarMonth.Month, 1);
        int offset = ((int)firstDay.DayOfWeek + 6) % 7;
        var gridStart = firstDay.AddDays(-offset);
        return Enumerable.Range(0, 42).Select(i => gridStart.AddDays(i));
    }

    private List<string> GenerateAllTimeSlots()
    {
        var slots = new List<string>();
        var current = new TimeSpan(9, 0, 0);
        var end = new TimeSpan(17, 0, 0);
        while (current < end)
        {
            slots.Add(current.ToString(@"hh\:mm"));
            current = current.Add(TimeSpan.FromMinutes(15));
        }
        return slots;
    }

    private bool IsTimeSlotAvailable(string timeStr)
    {
        if (!TimeSpan.TryParse(timeStr, out var startTime)) return false;
        if (newAppt.AppointmentDate.Date == DateTime.Today && startTime < DateTime.Now.TimeOfDay.Add(TimeSpan.FromHours(1))) return false;
        int slotsNeeded = (int)Math.Ceiling(TotalDurationMinutes / 15.0);
        for (int i = 0; i < slotsNeeded; i++)
        {
            var check = startTime.Add(TimeSpan.FromMinutes(i * 15));
            if (check >= new TimeSpan(17, 0, 0)) return false;
            if (bookedTimeSlots.Contains(check.ToString(@"hh\:mm"))) return false;
        }
        return true;
    }

    private async Task SelectMechanic(string mechanic)
    {
        selectedMechanic = mechanic;
        newAppt.TimeSlot = "";
        await FetchBookedSlots();
    }

    private void ToggleService(ServiceOption service)
    {
        service.IsSelected = !service.IsSelected;
        if (!string.IsNullOrEmpty(newAppt.TimeSlot) && !IsTimeSlotAvailable(newAppt.TimeSlot))
            newAppt.TimeSlot = "";
        errorMessage = "";
        showSuccessNote = false;
    }

    private async Task HandleSubmit()
    {
        if (isProcessing) return;

        if (string.IsNullOrEmpty(newAppt.TimeSlot)) { errorMessage = "Select a time slot."; return; }

        isProcessing = true;
        errorMessage = "";

        // UPDATED: Now saves the Service Name AND the included parts to the database record
        newAppt.ServicesRequested = string.Join(" | ", SelectedServices.Select(s =>
            s.RequiredProducts.Any()
                ? $"{s.Name} [+ {string.Join(", ", s.RequiredProducts.Select(p => p.Name))}]"
                : s.Name
        ));

        newAppt.TotalAmount = TotalPrice;
        newAppt.Category = SelectedServices.FirstOrDefault()?.Category ?? "General";
        newAppt.MechanicName = selectedMechanic;
        newAppt.DurationMinutes = TotalDurationMinutes;
        newAppt.Status = "Pending";

        try
        {
            var response = await Http.PostAsJsonAsync("api/appointments", newAppt);
            if (response.IsSuccessStatusCode)
            {
                showSuccessModal = true;
            }
            else
            {
                errorMessage = "Booking failed. " + await response.Content.ReadAsStringAsync();
            }
        }
        catch { errorMessage = "Connection error."; }
        finally { isProcessing = false; }
    }

    private void CloseSuccessModal()
    {
        showSuccessModal = false;
        showSuccessNote = true;
        currentStep = 1;

        string savedName = newAppt.CustomerName;
        newAppt = new() { AppointmentDate = DateTime.Today, CustomerName = savedName, TimeSlot = "" };

        foreach (var s in availableServices)
        {
            s.IsSelected = false;
        }

        selectedMechanic = "Any Available";
        _ = FetchBookedSlots();

        StateHasChanged();
    }

    private DateTime calendarMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private void PrevMonth() => calendarMonth = calendarMonth.AddMonths(-1);
    private void NextMonth() => calendarMonth = calendarMonth.AddMonths(1);

    private async Task SelectDate(DateTime date)
    {
        if (date.Date < DateTime.Today || date.Month != calendarMonth.Month) return;
        newAppt.AppointmentDate = date;
        newAppt.TimeSlot = "";
        await FetchBookedSlots();
    }
}