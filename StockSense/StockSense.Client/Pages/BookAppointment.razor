@page "/appointment"
@layout PublicLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using StockSense.shared
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager NavigationManager

@attribute [Authorize]
<AuthorizeView>
    <Authorized>
        <PageTitle>Book Appointment</PageTitle>

        @if (isLoading)
        {
            <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 9999; gap: var(--space-4);">
                <BbSpinner Size="SpinnerSize.Large" />
                <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-1);">
                    <span style="font-weight: 800; font-style: italic; font-size: 1.5rem; color: var(--primary); letter-spacing: 0.05em;">SAP<br />SHOP</span>
                    <p style="color: var(--muted-foreground); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">Syncing with Server...</p>
                </div>
            </div>
        }

        <div style="display: @(isLoading ? "none" : "block"); animation: fadeIn 0.4s ease-in;">
            <div class="appt-layout">

                @* --- LEFT: Services --- *@
                <div class="appt-services">
                    <div style="margin-bottom: var(--space-4);">
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">Select Services</h2>
                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Choose one or more services for your visit.</p>
                    </div>

                    @* Category filter pills *@
                    <div style="display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4);">
                        <button @onclick='() => selectedCategory = "All"'
                                style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == "All" ? "var(--primary)" : "var(--border)"); background-color: @(selectedCategory == "All" ? "var(--primary)" : "transparent"); color: @(selectedCategory == "All" ? "var(--primary-foreground)" : "var(--foreground)"); cursor: pointer; font-family: var(--font-sans);">
                            All
                        </button>
                        @foreach (var cat in availableServices.Select(s => s.Category).Distinct().OrderBy(c => c))
                        {
                            <button @onclick="() => selectedCategory = cat"
                                    style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == cat ? "var(--primary)" : "var(--border)"); background-color: @(selectedCategory == cat ? "var(--primary)" : "transparent"); color: @(selectedCategory == cat ? "var(--primary-foreground)" : "var(--foreground)"); cursor: pointer; font-family: var(--font-sans);">
                                @cat
                            </button>
                        }
                    </div>

                    @* Service list *@
                    <div style="display: flex; flex-direction: column; gap: var(--space-2);">
                        @foreach (var service in FilteredServices)
                        {
                            <div @onclick="() => ToggleService(service)"
                                 style="display: flex; align-items: center; justify-content: space-between; padding: var(--space-3) var(--space-4); background-color: var(--card); border: 1.5px solid @(service.IsSelected ? "var(--primary)" : "var(--border)"); border-radius: var(--radius); cursor: pointer; transition: border-color 0.15s;">
                                <div style="display: flex; align-items: center; gap: var(--space-3);">
                                    <div style="width: 1.25rem; height: 1.25rem; border-radius: 50%; border: 2px solid @(service.IsSelected ? "var(--primary)" : "var(--border)"); background-color: @(service.IsSelected ? "var(--primary)" : "transparent"); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: 0.15s;">
                                        @if (service.IsSelected)
                                        {
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--primary-foreground)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        }
                                    </div>
                                    <div>
                                        <div style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">@service.Name</div>
                                        <div style="font-size: var(--text-xs); color: var(--muted-foreground);">@service.Category</div>
                                    </div>
                                </div>
                                <span style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--primary); white-space: nowrap; margin-left: var(--space-4);">₱@service.Price.ToString("N0")</span>
                            </div>
                        }
                    </div>
                </div>

                @* --- RIGHT: Calendar + Timeslots + Summary --- *@
                <div class="appt-right">
                    <div style="display: flex; flex-direction: row; gap: var(--space-2)">
                        @* Calendar *@
                        <div style="width: 75%; background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-5); margin-bottom: var(--space-4);">
                            <h3 style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0;">Choose a Date</h3>

                            @* Month nav *@
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-3);">
                                <button @onclick="PrevMonth" style="background: none; border: none; cursor: pointer; color: var(--foreground); padding: var(--space-1); border-radius: var(--radius); display: flex; align-items: center;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                                </button>
                                <span style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground);">@calendarMonth.ToString("MMMM yyyy")</span>
                                <button @onclick="NextMonth" style="background: none; border: none; cursor: pointer; color: var(--foreground); padding: var(--space-1); border-radius: var(--radius); display: flex; align-items: center;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                </button>
                            </div>

                            @* Day headers *@
                            <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: var(--space-1); margin-bottom: var(--space-2);">
                                @foreach (var day in new[] { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" })
                                {
                                    <div style="text-align: center; font-size: var(--text-xs); color: var(--muted-foreground); font-weight: var(--font-medium); padding: var(--space-1) 0;">@day</div>
                                }
                            </div>

                            @* Calendar grid *@
                            <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: var(--space-1);">
                                @foreach (var cell in CalendarCells)
                                {
                                    if (cell == null)
                                    {
                                        <div></div>
                                    }
                                    else
                                    {
                                        var d = cell.Value;
                                        bool isPast = d < DateTime.Today;
                                        bool isSelected = newAppt.AppointmentDate.Date == d.Date;
                                        bool isToday = d.Date == DateTime.Today;

                                        <button @onclick="() => SelectDate(d)" disabled="@isPast"
                                                style="aspect-ratio: 1; border-radius: var(--radius); border: 1px solid @(isSelected ? "var(--primary)" : "transparent"); background-color: @(isSelected ? "var(--primary)" : (isToday ? "var(--accent)" : "transparent")); color: @(isSelected ? "var(--primary-foreground)" : (isPast ? "var(--muted-foreground)" : "var(--foreground)")); font-size: var(--text-xs); font-weight: @(isToday ? "var(--font-bold)" : "var(--font-normal)"); cursor: @(isPast ? "not-allowed" : "pointer"); opacity: @(isPast ? "0.4" : "1"); font-family: var(--font-sans); transition: background-color 0.1s;">
                                            @d.Day
                                        </button>
                                    }
                                }
                            </div>
                        </div>

                        @* Time Slots *@
                        <div style="display: flex; flex-direction: column; width: 25%; background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-2); margin-bottom: var(--space-4);">
                            <h3 style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-3) 0;">
                                <span style="font-weight: var(--font-normal); color: var(--muted-foreground);">@newAppt.AppointmentDate.ToString("MMM dd, yyyy")</span>
                            </h3>
                            <div style="display: grid; grid-template-columns: repeat(1, 1fr); gap: var(--space-2); max-height: 180px; overflow-y: auto; padding-right: var(--space-1); height: 100%">
                                @foreach (var time in availableTimeSlots)
                                {
                                    bool isBooked = bookedTimeSlots.Contains(time);
                                    bool isSelected = newAppt.TimeSlot == time;
                                    <button @onclick="() => { if (!isBooked) SelectTimeSlot(time); }"
                                            style="padding: var(--space-2); border-radius: var(--radius); font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(isSelected ? "var(--primary)" : "var(--border)"); background-color: @(isSelected ? "var(--primary)" : "transparent"); color: @(isSelected ? "var(--primary-foreground)" : (isBooked ? "var(--muted-foreground)" : "var(--foreground)")); cursor: @(isBooked ? "not-allowed" : "pointer"); text-decoration: @(isBooked ? "line-through" : "none"); opacity: @(isBooked ? "0.4" : "1"); font-family: var(--font-sans); transition: background-color 0.1s;">
                                        @time
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    @* Summary + Submit *@
                    <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-5);">
                        <h3 style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0; padding-bottom: var(--space-3); border-bottom: 1px solid var(--border);">Booking Summary</h3>

                        <div style="margin-bottom: var(--space-3);">
                            <p style="font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-1) 0;">Customer</p>
                            <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); margin: 0;">@newAppt.CustomerName</p>
                        </div>

                        @if (!string.IsNullOrEmpty(newAppt.TimeSlot))
                        {
                            <div style="margin-bottom: var(--space-3);">
                                <p style="font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 var(--space-1) 0;">Schedule</p>
                                <p style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground); margin: 0;">@newAppt.AppointmentDate.ToString("MMM dd, yyyy") at @newAppt.TimeSlot</p>
                            </div>
                        }

                        <div style="display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-4);">
                            @if (!SelectedServices.Any())
                            {
                                <p style="font-size: var(--text-sm); color: var(--muted-foreground); font-style: italic; margin: 0;">No services selected yet.</p>
                            }
                            @foreach (var selected in SelectedServices)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: var(--space-2); border-bottom: 1px solid var(--border);">
                                    <span style="font-size: var(--text-sm); color: var(--foreground);">@selected.Name</span>
                                    <span style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">₱@selected.Price.ToString("N0")</span>
                                </div>
                            }
                        </div>

                        <div style="display: flex; justify-content: space-between; align-items: center; padding: var(--space-3); background-color: var(--muted); border-radius: var(--radius); margin-bottom: var(--space-4);">
                            <span style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground);">Total</span>
                            <span style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--primary);">₱@TotalPrice.ToString("N0")</span>
                        </div>

                        @if (showSuccessMessage)
                        {
                            <div style="margin-bottom: var(--space-3); padding: var(--space-3); border-radius: var(--radius); background-color: var(--success-muted); border: 1px solid var(--success-border); color: var(--success-muted-foreground); font-size: var(--text-sm);">
                                Appointment booked successfully!
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div style="margin-bottom: var(--space-3); padding: var(--space-3); border-radius: var(--radius); background-color: var(--destructive-muted); border: 1px solid var(--destructive-border); color: var(--destructive-muted-foreground); font-size: var(--text-sm);">
                                @errorMessage
                            </div>
                        }

                        <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="HandleSubmit" Disabled="@isProcessing">
                            @if (isProcessing)
                            {
                                <BbSpinner Size="SpinnerSize.Small" />
                                <span>Processing...</span>
                            }
                            else
                            {
                                <span>Confirm Booking</span>
                            }
                        </BbButton>
                    </div>

                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div style="height: 100vh; background: #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white;">
            <div class="spinner-border text-danger" role="status"></div>
            <h2 style="margin-top: 20px; color: #d32f2f;">Session Expired</h2>
            <p style="color: #666;">Protecting your data... Redirecting to Home.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .appt-layout {
        display: flex;
        gap: var(--space-6);
        padding: var(--space-6);
        min-height: calc(100vh - 3.5rem);
        align-items: flex-start;
    }

    .appt-services {
        flex: 1;
        min-width: 0;
    }

    .appt-right {
        width: 480px;
        flex-shrink: 0;
        position: sticky;
        top: var(--space-6);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@code {
    private bool isLoading = true;
    private Appointment newAppt = new() { AppointmentDate = DateTime.Now, TimeSlot = "" };
    private bool showSuccessMessage = false;
    private bool isProcessing = false;
    private string errorMessage = "";
    private string selectedCategory = "All";

    public class ServiceOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public string Category { get; set; } = "General";
        public bool IsSelected { get; set; }
    }

    private List<ServiceOption> availableServices = new();
    private List<string> bookedTimeSlots = new();

    private List<string> availableTimeSlots = new()
    {
        "09:00", "09:15", "09:30", "09:45", "10:00", "10:15", "10:30", "10:45", "11:00",
        "13:00", "13:15", "13:30", "13:45", "14:00", "14:15", "14:30", "14:45", "15:00",
        "15:15", "15:30", "15:45", "16:00", "16:15", "16:30"
    };

    private IEnumerable<ServiceOption> FilteredServices =>
        selectedCategory == "All"
        ? availableServices
        : availableServices.Where(s => s.Category == selectedCategory);

    private IEnumerable<ServiceOption> SelectedServices => availableServices.Where(s => s.IsSelected);
    private decimal TotalPrice => SelectedServices.Sum(s => s.Price);

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            var tasks = new List<Task> {
                FetchBookedSlots(),
                LoadUserProfile(),
                LoadServices()
            };
            await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during initialization: {ex.Message}");
            errorMessage = "A connection error occurred. Please refresh the page.";
        }
        finally
        {
            await Task.Delay(200);
            isLoading = false;
        }
    }

    private async Task LoadUserProfile()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                try
                {
                    var profile = await Http.GetFromJsonAsync<UserProfile>("api/user/profile");
                    newAppt.CustomerName = profile != null ? $"{profile.FirstName} {profile.LastName}".Trim() : user.Identity.Name ?? "User";
                }
                catch { newAppt.CustomerName = user.Identity.Name ?? "User"; }
            }
        }
    }

    private async Task LoadServices()
    {
        try
        {
            var dbServices = await Http.GetFromJsonAsync<List<StoreService>>("api/services");
            if (dbServices != null)
            {
                availableServices = dbServices.Select(s => new ServiceOption
                {
                    Id = s.Id,
                    Name = s.Name,
                    Price = s.Price,
                    Category = s.Category,
                    IsSelected = false
                }).ToList();
            }
        }
        catch { errorMessage = "Failed to load services."; }
    }

    private async Task FetchBookedSlots()
    {
        try
        {
            var dateStr = newAppt.AppointmentDate.ToString("yyyy-MM-dd");
            var slots = await Http.GetFromJsonAsync<List<string>>($"api/appointments/booked-slots?date={dateStr}");
            bookedTimeSlots = slots ?? new();
        }
        catch { Console.WriteLine("Booking fetch failed."); }
    }

    private void SelectTimeSlot(string time)
    {
        newAppt.TimeSlot = time;
        errorMessage = "";
    }

    private void ToggleService(ServiceOption service)
    {
        service.IsSelected = !service.IsSelected;
        showSuccessMessage = false;
        errorMessage = "";
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(newAppt.TimeSlot)) { errorMessage = "Please select a time slot."; return; }
        if (!SelectedServices.Any()) { errorMessage = "Please select at least one service."; return; }

        isProcessing = true;
        newAppt.ServicesRequested = string.Join(", ", SelectedServices.Select(s => s.Name));
        newAppt.TotalAmount = TotalPrice;
        newAppt.Category = SelectedServices.FirstOrDefault()?.Category ?? "General";

        try
        {
            var response = await Http.PostAsJsonAsync("api/appointments", newAppt);

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                NavigationManager.NavigateTo("/", forceLoad: true);
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                showSuccessMessage = true;
                errorMessage = "";
                newAppt = new() { AppointmentDate = DateTime.Now, CustomerName = newAppt.CustomerName };
                availableServices.ForEach(s => s.IsSelected = false);
                await FetchBookedSlots();
            }
            else
            {
                errorMessage = "Booking failed.";
            }
        }
        catch { errorMessage = "Connection error."; }
        finally { isProcessing = false; }
    }

    private DateTime calendarMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

    private IEnumerable<DateTime?> CalendarCells
    {
        get
        {
            var cells = new List<DateTime?>();
            var firstDay = (int)calendarMonth.DayOfWeek;
            for (int i = 0; i < firstDay; i++) cells.Add(null);
            var daysInMonth = DateTime.DaysInMonth(calendarMonth.Year, calendarMonth.Month);
            for (int d = 1; d <= daysInMonth; d++)
                cells.Add(new DateTime(calendarMonth.Year, calendarMonth.Month, d));
            return cells;
        }
    }

    private void PrevMonth() => calendarMonth = calendarMonth.AddMonths(-1);
    private void NextMonth() => calendarMonth = calendarMonth.AddMonths(1);

    private async Task SelectDate(DateTime date)
    {
        newAppt.AppointmentDate = date;
        newAppt.TimeSlot = "";
        await FetchBookedSlots();
    }
}