@page "/appointment"
@layout EmptyLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using StockSense.shared
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http


@attribute [Authorize]


<div style="display: flex; gap: 40px; color: white; background: #111; padding: 20px;">


    <div style="flex: 2;">

        <div style="margin-bottom: 30px; background: #222; padding: 20px; border-radius: 8px;">
            <h2 style="margin-top: 0; margin-bottom: 15px;">Customer Details & Time</h2>

            <div style="display: flex; gap: 20px; margin-bottom: 20px;">

                <label style="display: block; margin-bottom: 5px; color: #aaa;">Date</label>
                <input type="date" @bind="newAppt.AppointmentDate" @bind:after="FetchBookedSlots"
                       style="width: 100%; padding: 10px; background: #111; color: white; border: 1px solid #333; border-radius: 5px;" />
            </div>

            <div>
                <label style="display: block; margin-bottom: 10px; color: #aaa;">Select Time</label>
                <div style="display: flex; flex-wrap: wrap; gap: 10px; max-height: 150px; overflow-y: auto; padding-right: 10px;">
                    @foreach (var time in availableTimeSlots)
                    {
                        // Check if this specific time is in our taken list
                        bool isBooked = bookedTimeSlots.Contains(time);

                        <div @onclick="() => { if (!isBooked) SelectTimeSlot(time); }"
                             style="border: 1px solid @(newAppt.TimeSlot == time ? "white" : (isBooked ? "#222" : "#444"));
                    background: @(newAppt.TimeSlot == time ? "white" : (isBooked ? "#222" : "#111"));
                    color: @(newAppt.TimeSlot == time ? "black" : (isBooked ? "#555" : "white"));
                    text-decoration: @(isBooked ? "line-through" : "none");
                    cursor: @(isBooked ? "not-allowed" : "pointer");
                    padding: 10px; border-radius: 5px; text-align: center; flex: 1 1 calc(16% - 10px); min-width: 70px;">
                            @time
                        </div>
                    }
                    }
                </div>
            </div>
        </div>

        <h2>1. Select the services you want to avail</h2>

        @if (showSuccessMessage)
        {
            <div style="color: #4CAF50; font-weight: bold; margin-bottom: 15px; padding: 10px; border: 1px solid #4CAF50; border-radius: 5px;">
                Appointment booked successfully!
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="color: #f44336; font-weight: bold; margin-bottom: 15px; padding: 10px; border: 1px solid #f44336; border-radius: 5px;">
                @errorMessage
            </div>
        }

        <div style="display: flex; flex-wrap: wrap; gap: 15px;">
            @if (!availableServices.Any())
            {
                <div style="color: gray; padding: 20px;">Loading services...</div>
            }
            else
            {
                @foreach (var service in availableServices)
                {
                    <div @onclick="() => ToggleService(service)"
                         style="border: 2px solid @(service.IsSelected ? "red" : "#333");
                                                background: #222; padding: 15px; cursor: pointer; width: 200px; border-radius: 8px;">

                        <div style="display: flex; justify-content: space-between;">
                            <strong>@service.Name</strong>
                            <input type="checkbox" checked="@service.IsSelected" style="pointer-events: none;" />
                        </div>
                        <div style="margin-top: 20px; color: #aaa;">
                            P @service.Price
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div style="flex: 1; background: #000; padding: 20px; border-radius: 8px; display: flex; flex-direction: column;">
        <h2>3. View the summary</h2>

        <ul style="list-style: none; padding: 0; flex-grow: 1;">
            @if (!SelectedServices.Any())
            {
                <li style="color: gray;">No services selected yet.</li>
            }
            @foreach (var selected in SelectedServices)
            {
                <li style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span>@selected.Name</span>
                    <span>P @selected.Price</span>
                </li>
            }
        </ul>

        <hr style="border-color: #333; margin-top: auto;" />

        <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 1.2em; margin-bottom: 20px;">
            <span>Total</span>
            <span>P @TotalPrice</span>
        </div>

        <button @onclick="HandleSubmit"
                style="width: 100%; padding: 15px; background: white; color: black; font-weight: bold; border: none; border-radius: 5px; cursor: pointer;">
            Next / Book Appointment
        </button>
    </div>

</div>

@code {
    // --- State Variables ---
    private Appointment newAppt = new() { AppointmentDate = DateTime.Now, TimeSlot = " " };
    private bool showSuccessMessage = false;
    private string errorMessage = "";

    // 1. A simple class to represent each service card in the UI
    public class ServiceOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public bool IsSelected { get; set; }
    }

    // 2. Start with an empty list
    private List<ServiceOption> availableServices = new();

    private List<string> bookedTimeSlots = new();

    private async Task FetchBookedSlots()
    {
        try
        {
            // Format the date to send to the API (e.g., ?date=2026-03-04)
            var dateString = newAppt.AppointmentDate.ToString("yyyy-MM-dd");

            // Fetch the list of taken strings from the server
            var slots = await Http.GetFromJsonAsync<List<string>>($"api/appointments/booked-slots?date={dateString}");

            if (slots != null)
            {
                bookedTimeSlots = slots;
            }

            // If the user currently has a slot selected that just became "booked", clear their selection
            if (!string.IsNullOrEmpty(newAppt.TimeSlot) && bookedTimeSlots.Contains(newAppt.TimeSlot))
            {
                newAppt.TimeSlot = "";
                errorMessage = "Your selected time slot is no longer available.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load booked slots: {ex.Message}");
        }
    }

     private List<string> availableTimeSlots = new()
    {
        "09:00", "09:15", "09:30", "09:45", "10:00", "10:15",
        "10:30", "10:45", "11:00", "13:00", "13:15", "13:30",
        "13:45", "14:00", "14:15", "14:30", "14:45", "15:00",
        "15:15", "15:30", "15:45", "16:00", "16:15", "16:30"
    };


    private void SelectTimeSlot(string time)
    {
        newAppt.TimeSlot = time;
        errorMessage = ""; // Clear errors if they are trying to fix a missed field
    }

    // 3. Dynamic properties that automatically update when a checkbox is clicked
    private IEnumerable<ServiceOption> SelectedServices => availableServices.Where(s => s.IsSelected);
    private decimal TotalPrice => SelectedServices.Sum(s => s.Price);

    // 4. Fetch the data from the database when the page loads
    // NEW: The proper way to get Auth State in Blazor 8
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await FetchBookedSlots();
        // 1. Check Auth State safely
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                try
                {
                    // Call the API endpoint to get the custom UserProfile
                    var profile = await Http.GetFromJsonAsync<UserProfile>("api/user/profile");

                    if (profile != null)
                    {
                        // Safely combine First and Last name
                        newAppt.CustomerName = $"{profile.FirstName ?? ""} {profile.LastName ?? ""}".Trim();
                    }
                    else
                    {
                        newAppt.CustomerName = user.Identity.Name ?? "Account User";
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Profile fetch failed: {ex.Message}");
                    newAppt.CustomerName = user.Identity.Name ?? "Account User";
                }
            }
            else
            {
                newAppt.CustomerName = "Guest User";
            }
        }
        else
        {
            newAppt.CustomerName = "Guest User";
        }

        // 2. Fetch the services from the database
        try
        {
            var dbServices = await Http.GetFromJsonAsync<List<StoreService>>("api/services");

            if (dbServices != null)
            {
                availableServices = dbServices.Select(s => new ServiceOption
                {
                    Id = s.Id,
                    Name = s.Name,
                    Price = s.Price,
                    IsSelected = false
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load services from the database.";
            Console.WriteLine($"Service error: {ex.Message}");
        }
    }


    // 5. The function that runs when a card is clicked
    private void ToggleService(ServiceOption service)
    {
        service.IsSelected = !service.IsSelected;

        showSuccessMessage = false;
        errorMessage = "";
    }

    // 6. The Submit Logic
    private async Task HandleSubmit()
    {
        // ==========================================
        // NEW: Validation Checks
        // ==========================================
        if (string.IsNullOrWhiteSpace(newAppt.CustomerName))
        {
            errorMessage = "Please enter your full name.";
            return; // Stops the submission
        }

        if (string.IsNullOrEmpty(newAppt.TimeSlot))
        {
            errorMessage = "Please select a time slot.";
            return;
        }

        if (!SelectedServices.Any())
        {
            errorMessage = "Please select at least one service.";
            return; // Stops the submission
        }

        // Pack the data for the database
        newAppt.ServicesRequested = string.Join(", ", SelectedServices.Select(s => s.Name));
        newAppt.TotalAmount = TotalPrice;

        try
        {
            var response = await Http.PostAsJsonAsync("api/appointments", newAppt);

            if (response.IsSuccessStatusCode)
            {
                newAppt = new() { AppointmentDate = DateTime.Now }; // Reset form
                availableServices.ForEach(s => s.IsSelected = false); // Uncheck boxes
                showSuccessMessage = true;
                errorMessage = ""; // Clear any old errors
            }
            else
            {
                errorMessage = $"Server error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not connect: {ex.Message}";
        }
    }
}