@page "/my-bookings"
@layout EmptyLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.shared
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager NavigationManager

@attribute [Authorize]

<AuthorizeView>
    <Authorized>
        <div style="padding: 20px; color: white; background: #111; min-height: 100vh;">
            <h2 style="margin-bottom: 20px;">My Appointment History</h2>

            @if (isLoading)
            {
                <p style="color: gray;">Loading your records...</p>
            }
            else if (myAppointments == null || !myAppointments.Any())
            {
                <div style="padding: 20px; background: #222; border-radius: 8px; text-align: center;">
                    <p style="color: gray;">You have no booking history yet.</p>
                    <a href="/appointment" style="color: #2196F3; text-decoration: none; font-weight: bold;">Book your first appointment</a>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    @foreach (var appt in myAppointments)
                    {
                        <div style="background: #222; padding: 20px; border-radius: 8px; border-left: 5px solid @GetStatusColor(appt.Status);">

                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                                <h3 style="margin: 0;">@appt.AppointmentDate.ToShortDateString() at @appt.TimeSlot</h3>

                                <span style="padding: 5px 12px; font-weight: bold; background: #111; border-radius: 20px; color: @GetStatusColor(appt.Status);">
                                    @appt.Status
                                </span>
                            </div>

                            <p style="margin: 5px 0; color: #aaa;"><strong>Services:</strong> @appt.ServicesRequested</p>
                            <p style="margin: 5px 0; color: white; font-size: 1.1em;"><strong>Total:</strong> P @appt.TotalAmount</p>
                        </div>
                    }
                </div>
            }
        </div>
    </Authorized>

    <NotAuthorized>
        <div style="height: 100vh; background: #000; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-family: sans-serif;">
            <div class="spinner-border text-primary" role="status" style="margin-bottom: 20px;"></div>
            <h2 style="color: #2196F3;">Session Expired</h2>
            <p style="color: #666;">Protecting your records... Redirecting to security center.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private List<Appointment>? myAppointments;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                string customerName = user.Identity.Name ?? "Account User";

                try
                {
                    // 1. Fetch Profile
                    var profileResponse = await Http.GetAsync("api/user/profile");

                    if (profileResponse.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                    {
                        NavigationManager.NavigateTo("/session-expired");
                        return;
                    }

                    var profile = await profileResponse.Content.ReadFromJsonAsync<UserProfile>();
                    if (profile != null)
                    {
                        customerName = $"{profile.FirstName ?? ""} {profile.LastName ?? ""}".Trim();
                    }

                    // 2. Fetch Bookings
                    var bookingsResponse = await Http.GetAsync($"api/appointments/my-bookings?name={Uri.EscapeDataString(customerName)}");

                    if (bookingsResponse.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                    {
                        NavigationManager.NavigateTo("/session-expired");
                        return;
                    }

                    myAppointments = await bookingsResponse.Content.ReadFromJsonAsync<List<Appointment>>();
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error fetching bookings: {ex.Message}");
                }
            }
        }
        isLoading = false;
    }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Pending" => "#ffc107",   // Yellow
            "Confirmed" => "#2196F3", // Blue
            "Completed" => "#4CAF50", // Green
            "Cancelled" => "#f44336", // Red
            _ => "#ffffff"            // White default
        };
    }
}