@page "/admin/prebuilds"
@layout AdminLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using BlazorBlueprint.Primitives.Services
@inject HttpClient Http

@attribute [Authorize(Roles = "Employee, Admin")]

<PageTitle>Manage Pre-Build Packages</PageTitle>



    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-6);">
        <div>
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Pre-Build Packages</h1>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Create and manage guided motor build packages.</p>
        </div>
            <BbButton Variant="ButtonVariant.Default" @onclick="OpenCreateModal">
                <LucideIcon Name="package-plus" Size="16" />
                Create Package
            </BbButton>
    </div>

    @* --- LIST OF EXISTING PACKAGES --- *@
    @if (isLoading)
    {
        <div style="width: 100%; display: flex; justify-content: center; align-items: center;">
            <LightSpinner Description="Loading Packages..."/>
        </div>
    }
    else if (!existingPackages.Any())
    {
        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-8); text-align: center; color: var(--muted-foreground);">
            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-2);">
                <LucideIcon Name="package" Size="32" />
                <span style="font-size: var(--text-sm);">No packages created yet.</span>
            </div>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-4);">
            @foreach (var pkg in existingPackages)
            {
                <div style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-4);">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-2);">
                        <h3 style="font-size: var(--text-lg); font-weight: bold; margin: 0; color: var(--foreground);">@pkg.Name</h3>
                        <span style="font-size: var(--text-sm); font-weight: 900; color: var(--primary);">₱@pkg.TotalPrice.ToString("N0")</span>
                    </div>
                    <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin-bottom: var(--space-3);">@pkg.Description</p>

                    <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: var(--space-3);">
                        <span style="font-size: 10px; background: var(--muted); padding: 2px 6px; border-radius: 4px; color: var(--foreground);">@pkg.CompatibleBrand</span>
                        <span style="font-size: 10px; background: var(--muted); padding: 2px 6px; border-radius: 4px; color: var(--foreground);">@pkg.CompatibleModel</span>
                        <span style="font-size: 10px; background: var(--muted); padding: 2px 6px; border-radius: 4px; color: var(--foreground);">@pkg.TargetCC</span>
                        @* NEW: Show the Added CC badge *@
                        <span style="font-size: 10px; background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.3); padding: 2px 6px; border-radius: 4px; color: #3b82f6; font-weight: bold;">+@pkg.EstimatedAddedCC CC</span>
                    </div>

                    <p style="font-size: 10px; font-weight: bold; text-transform: uppercase; color: var(--muted-foreground); margin: 0 0 4px 0;">Includes @pkg.IncludedProducts.Count Parts:</p>
                    <ul style="margin: 0; padding-left: 16px; font-size: var(--text-xs); color: var(--muted-foreground);">
                        @foreach (var part in pkg.IncludedProducts.Take(3))
                        {
                            <li>@part.Name</li>
                        }
                        @if (pkg.IncludedProducts.Count > 3)
                        {
                            <li style="list-style: none; font-style: italic; margin-top: 2px;">+ @(pkg.IncludedProducts.Count - 3) more items</li>
                        }
                    </ul>
                </div>
            }
        </div>
    }
    

@* --- CREATE PACKAGE MODAL --- *@
<BbDialog @bind-Open="showCreateModal">
    <BbDialogContent Class="max-w-4xl" Style="display: flex; flex-direction: column; max-height: 90vh;">

        <BbDialogHeader Style="flex-shrink: 0;">
            <BbDialogTitle>Create Pre-Build Package</BbDialogTitle>
            <BbDialogDescription>Combine existing inventory products into a single guided package.</BbDialogDescription>
        </BbDialogHeader>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="padding: 12px; background: var(--destructive-muted); color: var(--destructive-muted-foreground); border: 1px solid var(--destructive-border); border-radius: var(--radius); font-size: var(--text-sm); margin-bottom: 16px; flex-shrink: 0;">
                @errorMessage
            </div>
        }

        @* SCROLLABLE MIDDLE SECTION *@
        <div style="flex: 1; overflow-y: auto; padding-right: 8px; margin-top: var(--space-2);">
            <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: var(--space-4);">

                @* LEFT SIDE: Details *@
                <div style="display: flex; flex-direction: column; gap: var(--space-3);">
                    <div>
                        <label style="font-size: var(--text-xs); font-weight: bold; margin-bottom: 4px; display: block;">Package Name</label>
                        <input type="text" @bind="newPackage.Name" placeholder="e.g., Touring Spec Setup" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                    </div>

                    <div>
                        <label style="font-size: var(--text-xs); font-weight: bold; margin-bottom: 4px; display: block;">Description</label>
                        <textarea @bind="newPackage.Description" rows="3" placeholder="Describe who this build is for..." style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground); resize: none;"></textarea>
                    </div>

                    @* --- CASCADING DROPDOWNS --- *@
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <div>
                            <label style="font-size: var(--text-xs); font-weight: bold; margin-bottom: 4px; display: block;">Motor Brand</label>
                            <select value="@newPackage.CompatibleBrand" @onchange="OnBrandChanged" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);">
                                <option value="">Select Brand...</option>
                                @foreach (var brand in motorDatabase.Keys)
                                {
                                    <option value="@brand">@brand</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label style="font-size: var(--text-xs); font-weight: bold; margin-bottom: 4px; display: block;">Motor Model</label>
                            <select value="@newPackage.CompatibleModel" @onchange="OnModelChanged" disabled="@string.IsNullOrEmpty(newPackage.CompatibleBrand)" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid var(--border); background: @(string.IsNullOrEmpty(newPackage.CompatibleBrand) ? "var(--muted)" : "var(--background)"); color: var(--foreground);">
                                <option value="">Select Model...</option>
                                @if (!string.IsNullOrEmpty(newPackage.CompatibleBrand) && motorDatabase.ContainsKey(newPackage.CompatibleBrand))
                                {
                                    @foreach (var model in motorDatabase[newPackage.CompatibleBrand].Keys)
                                    {
                                        <option value="@model">@model</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <div>
                            <label style="font-size: var(--text-xs); font-weight: bold; margin-bottom: 4px; display: block;">Target CC Range</label>
                            <select @bind="newPackage.TargetCC" disabled="@string.IsNullOrEmpty(newPackage.CompatibleModel)" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid var(--border); background: @(string.IsNullOrEmpty(newPackage.CompatibleModel) ? "var(--muted)" : "var(--background)"); color: var(--foreground);">
                                <option value="">Select CC...</option>
                                @if (!string.IsNullOrEmpty(newPackage.CompatibleBrand) && !string.IsNullOrEmpty(newPackage.CompatibleModel) && motorDatabase.ContainsKey(newPackage.CompatibleBrand) && motorDatabase[newPackage.CompatibleBrand].ContainsKey(newPackage.CompatibleModel))
                                {
                                    @foreach (var cc in motorDatabase[newPackage.CompatibleBrand][newPackage.CompatibleModel])
                                    {
                                        <option value="@cc">@cc</option>
                                    }
                                }
                            </select>
                        </div>
                        @* --- NEW: ESTIMATED ADDED CC INPUT --- *@
                        <div>
                            <label style="font-size: var(--text-xs); font-weight: bold; margin-bottom: 4px; display: block;">Estimated Added CC</label>
                            <input type="number" @bind="newPackage.EstimatedAddedCC" placeholder="e.g., 30" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                        </div>
                    </div>
                    <p style="font-size: 10px; color: var(--muted-foreground); margin-top: -6px;">Added CC powers the dynamic stats bar (Power/Speed/Reliability) on the build page.</p>
                </div>

                @* RIGHT SIDE: Product Selection with Filters *@
                <div style="border: 1px solid var(--border); border-radius: var(--radius); display: flex; flex-direction: column; overflow: hidden; background: var(--card);">

                    <div style="padding: 12px; border-bottom: 1px solid var(--border); background: var(--muted); display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: var(--text-sm); font-weight: bold;">Select Products</span>
                        <span style="font-size: var(--text-xs); color: var(--primary); font-weight: bold; background: color-mix(in oklch, var(--primary) 10%, transparent); padding: 4px 8px; border-radius: 999px;">@newPackage.ProductIds.Count selected</span>
                    </div>

                    @* --- SEARCH & FILTER BAR --- *@
                    <div style="padding: 8px 12px; border-bottom: 1px solid var(--border); display: flex; gap: 8px; background: var(--background);">
                        <div style="position: relative; flex: 1;">
                            <LucideIcon Name="search" Size="14" style="position: absolute; left: 8px; top: 50%; transform: translateY(-50%); color: var(--muted-foreground);" />
                            <input type="text" @bind="productSearchQuery" @bind:event="oninput" placeholder="Search by name or brand..."
                                   style="width: 100%; padding: 6px 8px 6px 28px; border-radius: 4px; border: 1px solid var(--border); background: var(--card); color: var(--foreground); font-size: var(--text-xs);" />
                        </div>
                        <select @bind="productCategoryFilter" style="padding: 6px 8px; border-radius: 4px; border: 1px solid var(--border); background: var(--card); color: var(--foreground); font-size: var(--text-xs); width: 120px;">
                            <option value="All">All Categories</option>
                            @foreach (var cat in ModalCategories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>

                    @* Product List (Internal scroll) *@
                    <div style="flex: 1; overflow-y: auto; max-height: 250px; padding: 8px;">
                        @if (allProducts == null)
                        {
                            <div style="padding: 20px; text-align: center;"><BbSpinner Size="SpinnerSize.Small" /></div>
                        }
                        else if (!FilteredModalProducts.Any())
                        {
                            <div style="padding: 20px; text-align: center; color: var(--muted-foreground); font-size: var(--text-sm);">
                                No products match your search.
                            </div>
                        }
                        else
                        {
                            @foreach (var product in FilteredModalProducts)
                            {
                                bool isChecked = newPackage.ProductIds.Contains(product.Id);
                                <div @onclick="() => ToggleProductSelection(product.Id)"
                                     style="display: flex; align-items: center; justify-content: space-between; padding: 8px; border-radius: 4px; cursor: pointer; transition: background 0.15s; background: @(isChecked ? "color-mix(in oklch, var(--primary) 10%, transparent)" : "transparent"); border-bottom: 1px solid var(--muted);">

                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <input type="checkbox" checked="@isChecked" style="pointer-events: none;" />
                                        <div>
                                            <div style="font-size: var(--text-sm); color: var(--foreground); font-weight: @(isChecked ? "bold" : "normal");">@product.Name</div>
                                            <div style="font-size: 10px; color: var(--muted-foreground);">@product.Category • @product.Brand</div>
                                        </div>
                                    </div>
                                    <span style="font-size: var(--text-xs); font-weight: bold; color: var(--foreground);">₱@product.Price.ToString("N0")</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        @* PINNED BOTTOM FOOTER *@
        <div style="flex-shrink: 0; margin-top: 16px; border-top: 1px solid var(--border); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
            <div style="font-size: var(--text-sm);">
                Total Package Value: <span style="font-size: var(--text-lg); font-weight: 900; color: var(--primary);">₱@CalculateCurrentTotal().ToString("N0")</span>
            </div>
            <div style="display: flex; gap: 8px;">
                <BbButton Variant="ButtonVariant.Ghost" OnClick="() => showCreateModal = false">Cancel</BbButton>
                <BbButton Variant="ButtonVariant.Default" OnClick="SubmitPackage" Disabled="isProcessing">
                    @if (isProcessing)
                    {
                        <BbSpinner Size="SpinnerSize.Small" />
                    }
                    else
                    {
                        <span>Create Package</span>
                    }
                </BbButton>
            </div>
        </div>

    </BbDialogContent>
</BbDialog>

@code {
    private bool isLoading = true;
    private bool isProcessing = false;
    private bool showCreateModal = false;
    private string errorMessage = "";

    // Search and Filter State
    private string productSearchQuery = "";
    private string productCategoryFilter = "All";

    // Data from the backend
    private List<PreBuildPackage> existingPackages = new();
    private List<Product>? allProducts;

    // The DTO we will send to the API
    private CreatePreBuildDto newPackage = new();

    // --- EXACT MATCH DATABASE ---
    private Dictionary<string, Dictionary<string, List<string>>> motorDatabase = new()
    {
        { "Yamaha", new() {
            { "Mio Sporty / Soul", new() { "59mm (150cc)", "63mm (180cc)", "65mm (200cc)" } },
            { "Mio i125 / M3", new() { "59mm (150cc)", "63mm (180cc)" } },
            { "Aerox / NMAX v1-v2", new() { "63mm (180cc)", "65mm (200cc)", "66mm+ (Racing)" } },
            { "Sniper 150/155", new() { "62mm (180cc)", "65mm (200cc)", "Superhead Build" } }
        }},
        { "Honda", new() {
            { "Click 125i/150i", new() { "59mm (150cc)", "61mm (160cc)", "63mm (180cc)" } },
            { "PCX / ADV 150", new() { "61mm (160cc)", "63mm (180cc)" } },
            { "PCX / ADV 160", new() { "63mm (180cc)", "65mm (200cc)" } },
            { "Beat 110", new() { "55mm (130cc)", "59mm (150cc)" } }
        }},
        { "Suzuki", new() {
            { "Raider 150 Carb", new() { "66mm (200cc)", "68mm (220cc)", "Open Spec" } },
            { "Raider 150 FI", new() { "66mm (200cc)", "68mm (220cc)" } },
            { "Smash / Skydrive", new() { "59mm (150cc)", "63mm (180cc)" } }
        }}
    };

    // Local model for displaying fetched packages
    public class PreBuildPackage
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string CompatibleBrand { get; set; } = "";
        public string CompatibleModel { get; set; } = "";
        public string TargetCC { get; set; } = "";
        public int EstimatedAddedCC { get; set; } // <--- NEW PROPERTY
        public decimal TotalPrice { get; set; }
        public List<Product> IncludedProducts { get; set; } = new();
    }

    private IEnumerable<string> ModalCategories => (allProducts ?? new List<Product>())
        .Select(p => p.Category)
        .Distinct()
        .OrderBy(c => c);

    private IEnumerable<Product> FilteredModalProducts
    {
        get
        {
            if (allProducts == null) return Array.Empty<Product>();

            var query = allProducts.AsEnumerable();

            if (productCategoryFilter != "All")
            {
                query = query.Where(p => p.Category == productCategoryFilter);
            }

            if (!string.IsNullOrWhiteSpace(productSearchQuery))
            {
                var searchLower = productSearchQuery.ToLower();
                query = query.Where(p => p.Name.ToLower().Contains(searchLower) ||
                                         p.Brand.ToLower().Contains(searchLower));
            }

            return query.OrderBy(p => p.Category).ThenBy(p => p.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var pkgs = await Http.GetFromJsonAsync<List<PreBuildPackage>>("api/prebuilds/all");
            if (pkgs != null) existingPackages = pkgs;

            allProducts = await Http.GetFromJsonAsync<List<Product>>("api/products");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        newPackage = new CreatePreBuildDto();
        productSearchQuery = "";
        productCategoryFilter = "All";
        errorMessage = "";
        showCreateModal = true;
    }

    private void OnBrandChanged(ChangeEventArgs e)
    {
        newPackage.CompatibleBrand = e.Value?.ToString() ?? "";
        newPackage.CompatibleModel = ""; // Reset child
        newPackage.TargetCC = "";        // Reset child
    }

    private void OnModelChanged(ChangeEventArgs e)
    {
        newPackage.CompatibleModel = e.Value?.ToString() ?? "";
        newPackage.TargetCC = "";        // Reset child
    }

    private void ToggleProductSelection(int productId)
    {
        if (newPackage.ProductIds.Contains(productId))
        {
            newPackage.ProductIds.Remove(productId);
        }
        else
        {
            newPackage.ProductIds.Add(productId);
        }
    }

    private decimal CalculateCurrentTotal()
    {
        if (allProducts == null || !newPackage.ProductIds.Any()) return 0;
        return allProducts.Where(p => newPackage.ProductIds.Contains(p.Id)).Sum(p => p.Price);
    }

    private async Task SubmitPackage()
    {
        errorMessage = "";

        // Basic Validation
        if (string.IsNullOrWhiteSpace(newPackage.Name)) { errorMessage = "Package Name is required."; return; }
        if (string.IsNullOrWhiteSpace(newPackage.CompatibleBrand) || string.IsNullOrWhiteSpace(newPackage.CompatibleModel) || string.IsNullOrWhiteSpace(newPackage.TargetCC))
        { errorMessage = "Brand, Model, and CC specs are required."; return; }
        if (!newPackage.ProductIds.Any()) { errorMessage = "You must select at least one product."; return; }

        isProcessing = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/prebuilds", newPackage);

            if (response.IsSuccessStatusCode)
            {
                showCreateModal = false;
                await LoadData();
            }
            else
            {
                errorMessage = "Failed to save package. " + await response.Content.ReadAsStringAsync();
            }
        }
        catch
        {
            errorMessage = "Connection error while saving.";
        }
        finally
        {
            isProcessing = false;
        }
    }
}