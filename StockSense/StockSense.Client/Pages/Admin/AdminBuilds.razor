@page "/admin/builds"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Text.Json
@using System.Globalization
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager Nav

@attribute [Authorize(Roles = "Admin")]

<AuthorizeView Roles="Admin">
    <Authorized>
        <div class="admin-container">
            <div class="header-section">
                <h2>Manage Custom Builds</h2>
                <span class="badge-count">@ActiveBuilds.Count(b => b.Status == "Pending") Pending</span>
            </div>

            @if (allBuilds == null)
            {
                <div class="loading-state">Loading build requests...</div>
            }
            else
            {
                @* --- NEW TABS NAVIGATION --- *@
                <div class="tabs-container">
                    <button class="tab-btn @(activeTab == "Active" ? "active" : "")" @onclick='() => activeTab = "Active"'>
                        Active Builds (@ActiveBuilds.Count())
                    </button>
                    <button class="tab-btn @(activeTab == "History" ? "active" : "")" @onclick='() => activeTab = "History"'>
                        History (@HistoryBuilds.Count())
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table-dark">
                        <thead>
                            <tr>
                                <th style="width: 20%;">Customer</th>
                                <th style="width: 20%;">Date</th>
                                <th style="width: 15%;">Summary</th>
                                <th style="width: 15%;">Total Value</th>
                                <th style="width: 15%;">Status</th>
                                <th style="width: 15%;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var build in DisplayBuilds)
                            {
                                var parts = ParseParts(build.SelectedPartsJson);
                                var totalPrice = parts.Sum(p => p.Price);

                                <tr class="table-row">
                                    <td class="customer-name">@build.CustomerName</td>
                                    <td class="date">@build.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td>

                                    <td class="summary">
                                        <span class="item-count">@parts.Count items</span>
                                    </td>

                                    <td class="price">@totalPrice.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))</td>

                                    <td>
                                        <select value="@build.Status"
                                                @onchange="@(e => UpdateStatus(build, e.Value?.ToString() ?? "Pending"))"
                                                class="status-dropdown @GetStatusClass(build.Status)">
                                            <option value="Pending">Pending</option>
                                            <option value="Confirmed">Confirmed</option>
                                            <option value="Completed">Completed</option>
                                            <option value="Cancelled">Cancelled</option>
                                        </select>
                                    </td>
                                    <td>
                                        <button class="btn-view" @onclick="() => OpenModal(build, parts)">
                                            <span class="icon">👁</span> View Details
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!DisplayBuilds.Any())
                            {
                                <tr>
                                    <td colspan="6" style="text-align: center; padding: 30px; color: #888;">No builds found in this section.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @* --- MODAL FOR VIEWING DETAILS --- *@
            @if (ShowModal && CurrentParts != null)
            {
                <div class="modal-backdrop" @onclick="CloseModal">
                    <div class="modal-content" @onclick:stopPropagation>
                        <div class="modal-header">
                            <div>
                                <h3>@CurrentBuild?.CustomerName's Build</h3>
                                <span class="modal-date">@CurrentBuild?.CreatedAt.ToString("f")</span>
                            </div>
                            <button class="close-btn" @onclick="CloseModal">×</button>
                        </div>

                        <div class="modal-body">
                            @foreach (var group in CurrentParts.GroupBy(p => p.Category))
                            {
                                <div class="category-section">
                                    <h4 class="category-header">@group.Key</h4>
                                    @foreach (var part in group)
                                    {
                                        <div class="part-item">
                                            <div class="part-details">
                                                <span class="brand-tag">@part.Brand</span>
                                                <span class="part-name">@part.Name</span>
                                            </div>
                                            <div class="part-price">
                                                @part.Price.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="modal-footer">
                            <div class="total-summary">
                                <span>Grand Total:</span>
                                <span class="total-amount">@CurrentParts.Sum(p => p.Price).ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))</span>
                            </div>
                            <button class="btn-close" @onclick="CloseModal">Close</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </Authorized>

    <NotAuthorized>
        <div style="height: 100vh; background: #121212; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-family: sans-serif;">
            <div class="spinner-border text-danger" role="status" style="margin-bottom: 20px;"></div>
            <h2 style="color: #d32f2f;">Admin Session Expired</h2>
            <p style="color: #666;">Securing customer build data... Redirecting.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<BuildRequest>? allBuilds;
    private string activeTab = "Active";

    private IEnumerable<BuildRequest> ActiveBuilds =>
        allBuilds?.Where(b => b.Status == "Pending" || b.Status == "Confirmed").OrderByDescending(b => b.CreatedAt) ?? Enumerable.Empty<BuildRequest>();

    private IEnumerable<BuildRequest> HistoryBuilds =>
        allBuilds?.Where(b => b.Status == "Completed" || b.Status == "Cancelled").OrderByDescending(b => b.CreatedAt) ?? Enumerable.Empty<BuildRequest>();

    private IEnumerable<BuildRequest> DisplayBuilds => activeTab == "Active" ? ActiveBuilds : HistoryBuilds;

    private bool ShowModal = false;
    private BuildRequest? CurrentBuild;
    private List<Product> CurrentParts = new List<Product>();

    protected override async Task OnInitializedAsync() => await LoadBuilds();

    private async Task LoadBuilds()
    {
        try
        {
            var response = await Http.GetAsync("api/builds/all");

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Nav.NavigateTo("/session-expired");
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                allBuilds = await response.Content.ReadFromJsonAsync<List<BuildRequest>>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading builds: {ex.Message}");
        }
    }

    private async Task UpdateStatus(BuildRequest build, string newStatus)
    {
        try
        {
            var response = await Http.PutAsJsonAsync($"api/builds/{build.Id}/status", newStatus);

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Nav.NavigateTo("/session-expired");
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                build.Status = newStatus;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating status: {ex.Message}");
        }
    }

    private List<Product> ParseParts(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new List<Product>();
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<List<Product>>(json, options) ?? new List<Product>();
        }
        catch { return new List<Product>(); }
    }

    private void OpenModal(BuildRequest build, List<Product> parts)
    {
        CurrentBuild = build;
        CurrentParts = parts;
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    private string GetStatusClass(string status) => status?.ToLower() switch
    {
        "pending" => "status-pending",
        "confirmed" => "status-confirmed",
        "completed" => "status-completed",
        "cancelled" => "status-cancelled",
        _ => ""
    };
}

