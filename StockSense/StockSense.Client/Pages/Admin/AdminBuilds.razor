@page "/admin/builds"
@layout AdminLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Text.Json
@using System.Globalization
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

@attribute [Authorize(Roles = "Admin")]

<PageTitle>Manage Builds</PageTitle>

<div>
    <div style="display: flex; align-items: start; margin-bottom: var(--space-6); flex-wrap: wrap; flex-direction: column;">
        <div style="display: flex; align-items: center; gap: var(--space-2); flex: 1; flex-direction: row;">
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Manage Builds</h1>
            <BbBadge Variant="BadgeVariant.Destructive">
                @ActiveBuilds.Count(b => b.Status == "Pending") Pending
            </BbBadge>
        </div>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Review and manage customer build requests.</p>
    </div>

    @if (allBuilds == null)
    {
        <div style="display: flex; justify-content: center; align-items: center; padding: var(--space-8); color: var(--muted-foreground); gap: var(--space-3);">
            <BbSpinner Size="SpinnerSize.Small" />
            <span>Loading build requests...</span>
        </div>
    }
    else
    {
        @* Tabs *@
        <div style="display: flex; gap: var(--space-2); margin-bottom: var(--space-4);">
            <button @onclick='() => activeTab = "Active"'
                    style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(activeTab == "Active" ? "var(--secondary)" : "transparent"); color: @(activeTab == "Active" ? "var(--foreground)" : "var(--muted-foreground)"); font-family: var(--font-sans);">
                Active (@ActiveBuilds.Count())
            </button>
            <button @onclick='() => activeTab = "History"'
                    style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(activeTab == "History" ? "var(--secondary)" : "transparent"); color: @(activeTab == "History" ? "var(--foreground)" : "var(--muted-foreground)"); font-family: var(--font-sans);">
                History (@HistoryBuilds.Count())
            </button>
        </div>

        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius);">
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); min-width: 600px;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 20%;">Customer</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 20%;">Date</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 15%;">Summary</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 15%;">Total Value</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 15%;">Status</th>
                            <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 15%;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!DisplayBuilds.Any())
                        {
                            <tr>
                                <td colspan="6" style="text-align: center; padding: var(--space-8); color: var(--muted-foreground);">
                                    <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-2);">
                                        <LucideIcon Name="inbox" Size="32" />
                                        <span>No builds found in this section.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var build in DisplayBuilds)
                        {
                            var parts = ParseParts(build.SelectedPartsJson);
                            var totalPrice = parts.Sum(p => p.Price);

                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: var(--space-3) var(--space-4); font-weight: var(--font-medium); color: var(--foreground);">@build.CustomerName</td>
                                <td style="padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-size: var(--text-xs);">@build.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td>
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <BbBadge Variant="BadgeVariant.Secondary">@parts.Count items</BbBadge>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4); font-weight: var(--font-semibold); color: var(--foreground);">
                                    @totalPrice.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))
                                </td>
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <select value="@build.Status"
                                            @onchange="@((ChangeEventArgs e) => UpdateStatus(build, e.Value?.ToString() ?? "Pending"))"
                                            style="padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid @GetStatusBorderColor(build.Status); background-color: var(--background); color: var(--foreground); font-size: var(--text-sm); cursor: pointer; font-family: var(--font-sans);">
                                        <option value="Pending">Pending</option>
                                        <option value="Confirmed">Confirmed</option>
                                        <option value="Completed">Completed</option>
                                        <option value="Cancelled">Cancelled</option>
                                    </select>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small"
                                              OnClick="() => OpenModal(build, parts)">
                                        <LucideIcon Name="eye" Size="14" />
                                        View
                                    </BbButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* Modal *@
@if (ShowModal && CurrentParts != null)
{
    <div @onclick="CloseModal" style="position: fixed; inset: 0; background-color: rgba(0,0,0,0.7); display: flex; justify-content: center; align-items: center; z-index: 1000; padding: var(--space-4);">
        <div @onclick:stopPropagation style="background-color: var(--card); width: 600px; max-width: 100%; max-height: 85vh; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: var(--shadow-lg); display: flex; flex-direction: column;">

            <div style="padding: var(--card-padding); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <h3 style="font-size: var(--text-lg); font-weight: var(--font-semibold); color: var(--foreground); margin: 0;">@CurrentBuild?.CustomerName's Build</h3>
                    <span style="font-size: var(--text-xs); color: var(--muted-foreground); margin-top: var(--space-1); display: block;">@CurrentBuild?.CreatedAt.ToString("f")</span>
                </div>
                <button @onclick="CloseModal" style="background: none; border: none; cursor: pointer; color: var(--muted-foreground); padding: var(--space-1); border-radius: var(--radius); display: flex; align-items: center; justify-content: center;">
                    <LucideIcon Name="x" Size="18" />
                </button>
            </div>

            <div style="padding: var(--card-padding); overflow-y: auto; flex: 1;">
                @foreach (var group in CurrentParts.GroupBy(p => p.Category))
                {
                    <div style="margin-bottom: var(--space-6);">
                        <h4 style="font-size: var(--text-xs); color: var(--primary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 var(--space-3) 0; padding-bottom: var(--space-2); border-bottom: 1px solid var(--border);">@group.Key</h4>
                        @foreach (var part in group)
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-2); padding: var(--space-2) var(--space-3); background-color: var(--muted); border-radius: var(--radius);">
                                <div style="display: flex; align-items: center; gap: var(--space-2);">
                                    <BbBadge Variant="BadgeVariant.Secondary">@part.Brand</BbBadge>
                                    <span style="color: var(--foreground); font-size: var(--text-sm);">@part.Name</span>
                                </div>
                                <span style="font-weight: var(--font-semibold); color: var(--foreground); font-size: var(--text-sm);">
                                    @part.Price.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div style="padding: var(--card-padding); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <span style="font-size: var(--text-sm); color: var(--muted-foreground);">Grand Total</span>
                    <div style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground);">
                        @CurrentParts.Sum(p => p.Price).ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))
                    </div>
                </div>
                <BbButton Variant="ButtonVariant.Outline" OnClick="CloseModal">Close</BbButton>
            </div>

        </div>
    </div>
}

@code {
    private List<BuildRequest>? allBuilds;
    private string activeTab = "Active";

    private IEnumerable<BuildRequest> ActiveBuilds =>
        allBuilds?.Where(b => b.Status == "Pending" || b.Status == "Confirmed").OrderByDescending(b => b.CreatedAt) ?? Enumerable.Empty<BuildRequest>();

    private IEnumerable<BuildRequest> HistoryBuilds =>
        allBuilds?.Where(b => b.Status == "Completed" || b.Status == "Cancelled").OrderByDescending(b => b.CreatedAt) ?? Enumerable.Empty<BuildRequest>();

    private IEnumerable<BuildRequest> DisplayBuilds => activeTab == "Active" ? ActiveBuilds : HistoryBuilds;

    private bool ShowModal = false;
    private BuildRequest? CurrentBuild;
    private List<Product> CurrentParts = new List<Product>();

    protected override async Task OnInitializedAsync() => await LoadBuilds();

    private async Task LoadBuilds() => allBuilds = await Http.GetFromJsonAsync<List<BuildRequest>>("api/builds/all");

    private async Task UpdateStatus(BuildRequest build, string newStatus)
    {
        await Http.PutAsJsonAsync($"api/builds/{build.Id}/status", newStatus);
        build.Status = newStatus;
    }

    private List<Product> ParseParts(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new List<Product>();
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<List<Product>>(json, options) ?? new List<Product>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error parsing JSON: {ex.Message}");
            return new List<Product>();
        }
    }

    private void OpenModal(BuildRequest build, List<Product> parts)
    {
        CurrentBuild = build;
        CurrentParts = parts;
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    private string GetStatusBorderColor(string status) => status?.ToLower() switch
    {
        "pending" => "var(--warning)",
        "confirmed" => "var(--color-blue-accent)",
        "completed" => "var(--success)",
        "cancelled" => "var(--destructive)",
        _ => "var(--border)"
    };
}