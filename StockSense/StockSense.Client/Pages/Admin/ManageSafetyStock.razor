@page "/admin/safety-stock"
@layout AdminLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Inventory Targets</PageTitle>

<div style="animation: fadeIn 0.4s ease-in;">

    @* --- TOP HEADER --- *@
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-6); flex-wrap: wrap; gap: var(--space-3);">
        <div>
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Safety Stock</h1>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Adjust thresholds to trigger low-stock alerts and automate procurement.</p>
        </div>

        @if (products != null)
        {
            <div style="display: flex; gap: var(--space-4); flex-wrap: wrap;">
                <div style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-3) var(--space-5); text-align: center; min-width: 120px;">
                    <span style="display: block; font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em;">At Risk</span>
                    <span style="font-size: var(--text-2xl); font-weight: 800; color: var(--destructive);">@products.Count(p => p.CurrentStock <= p.ReorderTarget)</span>
                </div>
                <div style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-3) var(--space-5); text-align: center; min-width: 120px;">
                    <span style="display: block; font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em;">Healthy</span>
                    <span style="font-size: var(--text-2xl); font-weight: 800; color: #10b981;">@products.Count(p => p.CurrentStock > p.ReorderTarget)</span>
                </div>
            </div>
        }
    </div>

    @* --- Search and Filter Bar --- *@
    <div style="display: flex; gap: var(--space-3); margin-bottom: var(--space-6); align-items: center; flex-wrap: wrap;">
        @* Search Input *@
        <div style="position: relative; flex: 2; min-width: 250px;">
            <div style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted-foreground);">
                <LucideIcon Name="search" Size="18" />
            </div>
            <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Search product name or brand..." style="width: 100%; padding: 10px 10px 10px 40px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--card); color: var(--foreground); outline: none;" />
        </div>

        @* Category Filter *@
        <select @bind="categoryFilter" style="flex: 1; padding: 10px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--card); color: var(--foreground); outline: none; min-width: 140px;">
            <option value="All">All Categories</option>
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <option value="@cat">@cat</option>
                }
            }
        </select>

        @* Status Filter *@
        <select @bind="statusFilter" style="flex: 1; padding: 10px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--card); color: var(--foreground); outline: none; min-width: 140px;">
            <option value="All">All Statuses</option>
            <option value="AtRisk">At Risk</option>
            <option value="Healthy">Healthy</option>
        </select>
    </div>

    @if (products == null)
    {
        <div style="display: grid; place-items: center; min-height: 40vh;">
            <div style="text-align: center;">
                <BbSpinner Size="SpinnerSize.Large" />
                <p style="margin-top: var(--space-4); color: var(--muted-foreground);">Analyzing inventory levels...</p>
            </div>
        </div>
    }
    else
    {
        @* --- Product Table --- *@
        <div style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: var(--space-6); overflow: hidden;">
            <div style="width: 100%; overflow-x: auto;">
                <table style="width: 100%; min-width: 650px; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--muted); border-bottom: 1px solid var(--border);">
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); font-weight: var(--font-medium); color: var(--muted-foreground); font-size: var(--text-sm);">Product Details</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); font-weight: var(--font-medium); color: var(--muted-foreground); font-size: var(--text-sm);">Stock Status</th>
                            <th style="text-align: center; padding: var(--space-3) var(--space-4); font-weight: var(--font-medium); color: var(--muted-foreground); font-size: var(--text-sm);">Safety Threshold</th>
                            <th style="text-align: right; padding: var(--space-3) var(--space-4);"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in FilteredProducts)
                        {
                            var isLow = p.CurrentStock <= p.ReorderTarget;
                            var stockPercentage = p.ReorderTarget == 0 ? 100 : (Math.Min((double)p.CurrentStock / p.ReorderTarget, 1.0) * 100);

                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <div style="font-weight: var(--font-medium); color: var(--foreground); font-size: var(--text-sm);">@p.Name</div>
                                    <div style="display: flex; gap: 8px; align-items: center; margin-top: 4px;">
                                        <span style="font-size: var(--text-xs); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.025em;">@p.Brand</span>
                                        <span style="height: 4px; width: 4px; background: var(--border); border-radius: 50%;"></span>
                                        <span style="font-size: var(--text-xs); color: var(--primary); font-weight: 600;">@p.Category</span>
                                    </div>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4); width: 280px;">
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: var(--text-sm);">
                                        <span style="font-weight: 600; color: @(isLow ? "var(--destructive)" : "var(--foreground)")">
                                            @p.CurrentStock units
                                        </span>
                                        <span style="color: var(--muted-foreground);">Target: @p.ReorderTarget</span>
                                    </div>
                                    <div style="height: 8px; width: 100%; background: var(--muted); border-radius: 10px; overflow: hidden;">
                                        <div style="height: 100%; width: @stockPercentage%; background: @(isLow ? "var(--destructive)" : "#10b981"); transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);"></div>
                                    </div>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                    <span style="background: var(--background); padding: 6px 12px; border-radius: 8px; border: 1px solid var(--border); font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: var(--text-sm);">
                                        @p.ReorderTarget
                                    </span>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4); text-align: right;">
                                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="() => OpenEditModal(p)">
                                        <LucideIcon Name="sliders-horizontal" Size="16" style="margin-right: 8px;" /> Adjust
                                    </BbButton>
                                </td>
                            </tr>
                        }
                        @if (!FilteredProducts.Any())
                        {
                            <tr>
                                <td colspan="4" style="padding: var(--space-10); text-align: center; color: var(--muted-foreground);">
                                    No products found matching your filters.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* --- Edit Modal --- *@
@if (showModal && selectedProduct != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(6px); display: flex; justify-content: center; align-items: center; z-index: 1000; animation: modalAppear 0.25s ease-out; padding: 20px;">
        <div style="background: var(--card); width: 100%; max-width: 440px; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); padding: var(--space-8); position: relative;">

            <div style="text-align: center; margin-bottom: var(--space-8);">
                <div style="width: 56px; height: 56px; background: rgba(var(--primary-rgb), 0.1); color: var(--primary); border-radius: 16px; display: grid; place-items: center; margin: 0 auto var(--space-4) auto;">
                    <LucideIcon Name="package-search" Size="28" />
                </div>
                <h3 style="margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--foreground);">Edit Target</h3>
                <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin-top: 6px;">@selectedProduct.Name — @selectedProduct.Brand</p>
            </div>

            <div style="margin-bottom: var(--space-8);">
                <label style="display: block; font-size: var(--text-xs); font-weight: 800; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 10px; letter-spacing: 0.05em;">Minimum Safety Level</label>
                <input type="number" @bind="tempSafetyStock"
                       style="width: 100%; padding: 16px; border-radius: 12px; border: 2px solid var(--border); background: var(--background); font-size: 1.25rem; font-weight: 700; text-align: center; color: var(--foreground); outline: none;"
                       onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 4px rgba(var(--primary-rgb), 0.15)';"
                       onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none';" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3);">
                <BbButton Variant="ButtonVariant.Ghost" OnClick="CloseModal" style="height: 48px; font-weight: 600;">Cancel</BbButton>
                <BbButton Variant="ButtonVariant.Default" OnClick="SaveSafetyStock" Disabled="isSaving" style="height: 48px; font-weight: 600;">
                    @if (isSaving)
                    {
                        <BbSpinner Size="SpinnerSize.Small" />
                    }
                    else
                    {
                        <span>Save Changes</span>
                    }
                </BbButton>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes modalAppear {
        from {
            opacity: 0;
            transform: translateY(20px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
</style>

@code {
    private List<Product>? products;
    private List<string>? categories;
    private Product? selectedProduct;
    private int tempSafetyStock;
    private bool showModal = false;
    private bool isSaving = false;

    // Search and Filter State
    private string searchQuery = "";
    private string statusFilter = "All";
    private string categoryFilter = "All";

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        try
        {
            products = await Http.GetFromJsonAsync<List<Product>>("api/products");
            if (products != null)
            {
                // Extract unique categories for the dropdown
                categories = products
                    .Where(p => !string.IsNullOrEmpty(p.Category))
                    .Select(p => p.Category)
                    .Distinct()
                    .OrderBy(c => c)
                    .ToList();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Fetch error: {ex.Message}"); }
    }

    // Combined Filter Logic
    private IEnumerable<Product> FilteredProducts => products?
        .Where(p => string.IsNullOrWhiteSpace(searchQuery) ||
                    p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Brand.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(p => categoryFilter == "All" || p.Category == categoryFilter)
        .Where(p => statusFilter == "All" ||
                   (statusFilter == "AtRisk" && p.CurrentStock <= p.ReorderTarget) ||
                   (statusFilter == "Healthy" && p.CurrentStock > p.ReorderTarget))
        ?? Enumerable.Empty<Product>();

    private void OpenEditModal(Product p)
    {
        selectedProduct = p;
        tempSafetyStock = p.ReorderTarget;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedProduct = null;
    }

    private async Task SaveSafetyStock()
    {
        if (selectedProduct == null) return;
        isSaving = true;
        try
        {
            selectedProduct.ReorderTarget = tempSafetyStock;
            var response = await Http.PutAsJsonAsync($"api/products/{selectedProduct.Id}", selectedProduct);

            if (response.IsSuccessStatusCode)
            {
                showModal = false;
                selectedProduct = null;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Failed to save: {response.StatusCode} - {error}");
            }
        }
        catch (Exception ex) { Console.WriteLine($"Save error: {ex.Message}"); }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}
