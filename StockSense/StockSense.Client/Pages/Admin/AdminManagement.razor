@page "/admin/management"
@layout AdminLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.shared
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

@attribute [Authorize(Roles = "Admin")]

<PageTitle>System Management</PageTitle>

<div>
    <div style="display: flex; align-items: start; margin-bottom: var(--space-6); flex-direction: column;">
        <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">System Management</h1>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Manage users, employee roles, and shop mechanics.</p>
    </div>

    @* --- TABS & FILTERS --- *@
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-4); gap: var(--space-4);">
        <div style="display: flex; gap: var(--space-2);">
            <button @onclick='() => currentTab = "Users"'
                    style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(currentTab == "Users" ? "var(--secondary)" : "transparent"); color: @(currentTab == "Users" ? "var(--foreground)" : "var(--muted-foreground)");">
                Users & Employees
            </button>
            <button @onclick='() => currentTab = "Mechanics"'
                    style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(currentTab == "Mechanics" ? "var(--secondary)" : "transparent"); color: @(currentTab == "Mechanics" ? "var(--foreground)" : "var(--muted-foreground)");">
                Shop Mechanics
            </button>
        </div>

        @if (currentTab == "Users")
        {
            <div style="display: flex; align-items: center; gap: var(--space-3);">
                <label style="font-size: var(--text-sm); color: var(--muted-foreground);">Role Filter:</label>
                <select @bind="roleFilter" style="padding: 6px 12px; background: var(--background); color: var(--foreground); border: 1px solid var(--border); border-radius: var(--radius); font-size: var(--text-sm);">
                    <option value="All">All Roles</option>
                    <option value="Admin">Admins</option>
                    <option value="Employee">Employees</option>
                    <option value="Customer">Customers</option>
                </select>
            </div>
        }
    </div>

    <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-4);">

        @if (currentTab == "Users")
        {
            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--space-4);">
                <button @onclick="OpenEmployeeModal" style="padding: 8px 16px; background-color: var(--primary); color: white; border: none; border-radius: var(--radius); font-weight: bold; cursor: pointer;">
                    + Add New Employee
                </button>
            </div>

            @if (users == null)
            {
                <div style="color: var(--muted-foreground); text-align: center; padding: 20px;">Loading users...</div>
            }
            else
            {
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); text-align: left;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border); color: var(--muted-foreground);">
                            <th style="padding: 12px;">Name & Email</th>
                            <th style="padding: 12px;">Role</th>
                            <th style="padding: 12px;">Status</th>
                            <th style="padding: 12px; text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in FilteredUsers)
                        {
                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: 12px;">
                                    <div style="font-weight: bold; color: var(--foreground);">@user.FullName</div>
                                    <div style="color: var(--muted-foreground); font-size: 0.8rem;">@user.Email</div>
                                </td>
                                <td style="padding: 12px;">
                                    <select @onchange="@(e => ChangeUserRole(user, e.Value?.ToString()))"
                                            style="padding: 6px; background: var(--background); color: var(--foreground); border: 1px solid var(--border); border-radius: 4px;">
                                        <option value="Customer" selected="@(user.Role == "Customer")">Customer</option>
                                        <option value="Employee" selected="@(user.Role == "Employee")">Employee</option>
                                        <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                                    </select>
                                </td>
                                <td style="padding: 12px;">
                                    <button @onclick="() => ToggleBlockUser(user)"
                                            style="padding: 4px 8px; border: 1px solid var(--border); background: transparent; color: @(user.IsBlocked ? "var(--destructive)" : "#4CAF50"); border-radius: 4px; cursor: pointer; font-size: 0.7rem; font-weight: bold; text-transform: uppercase;">
                                        @(user.IsBlocked ? "Blocked" : "Active")
                                    </button>
                                </td>
                                <td style="padding: 12px; text-align: right;">
                                    <button @onclick="() => ConfirmDelete(user, user.FullName)" style="padding: 6px 12px; background: rgba(244, 67, 54, 0.1); color: #f44336; border: 1px solid #f44336; border-radius: 4px; cursor: pointer;">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else if (currentTab == "Mechanics")
        {
            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--space-4);">
                <button @onclick="OpenMechanicModal" style="padding: 8px 16px; background-color: var(--primary); color: white; border: none; border-radius: var(--radius); font-weight: bold; cursor: pointer;">
                    + Add Mechanic
                </button>
            </div>

            @if (mechanics == null)
            {
                <div style="color: var(--muted-foreground); text-align: center; padding: 20px;">Loading mechanics...</div>
            }
            else
            {
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); text-align: left;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border); color: var(--muted-foreground);">
                            <th style="padding: 12px;">Mechanic Name</th>
                            <th style="padding: 12px;">Status</th>
                            <th style="padding: 12px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mech in mechanics)
                        {
                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: 12px; font-weight: bold; color: var(--foreground);">@mech.Name</td>
                                <td style="padding: 12px;">
                                    <button @onclick="() => ToggleMechanic(mech)" style="padding: 4px 8px; border: 1px solid var(--border); background: var(--background); color: @(mech.IsActive ? "#4CAF50" : "var(--muted-foreground)"); border-radius: 4px; cursor: pointer; font-size: 0.7rem; font-weight: bold;">
                                        @(mech.IsActive ? "ACTIVE" : "INACTIVE")
                                    </button>
                                </td>
                                <td style="padding: 12px; text-align: right;">
                                    <button @onclick="() => ConfirmDelete(mech, mech.Name)" style="padding: 6px 12px; background: rgba(244, 67, 54, 0.1); color: #f44336; border: 1px solid #f44336; border-radius: 4px; cursor: pointer;">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>
</div>

@* --- DELETE CONFIRMATION MODAL --- *@
@if (pendingDeleteTarget != null)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); display: flex; justify-content: center; align-items: center; z-index: 2000;">
        <div style="background: var(--card); width: 380px; padding: 24px; border-radius: 12px; border: 1px solid var(--border); text-align: center; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);">
            <h3 style="color: var(--foreground); margin: 0 0 8px 0;">Are you sure?</h3>
            <p style="color: var(--muted-foreground); font-size: 0.9rem; line-height: 1.5;">
                You are about to delete <strong>@pendingDeleteName</strong>. This action is permanent and cannot be reversed.
            </p>

            <div style="display: flex; gap: 12px; margin-top: 24px;">
                <button @onclick="ExecuteDelete" style="flex: 1; padding: 12px; background: #f44336; color: white; border: none; border-radius: var(--radius); font-weight: bold; cursor: pointer;">Delete Now</button>
                <button @onclick="() => pendingDeleteTarget = null" style="flex: 1; padding: 12px; background: var(--secondary); color: var(--foreground); border: none; border-radius: var(--radius); font-weight: bold; cursor: pointer;">Cancel</button>
            </div>
        </div>
    </div>
}

@* --- ADD EMPLOYEE MODAL --- *@
@if (showEmployeeModal)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; justify-content: center; align-items: center; z-index: 1000;">
        <div style="background: var(--card); width: 450px; padding: 24px; border-radius: 12px; border: 1px solid var(--border);">
            <h2 style="margin-top: 0; color: var(--foreground);">Add New Staff</h2>
            <div style="display: flex; flex-direction: column; gap: 15px;">
                <input @bind="newEmp.FirstName" placeholder="First Name" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                <input @bind="newEmp.LastName" placeholder="Last Name" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                <input @bind="newEmp.Email" placeholder="Email Address" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                <input @bind="newEmp.Password" type="password" placeholder="Temporary Password" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                <select @bind="newEmp.Role" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);">
                    <option value="Employee">Employee</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            @if (!string.IsNullOrEmpty(modalError))
            {
                <p style="color: var(--destructive); margin-top: 10px;">@modalError</p>
            }
            <div style="display: flex; gap: 10px; margin-top: 20px;">
                <button @onclick="CreateEmployee" style="flex: 1; padding: 10px; background: var(--primary); color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">Create Account</button>
                <button @onclick="() => showEmployeeModal = false" style="flex: 1; padding: 10px; background: var(--secondary); color: var(--foreground); border: none; border-radius: 6px; cursor: pointer;">Cancel</button>
            </div>
        </div>
    </div>
}

@* --- ADD MECHANIC MODAL --- *@
@if (showMechanicModal)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; justify-content: center; align-items: center; z-index: 1000;">
        <div style="background: var(--card); width: 400px; padding: 24px; border-radius: 12px; border: 1px solid var(--border);">
            <h2 style="margin-top: 0; color: var(--foreground);">New Shop Mechanic</h2>
            <input @bind="newMechanicName" placeholder="Enter Full Name" style="width: 100%; padding: 10px; margin-bottom: 20px; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
            <div style="display: flex; gap: 10px;">
                <button @onclick="CreateMechanic" style="flex: 1; padding: 10px; background: var(--primary); color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">Save Mechanic</button>
                <button @onclick="() => showMechanicModal = false" style="flex: 1; padding: 10px; background: var(--secondary); color: var(--foreground); border: none; border-radius: 6px; cursor: pointer;">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private string currentTab = "Users";
    private string roleFilter = "All";

    private List<UserDto>? users;
    private List<Mechanic>? mechanics;

    private object? pendingDeleteTarget;
    private string pendingDeleteName = "";

    private IEnumerable<UserDto> FilteredUsers => users?
        .Where(u => roleFilter == "All" || u.Role.Equals(roleFilter, StringComparison.OrdinalIgnoreCase)) ?? Enumerable.Empty<UserDto>();

    private bool showEmployeeModal = false;
    private bool showMechanicModal = false;
    private string modalError = "";
    private CreateEmployeeDto newEmp = new();
    private string newMechanicName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
        await LoadMechanics();
    }

    private async Task LoadUsers() => users = await Http.GetFromJsonAsync<List<UserDto>>("api/admin/users");
    private async Task LoadMechanics() => mechanics = await Http.GetFromJsonAsync<List<Mechanic>>("api/mechanics/all");

    private void ConfirmDelete(object target, string name)
    {
        pendingDeleteTarget = target;
        pendingDeleteName = name;
    }

    private async Task ExecuteDelete()
    {
        if (pendingDeleteTarget is UserDto user)
        {
            var res = await Http.DeleteAsync($"api/admin/users/{user.Id}");
            if (res.IsSuccessStatusCode) await LoadUsers();
        }
        else if (pendingDeleteTarget is Mechanic mech)
        {
            var res = await Http.DeleteAsync($"api/mechanics/{mech.Id}");
            if (res.IsSuccessStatusCode) await LoadMechanics();
        }
        pendingDeleteTarget = null;
    }

    private async Task ChangeUserRole(UserDto user, string? newRole)
    {
        if (string.IsNullOrEmpty(newRole)) return;
        await Http.PostAsJsonAsync($"api/admin/change-role", new { UserId = user.Id, NewRole = newRole });
        user.Role = newRole;
    }

    private async Task ToggleBlockUser(UserDto user)
    {
        var response = await Http.PostAsync($"api/admin/toggle-block/{user.Id}", null);
        if (response.IsSuccessStatusCode) user.IsBlocked = !user.IsBlocked;
    }

    private void OpenEmployeeModal() { newEmp = new() { Role = "Employee" }; modalError = ""; showEmployeeModal = true; }

    private async Task CreateEmployee()
    {
        modalError = "";
        var response = await Http.PostAsJsonAsync("api/admin/create-employee", newEmp);
        if (response.IsSuccessStatusCode) { showEmployeeModal = false; await LoadUsers(); }
        else { modalError = await response.Content.ReadAsStringAsync(); }
    }

    private void OpenMechanicModal() { newMechanicName = ""; showMechanicModal = true; }

    private async Task CreateMechanic()
    {
        if (string.IsNullOrWhiteSpace(newMechanicName)) return;
        await Http.PostAsJsonAsync("api/mechanics", new Mechanic { Name = newMechanicName, IsActive = true });
        showMechanicModal = false;
        await LoadMechanics();
    }

    private async Task ToggleMechanic(Mechanic mech)
    {
        mech.IsActive = !mech.IsActive;
        await Http.PutAsJsonAsync($"api/mechanics/{mech.Id}", mech);
    }
}