@page "/admin/appointments"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

@attribute [Authorize(Roles = "Admin")]

<PageTitle>Manage Appointments</PageTitle>

<div>
    <div style="display: flex; align-items: start; margin-bottom: var(--space-6); flex-wrap: wrap; flex-direction: column;">
        <div style="display: flex; align-items: center; gap: var(--space-2); flex: 1; flex-direction: row;">
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Manage Appointments</h1>
            <BbBadge Variant="BadgeVariant.Destructive">
                @ActiveAppointments.Count(a => a.Status == "Pending") Pending
            </BbBadge>
        </div>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Review and manage customer appointment requests.</p>
    </div>

    @if (allAppointments == null)
    {
        <div style="display: flex; justify-content: center; align-items: center; padding: var(--space-8); color: var(--muted-foreground); gap: var(--space-3);">
            <BbSpinner Size="SpinnerSize.Small" />
            <span>Loading appointment requests...</span>
        </div>
    }
    else
    {
        @* Tabs *@
        <div style="display: flex; gap: var(--space-2); margin-bottom: var(--space-4);">
            <button @onclick='() => currentTab = "Active"'
                    style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(currentTab == "Active" ? "var(--secondary)" : "transparent"); color: @(currentTab == "Active" ? "var(--foreground)" : "var(--muted-foreground)"); font-family: var(--font-sans);">
                Active (@ActiveAppointments.Count())
            </button>
            <button @onclick='() => currentTab = "History"'
                    style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(currentTab == "History" ? "var(--secondary)" : "transparent"); color: @(currentTab == "History" ? "var(--foreground)" : "var(--muted-foreground)"); font-family: var(--font-sans);">
                History (@HistoryAppointments.Count())
            </button>
        </div>

        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius);">
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); min-width: 600px;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 20%;">Customer</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 25%;">Date & Time</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 25%;">Services</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 15%;">Total Value</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 15%;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!DisplayAppointments.Any())
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; padding: var(--space-8); color: var(--muted-foreground);">
                                    <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-2);">
                                        <LucideIcon Name="calendar-x" Size="32" />
                                        <span>No appointments found in this section.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var appt in DisplayAppointments)
                        {
                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: var(--space-3) var(--space-4); font-weight: var(--font-medium); color: var(--foreground);">@appt.CustomerName</td>
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <div style="color: var(--foreground); font-size: var(--text-sm);">@appt.AppointmentDate.ToShortDateString()</div>
                                    <div style="color: var(--color-blue-accent); font-size: var(--text-xs); font-weight: var(--font-semibold); margin-top: var(--space-1);">@appt.TimeSlot</div>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-size: var(--text-sm);">@appt.ServicesRequested</td>
                                <td style="padding: var(--space-3) var(--space-4); font-weight: var(--font-semibold); color: var(--foreground);">
                                    ₱@appt.TotalAmount.ToString("N2")
                                </td>
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <select value="@appt.Status"
                                            @onchange="@((ChangeEventArgs e) => UpdateStatus(appt, e.Value?.ToString() ?? "Pending"))"
                                            style="padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--border); border-left: 3px solid @GetStatusBorderColor(appt.Status); background-color: var(--background); color: var(--foreground); font-size: var(--text-sm); cursor: pointer; font-family: var(--font-sans);">
                                        <option value="Pending">Pending</option>
                                        <option value="Confirmed">Confirmed</option>
                                        <option value="Completed">Completed</option>
                                        <option value="Cancelled">Cancelled</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<Appointment>? allAppointments;
    private string currentTab = "Active";

    private IEnumerable<Appointment> ActiveAppointments =>
        allAppointments?.Where(a => a.Status == "Pending" || a.Status == "Confirmed").OrderBy(a => a.AppointmentDate) ?? Enumerable.Empty<Appointment>();

    private IEnumerable<Appointment> HistoryAppointments =>
        allAppointments?.Where(a => a.Status == "Completed" || a.Status == "Cancelled").OrderByDescending(a => a.AppointmentDate) ?? Enumerable.Empty<Appointment>();

    private IEnumerable<Appointment> DisplayAppointments => currentTab == "Active" ? ActiveAppointments : HistoryAppointments;

    protected override async Task OnInitializedAsync() => await LoadAppointments();

    private async Task LoadAppointments()
    {
        try
        {
            allAppointments = await Http.GetFromJsonAsync<List<Appointment>>("api/appointments/all");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load appointments: {ex.Message}");
        }
    }

    private async Task UpdateStatus(Appointment appt, string newStatus)
    {
        try
        {
            var response = await Http.PutAsJsonAsync($"api/appointments/{appt.Id}/status", newStatus);
            if (response.IsSuccessStatusCode)
                appt.Status = newStatus;
            else
                Console.WriteLine("Server failed to update status.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating status: {ex.Message}");
        }
    }

    private string GetStatusBorderColor(string status) => status?.ToLower() switch
    {
        "pending" => "var(--warning)",
        "confirmed" => "var(--color-blue-accent)",
        "completed" => "var(--success)",
        "cancelled" => "var(--destructive)",
        _ => "var(--border)"
    };
}