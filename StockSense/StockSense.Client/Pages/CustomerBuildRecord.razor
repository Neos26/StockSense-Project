@page "/my-builds"
@layout PublicLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.shared
@using StockSense.Shared
@using System.Text.Json
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Nav

@attribute [Authorize]

<PageTitle>My Builds</PageTitle>

<div style="width: 100%; min-width: 350px; max-width: 700px; margin: 0 auto; padding: var(--space-8) var(--space-4);">

    <div style="margin-bottom: var(--space-6);">
        <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">My Builds</h1>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Track the status of your submitted custom builds.</p>
    </div>

    @if (isLoading)
    {
        <div style="display: flex; align-items: center; gap: var(--space-3); color: var(--muted-foreground); padding: var(--space-8); justify-content: center;">
            <span style="font-size: var(--text-sm);">Loading your records...</span>
        </div>
    }
    else if (myBuilds == null || !myBuilds.Any())
    {
        <div style="text-align: center; padding: var(--space-8); background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); display: flex; flex-direction: column; align-items: center; gap: var(--space-4);">
            <div>
                <p style="font-size: var(--text-base); font-weight: var(--font-medium); color: var(--foreground); margin: 0 0 var(--space-1) 0;">No builds yet</p>
                <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">You haven't submitted any builds yet.</p>
            </div>
            <button @onclick='() => Nav.NavigateTo("/build")' style="padding: 10px 20px; background: var(--primary); color: white; border: none; border-radius: var(--radius); cursor: pointer;">Start a New Build</button>
        </div>
    }
    else
    {
        @* --- ARCHIVE TOGGLE --- *@
        <div style="display: flex; justify-content: flex-end; margin-bottom: var(--space-3); align-items: center; gap: 8px;">
            <input type="checkbox" @bind="showAllHistory" id="userBuildArchive" />
            <label for="userBuildArchive" style="font-size: var(--text-xs); color: var(--muted-foreground); cursor: pointer;">Show full history</label>
        </div>

        <div style="display: flex; flex-direction: column; gap: var(--space-3);">
            @foreach (var build in FilteredBuilds)
            {
                var parts = ParseParts(build.SelectedPartsJson);
                <div style="background-color: var(--card); border: 1px solid var(--border); border-left: 4px solid @GetStatusColor(build.Status); border-radius: var(--radius); padding: var(--space-4) var(--space-5); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.01)'" onmouseout="this.style.transform='scale(1)'">

                    @* HEADER *@
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-3); flex-wrap: wrap; gap: var(--space-2);">
                        <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground);">
                            Build #@build.Id - @parts.Count items
                        </span>
                        <span style="padding: 2px 10px; border-radius: 9999px; font-size: 0.7rem; font-weight: bold; text-transform: uppercase; background: rgba(255,255,255,0.05); color: @GetStatusColor(build.Status); border: 1px solid @GetStatusColor(build.Status);">
                            @build.Status
                        </span>
                    </div>

                    @* BODY *@
                    <div style="display: flex; flex-direction: column; gap: 6px;">
                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">
                            <span style="font-weight: bold; color: var(--foreground);">Parts:</span>
                            @parts.Count parts selected
                        </p>

                        @if (parts.Any())
                        {
                            var categories = parts.Select(p => p.Category).Distinct().Take(3);
                            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">
                                <span style="font-weight: bold; color: var(--foreground);">Categories:</span>
                                @string.Join(", ", categories)@(parts.Select(p => p.Category).Distinct().Count() > 3 ? "..." : "")
                            </p>
                        }

                        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 8px; border-top: 1px solid var(--border); margin-top: 4px;">
                            <span style="font-size: var(--text-xs); color: var(--muted-foreground);">@build.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</span>
                            <span style="font-size: var(--text-sm); font-weight: bold; color: var(--primary);">₱@parts.Sum(p => p.Price).ToString("N2")</span>
                        </div>

                        <div style="display: flex; justify-content: flex-end; margin-top: var(--space-2);">
                            <button @onclick="() => OpenModal(build, parts)" style="background: var(--primary); border: none; color: white; padding: 8px 16px; border-radius: var(--radius); cursor: pointer; font-size: var(--text-xs); font-weight: var(--font-medium);">
                                VIEW DETAILS
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* --- MODAL REMAINS THE SAME BUT CLEANER --- *@
@if (ShowModal && CurrentParts != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.8); display: flex; justify-content: center; align-items: center; z-index: 1000; padding: 20px;">
        <div style="background: var(--card); width: 600px; max-height: 85vh; border-radius: 12px; border: 1px solid var(--border); display: flex; flex-direction: column;">
            <div style="padding: 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between;">
                <h3 style="margin: 0; color: var(--foreground);">Build Summary</h3>
                <button @onclick="CloseModal" style="background: none; border: none; color: var(--muted-foreground); cursor: pointer; font-size: 1.5rem;">&times;</button>
            </div>
            <div style="padding: 20px; overflow-y: auto; flex: 1;">
                @foreach (var group in CurrentParts.GroupBy(p => p.Category))
                {
                    <div style="margin-bottom: 15px;">
                        <h4 style="font-size: 0.7rem; color: var(--primary); text-transform: uppercase; margin-bottom: 8px;">@group.Key</h4>
                        @foreach (var part in group)
                        {
                            <div style="display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <span style="font-size: 0.85rem; color: var(--foreground);">@part.Brand @part.Name</span>
                                <span style="font-weight: bold;">₱@part.Price.ToString("N2")</span>
                            </div>
                        }
                    </div>
                }
            </div>
            <div style="padding: 20px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                <span style="font-weight: bold; font-size: 1.1rem;">Total: ₱@CurrentParts.Sum(p => p.Price).ToString("N2")</span>
                <button @onclick="CloseModal" style="padding: 8px 20px; background: var(--secondary); color: var(--foreground); border: none; border-radius: 6px; cursor: pointer;">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private List<BuildRequest>? myBuilds;
    private bool isLoading = true;
    private bool showAllHistory = false;

    private bool ShowModal = false;
    private BuildRequest? CurrentBuild;
    private List<Product> CurrentParts = new();

    // --- FILTER LOGIC ---
    private IEnumerable<BuildRequest> FilteredBuilds
    {
        get
        {
            if (myBuilds == null) return Enumerable.Empty<BuildRequest>();

            // 1. Always show Pending and Confirmed
            var active = myBuilds.Where(b => b.Status == "Pending" || b.Status == "Confirmed");

            // 2. Filter history based on 30-day rule
            var history = myBuilds.Where(b => b.Status == "Completed" || b.Status == "Cancelled");

            if (!showAllHistory)
            {
                var limitDate = DateTime.Now.AddDays(-30);
                history = history.Where(b => b.CreatedAt >= limitDate);
            }

            return active.Concat(history).OrderByDescending(b => b.CreatedAt);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                string userName = user.Identity.Name ?? "User";

                try
                {
                    myBuilds = await Http.GetFromJsonAsync<List<BuildRequest>>($"api/builds/customer/{userName}");
                }
                catch
                {
                    myBuilds = new();
                }
            }
        }
        isLoading = false;
    }

    private List<Product> ParseParts(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new();
        try
        {
            return JsonSerializer.Deserialize<List<Product>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch
        {
            return new();
        }
    }

    private void OpenModal(BuildRequest build, List<Product> parts)
    {
        CurrentBuild = build;
        CurrentParts = parts;
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    private string GetStatusColor(string status) => status switch
    {
        "Pending" => "#f59e0b",
        "Confirmed" => "#3b82f6",
        "Completed" => "#10b981",
        "Cancelled" => "#ef4444",
        _ => "#888888"
    };
}