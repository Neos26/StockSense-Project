@page "/my-builds"
@layout PublicLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Text.Json
@using System.Globalization
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager Nav

@attribute [Authorize]

<PageTitle>My Builds</PageTitle>

<div style="max-width: 900px; margin: 0 auto; padding: var(--space-8) var(--space-4);">

    <div style="margin-bottom: var(--space-6);">
        <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">My Builds</h1>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Track the status of your submitted custom builds.</p>
    </div>

    @if (isLoading)
    {
        <div style="display: flex; align-items: center; gap: var(--space-3); color: var(--muted-foreground); padding: var(--space-8); justify-content: center;">
            <BbSpinner Size="SpinnerSize.Small" />
            <span style="font-size: var(--text-sm);">Loading your builds...</span>
        </div>
    }
    else if (myBuilds == null || !myBuilds.Any())
    {
        <div style="text-align: center; padding: var(--space-8); background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); display: flex; flex-direction: column; align-items: center; gap: var(--space-4);">
            <LucideIcon Name="wrench" Size="40" />
            <div>
                <p style="font-size: var(--text-base); font-weight: var(--font-medium); color: var(--foreground); margin: 0 0 var(--space-1) 0;">No builds yet</p>
                <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">You haven't submitted any builds yet.</p>
            </div>
            <BbButton Variant="ButtonVariant.Default" OnClick='() => Nav.NavigateTo("/build")'>Start a New Build</BbButton>
        </div>
    }
    else
    {
        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); min-width: 600px;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Date Submitted</th>
                        <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Items</th>
                        <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Total Value</th>
                        <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Status</th>
                        <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var build in myBuilds)
                    {
                        var parts = ParseParts(build.SelectedPartsJson);
                        var totalPrice = parts.Sum(p => p.Price);
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-size: var(--text-xs);">@build.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td>
                            <td style="padding: var(--space-3) var(--space-4);">
                                <BbBadge Variant="BadgeVariant.Secondary">@parts.Count items</BbBadge>
                            </td>
                            <td style="padding: var(--space-3) var(--space-4); font-weight: var(--font-semibold); color: var(--foreground);">@totalPrice.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))</td>
                            <td style="padding: var(--space-3) var(--space-4);">
                                <span style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-semibold); background-color: var(--muted); color: @GetStatusColor(build.Status);">
                                    @build.Status
                                </span>
                            </td>
                            <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="() => OpenModal(build, parts)">
                                    <LucideIcon Name="eye" Size="14" />
                                    View
                                </BbButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (ShowModal && CurrentParts != null)
    {
        <div @onclick="CloseModal" style="position: fixed; inset: 0; background-color: rgba(0,0,0,0.7); display: flex; justify-content: center; align-items: center; z-index: 1000; padding: var(--space-4);">
            <div @onclick:stopPropagation style="background-color: var(--card); width: 600px; max-width: 100%; max-height: 85vh; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: var(--shadow-lg); display: flex; flex-direction: column;">

                <div style="padding: var(--card-padding); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <h3 style="font-size: var(--text-lg); font-weight: var(--font-semibold); color: var(--foreground); margin: 0;">Build Details</h3>
                        <span style="font-size: var(--text-xs); color: var(--muted-foreground); margin-top: var(--space-1); display: block;">Submitted: @CurrentBuild?.CreatedAt.ToString("f")</span>
                    </div>
                    <button @onclick="CloseModal" style="background: none; border: none; cursor: pointer; color: var(--muted-foreground); padding: var(--space-1); border-radius: var(--radius); display: flex; align-items: center; justify-content: center;">
                        <LucideIcon Name="x" Size="18" />
                    </button>
                </div>

                <div style="padding: var(--card-padding); overflow-y: auto; flex: 1;">
                    @foreach (var group in CurrentParts.GroupBy(p => p.Category))
                    {
                        <div style="margin-bottom: var(--space-6);">
                            <h4 style="font-size: var(--text-xs); color: var(--primary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 var(--space-3) 0; padding-bottom: var(--space-2); border-bottom: 1px solid var(--border);">@group.Key</h4>
                            @foreach (var part in group)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-2); padding: var(--space-2) var(--space-3); background-color: var(--muted); border-radius: var(--radius);">
                                    <div style="display: flex; align-items: center; gap: var(--space-2);">
                                        <BbBadge Variant="BadgeVariant.Secondary">@part.Brand</BbBadge>
                                        <span style="color: var(--foreground); font-size: var(--text-sm);">@part.Name</span>
                                    </div>
                                    <span style="font-weight: var(--font-semibold); color: var(--foreground); font-size: var(--text-sm);">@part.Price.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div style="padding: var(--card-padding); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <span style="font-size: var(--text-sm); color: var(--muted-foreground);">Grand Total</span>
                        <div style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground);">@CurrentParts.Sum(p => p.Price).ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))</div>
                    </div>
                    <BbButton Variant="ButtonVariant.Outline" OnClick="CloseModal">Close</BbButton>
                </div>

            </div>
        </div>
    }

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private List<BuildRequest>? myBuilds;
    private bool isLoading = true;

    // Modal State
    private bool ShowModal = false;
    private BuildRequest? CurrentBuild;
    private List<Product> CurrentParts = new List<Product>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask!;
        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            Nav.NavigateTo($"/Account/Login?returnUrl={Uri.EscapeDataString(Nav.Uri)}", true);
            return;
        }

        var userName = authState.User.Identity.Name;

        try
        {
            // Call the new endpoint using the logged-in user's name
            myBuilds = await Http.GetFromJsonAsync<List<BuildRequest>>($"api/builds/customer/{userName}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading builds: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<Product> ParseParts(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new List<Product>();
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<List<Product>>(json, options) ?? new List<Product>();
        }
        catch
        {
            return new List<Product>();
        }
    }

    private void OpenModal(BuildRequest build, List<Product> parts)
    {
        CurrentBuild = build;
        CurrentParts = parts;
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    private string GetStatusColor(string status) => status?.ToLower() switch
    {
        "pending" => "var(--warning)",
        "confirmed" => "var(--color-blue-accent)",
        "completed" => "var(--success)",
        "cancelled" => "var(--destructive)",
        _ => "var(--foreground)"
    };

}