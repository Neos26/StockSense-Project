@page "/my-bookings"
@layout PublicLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

@attribute [Authorize]

<PageTitle>My Appointments</PageTitle>

<div style="max-width: 720px; margin: 0 auto; padding: var(--space-8) var(--space-4);">

    <div style="margin-bottom: var(--space-6);">
        <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">My Appointments</h1>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Your booking history and appointment status.</p>
    </div>

    @if (isLoading)
    {
        <div style="display: flex; align-items: center; gap: var(--space-3); color: var(--muted-foreground); padding: var(--space-8); justify-content: center;">
            <BbSpinner Size="SpinnerSize.Small" />
            <span style="font-size: var(--text-sm);">Loading your records...</span>
        </div>
    }
    else if (myAppointments == null || !myAppointments.Any())
    {
        <div style="text-align: center; padding: var(--space-8); background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); display: flex; flex-direction: column; align-items: center; gap: var(--space-4);">
            <LucideIcon Name="calendar-x" Size="40" />
            <div>
                <p style="font-size: var(--text-base); font-weight: var(--font-medium); color: var(--foreground); margin: 0 0 var(--space-1) 0;">No appointments yet</p>
                <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">You have no booking history yet.</p>
            </div>
            <BbButton Variant="ButtonVariant.Default" Href="/appointment">Book your first appointment</BbButton>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: var(--space-3);">
            @* Sorting by date so the newest appointments show up at the top *@
            @foreach (var appt in myAppointments.OrderByDescending(a => a.AppointmentDate))
            {
                <div style="background-color: var(--card); border: 1px solid var(--border); border-left: 4px solid @GetStatusColor(appt.Status); border-radius: var(--radius); padding: var(--space-4) var(--space-5);">

                    @* HEADER: Date, Time, and Status Badge *@
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-3); flex-wrap: wrap; gap: var(--space-2);">
                        <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground);">
                            @appt.AppointmentDate.ToString("MMM dd, yyyy") at @appt.TimeSlot
                        </span>
                        <span style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-semibold); background-color: var(--muted); color: @GetStatusColor(appt.Status); border: 1px solid @GetStatusColor(appt.Status);">
                            @appt.Status
                        </span>
                    </div>

                    @* BODY: New Data Fields *@
                    <div style="display: flex; flex-direction: column; gap: 6px;">

                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">
                            <span style="font-weight: var(--font-medium); color: var(--foreground);">Mechanic:</span>
                            @(string.IsNullOrEmpty(appt.MechanicName) ? "Unassigned" : appt.MechanicName)
                        </p>

                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">
                            <span style="font-weight: var(--font-medium); color: var(--foreground);">Services:</span> @appt.ServicesRequested
                        </p>

                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">
                            <span style="font-weight: var(--font-medium); color: var(--foreground);">Est. Duration:</span> @appt.DurationMinutes mins
                        </p>

                        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0; padding-top: 4px;">
                            <span style="font-weight: var(--font-medium); color: var(--foreground);">Total:</span>
                            <span style="color: var(--primary); font-weight: var(--font-semibold);">₱@appt.TotalAmount.ToString("N0")</span>
                        </p>

                        @* FOOTER: Date Booked (Uses the CreatedAt property we added earlier) *@
                        <p style="font-size: 0.75rem; color: #555; margin: 8px 0 0 0; font-style: italic; border-top: 1px solid var(--border); padding-top: 8px;">
                            Booked on @appt.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
                        </p>
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private List<Appointment>? myAppointments;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                // 1. Set email as the default fallback
                string customerName = user.Identity.Name ?? "User";

                // 2. Fetch their actual First and Last name
                try
                {
                    var profile = await Http.GetFromJsonAsync<UserProfile>("api/user/profile");
                    if (profile != null)
                    {
                        customerName = $"{profile.FirstName ?? ""} {profile.LastName ?? ""}".Trim();
                    }
                }
                catch { /* Silent fallback */ }

                // 3. Search the database for bookings matching their real name
                try
                {
                    myAppointments = await Http.GetFromJsonAsync<List<Appointment>>($"api/appointments/my-bookings?name={Uri.EscapeDataString(customerName)}");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error fetching bookings: {ex.Message}");
                }
            }
        }
        isLoading = false;
    }

    // A helper function to color-code the badges!
    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Pending" => "#ff9800",   // Orange-Yellow
            "Confirmed" => "#2196F3", // Blue
            "Completed" => "#4CAF50", // Green
            "Cancelled" => "#f44336", // Red
            _ => "#888888"            // Gray default
        };
    }
}