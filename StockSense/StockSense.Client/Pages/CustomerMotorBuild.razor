@page "/build"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout PublicLayout
@using StockSense.Shared
@using StockSense.shared
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager Nav

@attribute [Authorize]

<PageTitle>Build Your Motor</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (isLoading)
        {
            <Spinner Description="syncing with the server..." />
        }

        <div class="build-layout" style="display: @(isLoading ? "none" : "flex"); animation: fadeIn 0.4s ease-in;">

            @* ── Desktop Sidebar ── *@
            <div class="build-sidebar">

                <div style="padding: var(--space-4); border-bottom: 1px solid var(--border); flex-shrink: 0;">
                    <h2 style="font-size: var(--text-lg); font-weight: var(--font-bold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">Build Your Motor</h2>
                    <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0;">Step @currentStep of @TotalSteps — @CurrentStepLabel</p>
                </div>

                @* Step Indicators *@
                <div style="padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; gap: 0;">
                    @for (int i = 1; i <= TotalSteps; i++)
                    {
                        int stepNum = i;
                        bool isActive = currentStep == stepNum;
                        bool isCompleted = currentStep > stepNum;
                        <div style="display: flex; align-items: center;">
                            <div style="width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: var(--text-xs); font-weight: var(--font-bold); transition: all 0.2s; background-color: @(isActive || isCompleted ? "var(--primary)" : "var(--muted)"); color: @(isActive || isCompleted ? "var(--primary-foreground)" : "var(--muted-foreground)"); box-shadow: @(isActive ? "0 0 0 3px color-mix(in oklch, var(--primary) 20%, transparent)" : "none");">
                                @if (isCompleted) { <LucideIcon Name="check" Size="13" /> } else { @stepNum }
                            </div>
                            @if (stepNum < TotalSteps)
                            {
                                <div style="width: 24px; height: 2px; background-color: @(isCompleted ? "var(--primary)" : "var(--border)"); transition: background-color 0.2s;"></div>
                            }
                        </div>
                    }
                </div>

                @* Category Filter (only on final step) *@
                <div style="flex: 1; overflow-y: auto; padding: var(--space-3) var(--space-2);">
                    @if (buildRoute != null && currentStep == TotalSteps)
                    {
                        @foreach (var category in UniqueCategories)
                        {
                            <div style="margin-bottom: var(--space-1);">
                                <button @onclick="() => ToggleCategory(category)" style="width: 100%; display: flex; justify-content: space-between; align-items: center; padding: var(--space-2) var(--space-3); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); background-color: @(expandedCategory == category ? "var(--accent)" : "transparent"); color: var(--foreground); border: none; cursor: pointer; font-family: var(--font-sans);">
                                    <span>@category</span>
                                    <LucideIcon Name="@(expandedCategory == category ? "chevron-up" : "chevron-down")" Size="14" />
                                </button>
                                @if (expandedCategory == category)
                                {
                                    <div style="padding: var(--space-1) var(--space-2) var(--space-2) var(--space-4);">
                                        <button @onclick="() => { selectedBrand = null; }" style="display: block; width: 100%; text-align: left; background: none; border: none; font-size: var(--text-sm); cursor: pointer; padding: var(--space-1) var(--space-2); border-radius: var(--radius); color: @(selectedBrand == null ? "var(--primary)" : "var(--muted-foreground)"); font-family: var(--font-sans);">All Brands</button>
                                        @foreach (var brand in GetBrandsByCategory(category))
                                        {
                                            <button @onclick="() => { selectedBrand = brand; }" style="display: block; width: 100%; text-align: left; background: none; border: none; font-size: var(--text-sm); cursor: pointer; padding: var(--space-1) var(--space-2); border-radius: var(--radius); color: @(selectedBrand == brand ? "var(--foreground)" : "var(--muted-foreground)"); font-family: var(--font-sans);">@brand</button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div style="padding: var(--space-4); text-align: center; color: var(--muted-foreground); font-size: var(--text-sm);">
                            @if (currentStep == 1) { <span>Choose a build path to get started.</span> }
                            else { <span>Follow the steps in the main window.</span> }
                        </div>
                    }
                </div>

                @* Sidebar Footer — build summary + submit actions only, NO back/next *@
                <div style="padding: var(--space-4); border-top: 1px solid var(--border); flex-shrink: 0; background-color: var(--background);">
                    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-2);">
                        <p style="font-size: var(--text-xs); font-weight: var(--font-semibold); color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">Your Build</p>
                        <span style="font-size: var(--text-sm); font-weight: 900; color: var(--primary);">₱@TotalPrice.ToString("N0")</span>
                    </div>
                    <div style="max-height: 120px; overflow-y: auto; margin-bottom: var(--space-3); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-2); background: var(--card);">
                        @if (!selectedParts.Any())
                        {
                            <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0; text-align: center; font-style: italic;">No parts selected yet.</p>
                        }
                        else
                        {
                            @foreach (var part in selectedParts)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                                    <span style="font-size: 10px; color: var(--foreground); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; padding-right: var(--space-2);">@part.Name</span>
                                    <button @onclick="() => TogglePart(part)" style="background: none; border: none; cursor: pointer; color: var(--destructive); padding: 0; display: flex; align-items: center;"><LucideIcon Name="x" Size="10" /></button>
                                </div>
                            }
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div style="margin-bottom: var(--space-3); padding: var(--space-2) var(--space-3); border-radius: var(--radius); background-color: @(isSuccess ? "var(--success-muted)" : "var(--destructive-muted)"); border: 1px solid @(isSuccess ? "var(--success-border)" : "var(--destructive-border)"); color: @(isSuccess ? "var(--success-muted-foreground)" : "var(--destructive-muted-foreground)"); font-size: var(--text-xs);">@statusMessage</div>
                    }
                    <div style="display: flex; flex-direction: column; gap: var(--space-2);">
                        @if (currentStep == TotalSteps)
                        {
                            <BbButton Variant="ButtonVariant.Outline" Class="w-full" OnClick="SendEmailQuote" Disabled="@(isProcessing || !selectedParts.Any())">Send Quote to Email</BbButton>
                            <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="SubmitBuildToAdmin" Disabled="@(isProcessing || !selectedParts.Any())">Submit Build to Shop</BbButton>
                            <div style="margin-top: var(--space-2); padding-top: var(--space-3); border-top: 1px dashed var(--border);">
                                <BbButton Variant="ButtonVariant.Outline" Class="w-full" OnClick='@(() => Nav.NavigateTo("/my-builds", forceLoad: true))'>
                                    <LucideIcon Name="blocks" Size="16" style="margin-right: 6px;" />
                                    View My Builds
                                </BbButton>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* ── Mobile Top Bar ── *@
            <div class="build-mobile-bar">
                <div>
                    <p style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground); margin: 0;">@CurrentStepLabel</p>
                    <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0;">Step @currentStep of @TotalSteps</p>
                </div>
                <div style="display: flex; align-items: center; gap: var(--space-2);">
                    @if (selectedParts.Any())
                    {
                        <span style="font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--primary);">₱@TotalPrice.ToString("N0")</span>
                    }
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="() => mobileDrawerOpen = !mobileDrawerOpen">
                        <LucideIcon Name="@(mobileDrawerOpen ? "x" : "layout-list")" Size="18" />
                    </BbButton>
                </div>
            </div>

            @* ── Mobile Bottom Drawer — summary only, NO back/next ── *@
            @if (mobileDrawerOpen)
            {
                <div class="build-bottom-drawer">
                    <div style="padding: var(--space-4); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                        <p style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground); margin: 0;">Your Build</p>
                        <span style="font-size: var(--text-sm); font-weight: 900; color: var(--primary);">₱@TotalPrice.ToString("N0")</span>
                    </div>

                    @if (buildRoute != null && currentStep == TotalSteps)
                    {
                        <div style="padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border); overflow-x: auto;">
                            <div style="display: flex; gap: var(--space-2); flex-wrap: nowrap;">
                                @foreach (var category in UniqueCategories)
                                {
                                    <button @onclick="() => { ToggleCategory(category); mobileDrawerOpen = false; }" style="white-space: nowrap; padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(expandedCategory == category ? "var(--primary)" : "var(--border)"); background-color: @(expandedCategory == category ? "var(--primary)" : "transparent"); color: @(expandedCategory == category ? "var(--primary-foreground)" : "var(--foreground)"); cursor: pointer; font-family: var(--font-sans);">@category</button>
                                }
                            </div>
                        </div>
                    }

                    <div style="padding: var(--space-3) var(--space-4); max-height: 200px; overflow-y: auto;">
                        @if (!selectedParts.Any())
                        {
                            <p style="font-size: var(--text-xs); color: var(--muted-foreground); text-align: center; font-style: italic; margin: 0;">No parts selected yet.</p>
                        }
                        else
                        {
                            @foreach (var part in selectedParts)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-2);">
                                    <span style="font-size: var(--text-xs); color: var(--foreground);">@part.Name</span>
                                    <button @onclick="() => TogglePart(part)" style="background: none; border: none; cursor: pointer; color: var(--destructive); padding: 0; display: flex;"><LucideIcon Name="x" Size="12"/></button>
                                </div>
                            }
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div style="margin: 0 var(--space-4) var(--space-3); padding: var(--space-2) var(--space-3); border-radius: var(--radius); background-color: @(isSuccess ? "var(--success-muted)" : "var(--destructive-muted)"); border: 1px solid @(isSuccess ? "var(--success-border)" : "var(--destructive-border)"); color: @(isSuccess ? "var(--success-muted-foreground)" : "var(--destructive-muted-foreground)"); font-size: var(--text-xs);">@statusMessage</div>
                    }

                    @if (currentStep == TotalSteps)
                    {
                        <div style="padding: var(--space-4); border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: var(--space-2);">
                            <BbButton Variant="ButtonVariant.Outline" Class="w-full" OnClick="SendEmailQuote" Disabled="@(isProcessing || !selectedParts.Any())">
                                Send Quote to Email
                            </BbButton>

                            <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="SubmitBuildToAdmin" Disabled="@(isProcessing || !selectedParts.Any())">
                                Submit Build to Shop
                            </BbButton>
                            
                            <div style="margin-top: var(--space-2); padding-top: var(--space-3); border-top: 1px dashed var(--border);">
                                <BbButton Variant="ButtonVariant.Outline" Class="w-full" OnClick='@(() => Nav.NavigateTo("/my-builds", forceLoad: true))'>
                                    <LucideIcon Name="blocks" Size="16" style="margin-right: 6px;"/>
                                    View My Builds
                                </BbButton>
                            </div>
                        </div>


                    }
                </div>
            }

            @* ── Main Content ── *@
            <div class="build-main" style="flex: 1; overflow-y: auto; display: flex; flex-direction: column; background-color: var(--background)">

                @* Scrollable step content *@
                <div style="flex: 1; padding: @(currentStep == 1 ? "0" : "var(--space-6)");">

                    @* STEP 1: Choose Route *@
                    @if (currentStep == 1)
                    {
                        <div style="min-height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: var(--space-8) var(--space-4);">
                            <h1 style="font-size: var(--text-3xl); font-weight: 900; color: var(--foreground); margin-bottom: var(--space-2); letter-spacing: -0.02em; text-align: center;">How do you want to build?</h1>
                            <p style="color: var(--muted-foreground); margin-bottom: var(--space-8); font-size: var(--text-base); text-align: center;">Choose a guided pre-built package or start from scratch.</p>
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-6); max-width: 800px; width: 100%;">
                                <div @onclick='() => SelectBuildRoute("Pre-Built")' style="cursor: pointer; background: var(--card); border: 2px solid @(buildRoute == "Pre-Built" ? "var(--primary)" : "var(--border)"); border-radius: var(--radius); padding: var(--space-8); transition: all 0.2s; text-align: center;">
                                    <div style="width: 64px; height: 64px; border-radius: 50%; background-color: color-mix(in oklch, var(--primary) 15%, transparent); color: var(--primary); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4) auto;"><LucideIcon Name="zap" Size="32" /></div>
                                    <h3 style="font-size: var(--text-xl); font-weight: bold; color: var(--foreground); margin-bottom: var(--space-2);">Engine Pre-Builts</h3>
                                    <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Get a complete package tailored to your motor's specs and budget.</p>
                                </div>
                                <div @onclick='() => SelectBuildRoute("Custom")' style="cursor: pointer; background: var(--card); border: 2px solid @(buildRoute == "Custom" ? "var(--primary)" : "var(--border)"); border-radius: var(--radius); padding: var(--space-8); transition: all 0.2s; text-align: center;">
                                    <div style="width: 64px; height: 64px; border-radius: 50%; background-color: color-mix(in oklch, var(--primary) 15%, transparent); color: var(--primary); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4) auto;"><LucideIcon Name="wrench" Size="32" /></div>
                                    <h3 style="font-size: var(--text-xl); font-weight: bold; color: var(--foreground); margin-bottom: var(--space-2);">Custom Build</h3>
                                    <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Hand-pick every single part from our full inventory.</p>
                                </div>
                            </div>
                        </div>
                    }

                    @* STEP 2 (Pre-Built): Motor Specs *@
                    @if (currentStep == 2 && buildRoute == "Pre-Built")
                    {
                        <div style="max-width: 600px; margin: 0 auto; background: var(--card); padding: var(--space-6); border-radius: var(--radius); border: 1px solid var(--border);">
                            <h2 style="font-size: var(--text-2xl); font-weight: bold; margin-bottom: var(--space-6);">Tell us about your motor</h2>
                            <div style="margin-bottom: var(--space-5);">
                                <label style="display: block; font-size: var(--text-sm); font-weight: bold; margin-bottom: var(--space-2);">1. Select Brand</label>
                                <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
                                    @foreach (var brand in motorDatabase.Keys)
                                    {
                                        <button @onclick="() => UpdateBrand(brand)" style="flex: 1; min-width: 80px; padding: 12px; border-radius: var(--radius); border: 1px solid @(specBrand == brand ? "var(--primary)" : "var(--border)"); background: @(specBrand == brand ? "color-mix(in oklch, var(--primary) 10%, transparent)" : "var(--background)"); color: @(specBrand == brand ? "var(--primary)" : "var(--foreground)"); font-weight: bold; cursor: pointer;">@brand</button>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(specBrand))
                            {
                                <div style="margin-bottom: var(--space-5);">
                                    <label style="display: block; font-size: var(--text-sm); font-weight: bold; margin-bottom: var(--space-2);">2. Select Model</label>
                                    <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
                                        @foreach (var model in motorDatabase[specBrand].Keys)
                                        {
                                            <button @onclick="() => UpdateModel(model)" style="padding: 10px 20px; border-radius: var(--radius); border: 1px solid @(specModel == model ? "var(--primary)" : "var(--border)"); background: @(specModel == model ? "color-mix(in oklch, var(--primary) 10%, transparent)" : "var(--background)"); color: @(specModel == model ? "var(--primary)" : "var(--foreground)"); font-weight: bold; cursor: pointer;">@model</button>
                                        }
                                    </div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(specModel))
                            {
                                <div>
                                    <label style="display: block; font-size: var(--text-sm); font-weight: bold; margin-bottom: var(--space-2);">3. Engine CC (Target Upgrade)</label>
                                    <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
                                        @foreach (var cc in motorDatabase[specBrand][specModel])
                                        {
                                            <button @onclick="() => { specCC = cc; }" style="padding: 10px 20px; border-radius: var(--radius); border: 1px solid @(specCC == cc ? "var(--primary)" : "var(--border)"); background: @(specCC == cc ? "color-mix(in oklch, var(--primary) 10%, transparent)" : "var(--background)"); color: @(specCC == cc ? "var(--primary)" : "var(--foreground)"); font-weight: bold; cursor: pointer;">@cc</button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @* STEP 3 (Pre-Built): Budget *@
                    @if (currentStep == 3 && buildRoute == "Pre-Built")
                    {
                        <div style="max-width: 600px; margin: 0 auto; background: var(--card); padding: var(--space-6); border-radius: var(--radius); border: 1px solid var(--border); text-align: center;">
                            <h2 style="font-size: var(--text-2xl); font-weight: bold; margin-bottom: var(--space-2);">What's your budget?</h2>
                            <p style="color: var(--muted-foreground); margin-bottom: var(--space-6);">We'll find the best performance packages in this range.</p>
                            <div style="display: flex; align-items: center; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
                                <div style="text-align: left; width: 100%; max-width: 180px;">
                                    <label style="font-size: var(--text-xs); font-weight: bold; color: var(--muted-foreground); text-transform: uppercase;">Minimum (₱)</label>
                                    <input type="number" @bind="minBudget" style="width: 100%; padding: 12px; font-size: var(--text-lg); font-weight: bold; border-radius: var(--radius); border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                                </div>
                                <div style="text-align: left; width: 100%; max-width: 180px;">
                                    <label style="font-size: var(--text-xs); font-weight: bold; color: var(--muted-foreground); text-transform: uppercase;">Maximum (₱)</label>
                                    <input type="number" @bind="maxBudget" style="width: 100%; padding: 12px; font-size: var(--text-lg); font-weight: bold; border-radius: var(--radius); border: 1px solid var(--border); background: var(--background); color: var(--foreground);" />
                                </div>
                            </div>
                        </div>
                    }

                    @* STEP 4 (Pre-Built): Select Package *@
                    @if (currentStep == 4 && buildRoute == "Pre-Built")
                    {
                        <div style="max-width: 900px; margin: 0 auto;">
                            <h2 style="font-size: var(--text-2xl); font-weight: bold; margin-bottom: var(--space-2);">Recommended Packages</h2>
                            <p style="color: var(--muted-foreground); margin-bottom: var(--space-6);">Based on: @specBrand @specModel (@specCC)</p>
                            @if (!FetchedPackages.Any())
                            {
                                <div style="padding: var(--space-8); background: var(--card); border: 1px dashed var(--border); border-radius: var(--radius); text-align: center;">
                                    <p style="color: var(--muted-foreground);">No pre-built packages found matching these criteria.</p>
                                </div>
                            }
                            else
                            {
                                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-4);">
                                    @foreach (var pkg in FetchedPackages)
                                    {
                                        bool isPkgSelected = selectedPackageId == pkg.Id;
                                        int baseCC = ExtractBaseCC(specCC);
                                        int finalCC = baseCC + pkg.EstimatedAddedCC;
                                        var stats = GetDynamicStats(baseCC, pkg.EstimatedAddedCC);
                                        <div @onclick="() => SelectPackage(pkg)" style="cursor: pointer; background: var(--card); border: 2px solid @(isPkgSelected ? "var(--primary)" : "var(--border)"); border-radius: var(--radius); padding: var(--space-4); transition: all 0.2s; display: flex; flex-direction: column;">
                                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-2);">
                                                <h3 style="font-size: var(--text-lg); font-weight: bold; color: var(--foreground); margin: 0;">@pkg.Name</h3>
                                                @if (isPkgSelected) { <div style="background: var(--primary); color: white; border-radius: 50%; width: 24px; height: 24px; display: flex; justify-content: center; align-items: center;"><LucideIcon Name="check" Size="14" /></div> }
                                            </div>
                                            <div style="margin-bottom: 12px; display: inline-block; background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.3); padding: 4px 8px; border-radius: 4px; color: #3b82f6; font-size: 11px; font-weight: bold;">UPGRADE: @baseCC cc ➔ @finalCC cc (+@pkg.EstimatedAddedCC cc)</div>
                                            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin-bottom: var(--space-4);">@pkg.Description</p>
                                            <div style="margin-bottom: var(--space-4); padding: 8px; background: var(--muted); border-radius: 6px;">
                                                <p style="font-size: 10px; font-weight: bold; color: var(--muted-foreground); text-transform: uppercase; margin: 0 0 8px 0;">Included Parts:</p>
                                                @foreach (var group in pkg.IncludedProducts.GroupBy(p => string.IsNullOrWhiteSpace(p.Category) ? "Other" : p.Category).OrderBy(g => g.Key))
                                                {
                                                    <div style="margin-bottom: 6px;">
                                                        <div style="font-size: 9px; font-weight: bold; color: var(--primary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;">@group.Key</div>
                                                        <ul style="margin: 0; padding-left: 14px; font-size: 11px; color: var(--foreground); opacity: 0.8;">
                                                            @foreach (var item in group) { <li>@item.Name</li> }
                                                        </ul>
                                                    </div>
                                                }
                                            </div>
                                            <div style="margin-top: var(--space-4); padding-top: var(--space-3); border-top: 1px solid var(--border);">
                                                <p style="font-size: 10px; font-weight: bold; color: var(--muted-foreground); margin-bottom: 8px; text-transform: uppercase;">Performance Estimate</p>
                                                @foreach (var (label, value, color) in new[] { ("HORSEPOWER", stats.Power, "var(--primary)"), ("TOP SPEED", stats.Speed, "#3b82f6"), ("RELIABILITY", stats.Reliability, stats.Reliability < 60 ? "var(--destructive)" : "#10b981") })
                                                {
                                                    <div style="margin-bottom: 6px;">
                                                        <div style="display: flex; justify-content: space-between; font-size: 10px; color: var(--foreground); margin-bottom: 2px;"><span>@label</span><span>@value%</span></div>
                                                        <div style="height: 4px; width: 100%; background: var(--muted); border-radius: 2px; overflow: hidden;"><div style="height: 100%; width: @(value)%; background: @color;"></div></div>
                                                    </div>
                                                }
                                            </div>
                                            <div style="margin-top: 15px; font-size: var(--text-xl); font-weight: 900; color: var(--primary);">₱@pkg.TotalPrice.ToString("N0")</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* FINAL STEP: Customize & Inventory *@
                    @if (currentStep == TotalSteps && buildRoute != null)
                    {
                        <h2 style="font-size: var(--text-xl); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-1) 0;">@(buildRoute == "Pre-Built" ? "Review & Customize" : "Select Your Parts")</h2>
                        <p style="font-size: var(--text-xs); color: var(--muted-foreground); margin: 0 0 var(--space-4) 0;">@(buildRoute == "Pre-Built" ? "We loaded your package parts. Add or remove items below." : "Browse the inventory and build from scratch.")</p>
                        <h3 style="font-size: var(--text-sm); font-weight: bold; margin-bottom: var(--space-3); padding-bottom: var(--space-1); border-bottom: 1px solid var(--border);">Showing: @(selectedBrand ?? "All Brands") - @expandedCategory</h3>
                        @if (products != null)
                        {
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: var(--space-4);">
                                @foreach (var product in FilteredProducts)
                                {
                                    bool isSelected = selectedParts.Any(p => p.Id == product.Id);
                                    bool isOutOfStock = product.CurrentStock <= 0;
                                    <div @onclick="@(() => { if (!isOutOfStock) TogglePart(product); })" style="position: relative; cursor: @(isOutOfStock ? "not-allowed" : "pointer"); background-color: var(--card); border: 2px solid @(isSelected ? "var(--primary)" : "var(--border)"); padding: var(--space-3); border-radius: var(--radius); transition: all 0.15s; opacity: @(isOutOfStock ? "0.6" : "1");">
                                        @if (isOutOfStock) { <div style="position: absolute; top: 12px; right: 12px; background: var(--destructive); color: var(--destructive-foreground); padding: 4px 8px; font-size: 10px; font-weight: 800; border-radius: 4px; z-index: 10;">OUT OF STOCK</div> }
                                        <img src="@product.ImageUrl" style="width: 100%; height: 100px; object-fit: cover; border-radius: calc(var(--radius) - 2px); background-color: var(--muted); margin-bottom: var(--space-2);" />
                                        <div style="font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--foreground);">@product.Name</div>
                                        <div style="font-size: var(--text-xs); color: var(--muted-foreground);">@product.Brand</div>
                                        <div style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--primary); margin-top: var(--space-1);">₱@product.Price.ToString("N0")</div>
                                    </div>
                                }
                            </div>
                        }
                    }

                </div>

                @* ── Navigation Bar — pinned below main content ── *@
                @if (currentStep < TotalSteps || buildRoute == "Custom")
                {
                    <div style="flex-shrink: 0; bottom: 0; padding: var(--space-4) var(--space-6); border-top: 1px solid var(--border); background-color: var(--card); display: flex; justify-content: space-between; align-items: center; gap: var(--space-3);">

                        <BbButton Variant="ButtonVariant.Outline" OnClick="PrevStep" Disabled="@(currentStep == 1)">
                            <LucideIcon Name="arrow-left" Size="16" />
                            Back
                        </BbButton>

                        <span style="font-size: var(--text-xs); color: var(--muted-foreground);">
                            Step @currentStep of @TotalSteps
                        </span>

                        @if (buildRoute != "Custom")
                        {
                            <BbButton Variant="ButtonVariant.Default" OnClick="NextStep" Disabled="@(!CanProceedToNextStep)">
                                Next
                                <LucideIcon Name="arrow-right" Size="16" />
                            </BbButton>
                        }
                        else
                        {
                            <div style="width:80px;"></div>
                        }

                    </div>
                }
            </div>
        </div>

    </Authorized>

    <NotAuthorized>
        <div style="height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; color: var(--foreground); gap: var(--space-4);">
            <BbSpinner Size="SpinnerSize.Large" />
            <h2 style="color: var(--destructive); font-weight: var(--font-bold); letter-spacing: 0.1em;">SESSION EXPIRED</h2>
            <p style="color: var(--muted-foreground); font-size: var(--text-sm);">Redirecting to Home.</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    @@media (max-width: 767px) {
        .build-mobile-bar { display: flex !important; }
    }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private List<Product>? products = new();
    private List<Product> selectedParts = new();
    private bool isLoading = true;
    private bool isProcessing = false;
    private string statusMessage = "";
    private bool isSuccess = false;
    private bool mobileDrawerOpen = true;

    private string? buildRoute = null;
    private int currentStep = 1;

    private Dictionary<string, Dictionary<string, List<string>>> motorDatabase = new()
    {
        { "Yamaha", new() {
            { "Mio Sporty / Soul", new() { "59mm (150cc)", "63mm (180cc)", "65mm (200cc)" } },
            { "Mio i125 / M3", new() { "59mm (150cc)", "63mm (180cc)" } },
            { "Aerox / NMAX v1-v2", new() { "63mm (180cc)", "65mm (200cc)", "66mm+ (Racing)" } },
            { "Sniper 150/155", new() { "62mm (180cc)", "65mm (200cc)", "Superhead Build" } }
        }},
        { "Honda", new() {
            { "Click 125i/150i", new() { "59mm (150cc)", "61mm (160cc)", "63mm (180cc)" } },
            { "PCX / ADV 150", new() { "61mm (160cc)", "63mm (180cc)" } },
            { "PCX / ADV 160", new() { "63mm (180cc)", "65mm (200cc)" } },
            { "Beat 110", new() { "55mm (130cc)", "59mm (150cc)" } }
        }},
        { "Suzuki", new() {
            { "Raider 150 Carb", new() { "66mm (200cc)", "68mm (220cc)", "Open Spec" } },
            { "Raider 150 FI", new() { "66mm (200cc)", "68mm (220cc)" } },
            { "Smash / Skydrive", new() { "59mm (150cc)", "63mm (180cc)" } }
        }}
    };

    private string specBrand = "";
    private string specModel = "";
    private string specCC = "";
    private decimal minBudget = 0;
    private decimal maxBudget = 20000;
    private int? selectedPackageId = null;
    private string expandedCategory = "Genuine Parts";
    private string? selectedBrand = null;

    private int TotalSteps => buildRoute == "Pre-Built" ? 5 : (buildRoute == "Custom" ? 2 : 1);

    private string CurrentStepLabel => buildRoute switch
    {
        null => "Choose Route",
        "Custom" => currentStep == 1 ? "Choose Route" : "Select Parts",
        "Pre-Built" => currentStep switch
        {
            1 => "Choose Route",
            2 => "Motor Specs",
            3 => "Budget",
            4 => "Select Package",
            5 => "Customize",
            _ => ""
        },
        _ => ""
    };

    private bool CanProceedToNextStep => buildRoute switch
    {
        null => false,
        "Custom" => currentStep == 1 && !string.IsNullOrEmpty(buildRoute),
        "Pre-Built" => currentStep switch
        {
            1 => !string.IsNullOrEmpty(buildRoute),
            2 => !string.IsNullOrEmpty(specBrand) && !string.IsNullOrEmpty(specModel) && !string.IsNullOrEmpty(specCC),
            3 => maxBudget >= minBudget,
            4 => selectedPackageId != null,
            _ => true
        },
        _ => false
    };

    private decimal TotalPrice => selectedParts.Sum(s => s.Price);
    private IEnumerable<string> UniqueCategories => products?.Select(p => p.Category).Distinct() ?? Array.Empty<string>();
    private IEnumerable<Product> FilteredProducts => products?.Where(p =>
        (string.IsNullOrEmpty(expandedCategory) || p.Category == expandedCategory) &&
        (string.IsNullOrEmpty(selectedBrand) || p.Brand == selectedBrand)) ?? Array.Empty<Product>();

    private int ExtractBaseCC(string ccString)
    {
        if (string.IsNullOrEmpty(ccString)) return 125;
        var match = Regex.Match(ccString, @"(\d+)cc");
        if (match.Success && int.TryParse(match.Groups[1].Value, out int cc)) return cc;
        return 125;
    }

    private (int Power, int Speed, int Reliability) GetDynamicStats(int baseCC, int addedCC)
    {
        int totalCC = baseCC + addedCC;
        int power = Math.Min(100, (int)((totalCC / 250.0) * 100));
        int speed = Math.Min(100, (int)((totalCC / 250.0) * 95) + 5);
        double stressFactor = (double)addedCC / baseCC;
        int reliability = Math.Max(20, 95 - (int)(stressFactor * 100));
        return (power, speed, reliability);
    }

    public class PreBuildPackage
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public int EstimatedAddedCC { get; set; }
        public decimal TotalPrice => IncludedProducts.Sum(p => p.Price);
        public List<Product> IncludedProducts { get; set; } = new();
    }

    private List<PreBuildPackage> FetchedPackages = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            products = await Http.GetFromJsonAsync<List<Product>>("api/products");
            if (products != null && products.Any())
                expandedCategory = products.First().Category;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            statusMessage = "Could not load inventory.";
        }
        finally
        {
            await Task.Delay(200);
            isLoading = false;
        }
    }

    private void UpdateBrand(string brand) { specBrand = brand; specModel = ""; specCC = ""; }
    private void UpdateModel(string model) { specModel = model; specCC = ""; }

    private void SelectBuildRoute(string route)
    {
        buildRoute = route;
        selectedParts.Clear();
        selectedPackageId = null;
        _ = NextStep();
    }

    private async Task NextStep()
    {
        if (currentStep == 3 && buildRoute == "Pre-Built")
        {
            isLoading = true;
            StateHasChanged();
            try
            {
                string url = $"api/prebuilds?brand={Uri.EscapeDataString(specBrand)}&model={Uri.EscapeDataString(specModel)}&cc={Uri.EscapeDataString(specCC)}&minBudget={minBudget}&maxBudget={maxBudget}";
                FetchedPackages = await Http.GetFromJsonAsync<List<PreBuildPackage>>(url) ?? new();
            }
            catch (Exception ex) { Console.WriteLine(ex.Message); }
            finally { isLoading = false; }
        }
        if (currentStep < TotalSteps) currentStep++;
    }

    private void PrevStep()
    {
        if (currentStep > 1)
        {
            currentStep--;
            if (currentStep == 1) buildRoute = null;
        }
    }

    private void SelectPackage(PreBuildPackage pkg)
    {
        selectedPackageId = pkg.Id;
        selectedParts = new List<Product>(pkg.IncludedProducts);
    }

    private void ToggleCategory(string category) { expandedCategory = category; selectedBrand = null; }
    private IEnumerable<string> GetBrandsByCategory(string category) =>
        products?.Where(p => p.Category == category).Select(p => p.Brand).Distinct() ?? Array.Empty<string>();

    private void TogglePart(Product product)
    {
        if (selectedParts.Any(p => p.Id == product.Id))
            selectedParts.RemoveAll(p => p.Id == product.Id);
        else
            selectedParts.Add(product);
    }

    private async Task SendEmailQuote()
    {
        if (!selectedParts.Any()) { statusMessage = "Please select parts first."; isSuccess = false; return; }
        isProcessing = true;
        statusMessage = "Sending email quote...";
        try
        {
            var authState = await AuthStateTask!;
            var userEmail = authState.User.Identity?.Name ?? "User";
            var response = await Http.PostAsJsonAsync("api/products/send-quote", new { UserEmail = userEmail, ProductIds = selectedParts.Select(p => p.Id).ToList() });
            if (response.IsSuccessStatusCode) { statusMessage = "Quote sent to your email!"; isSuccess = true; }
            else { statusMessage = "Failed to send email."; isSuccess = false; }
        }
        catch { statusMessage = "Connection Error."; isSuccess = false; }
        finally { isProcessing = false; }
    }

    private async Task SubmitBuildToAdmin()
    {
        if (!selectedParts.Any()) { statusMessage = "Please select parts first."; return; }
        isProcessing = true;
        statusMessage = "Submitting to admin...";
        try
        {
            var authState = await AuthStateTask!;
            var userName = authState.User.Identity?.Name ?? "Guest";
            var buildRequest = new BuildRequest
            {
                CustomerName = userName,
                SelectedPartsJson = JsonSerializer.Serialize(selectedParts),
                TotalPrice = selectedParts.Sum(p => p.Price),
                Status = "Pending",
                CreatedAt = DateTime.Now
            };
            var response = await Http.PostAsJsonAsync("api/builds", buildRequest);
            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Build submitted successfully!";
                isSuccess = true;
                selectedParts.Clear();
                currentStep = 1;
                buildRoute = null;
            }
            else { statusMessage = "Failed to submit build."; isSuccess = false; }
        }
        catch { statusMessage = "Connection Error."; isSuccess = false; }
        finally { isProcessing = false; }
    }
}
