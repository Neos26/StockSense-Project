@page "/Dashboard"
@layout AdminLayout
@using StockSense.Shared
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject NavigationManager NavManager
@rendermode InteractiveWebAssembly

@attribute [Authorize(Roles = "Employee, Admin")]

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{ <Spinner/>
    @* NOTE: Look for more possible code blocks that can be turned into components*@
}

<div style="display: @(isLoading ? "none" : "block"); animation: fadeIn 0.4s ease-in;">

    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-6); flex-wrap: wrap; gap: var(--space-3);">
        <div>
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Dashboard</h1>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Admin overview and stock alerts.</p>
        </div>
        <BbButton Variant="ButtonVariant.Destructive" OnClick='() => NavManager.NavigateTo("/admin/orderslips?orderAll=true")'>
            <LucideIcon Name="shopping-cart" Size="16" />
            Order All Low Stock
        </BbButton>
    </div>

    @if (data != null)
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: var(--space-4); margin-bottom: var(--space-6);">

            <BbCard>
                <BbCardHeader>
                    <BbCardDescription>Total Products</BbCardDescription>
                </BbCardHeader>
                <BbCardContent>
                    <span style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--foreground);">@data.TotalProducts</span>
                </BbCardContent>
            </BbCard>

            <BbCard Class="card-destructive">
                <BbCardHeader>
                    <BbCardDescription Class="text-destructive"> Critical Low Stock</BbCardDescription>
                </BbCardHeader>
                <BbCardContent>
                    <span style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--foreground);">@data.LowStockCount</span>
                </BbCardContent>
            </BbCard>

            <BbCard>
                <BbCardHeader>
                    <BbCardDescription>Inventory Value</BbCardDescription>
                </BbCardHeader>
                <BbCardContent>
                    <span style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--foreground);">₱@data.TotalValue.ToString("N0")</span>
                </BbCardContent>
            </BbCard>

            <BbCard>
                <BbCardHeader>
                    <BbCardDescription>Open Orders</BbCardDescription>
                </BbCardHeader>
                <BbCardContent>
                    <span style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--foreground);">@data.PendingOrders</span>
                </BbCardContent>
            </BbCard>

        </div>

        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius);">
            <div style="padding: var(--card-padding); border-bottom: 1px solid var(--border);">
                <h2 style="font-size: var(--text-lg); font-weight: var(--font-semibold); color: var(--destructive); margin: 0; display: flex; align-items: center; gap: var(--space-2);">
                    <LucideIcon Name="triangle-alert" Size="18" />
                    Critical Stock Alerts
                </h2>
            </div>
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); min-width: 500px;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Product</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Category</th>
                            <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Stock Status</th>
                            <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!data.LowStockProducts.Any())
                        {
                            <tr>
                                <td colspan="4" style="text-align: center; padding: var(--space-8); color: var(--muted-foreground);">
                                    <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-2);">
                                        <LucideIcon Name="shield-check" Size="32" />
                                        <span>Inventory levels are currently stable.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var p in data.LowStockProducts)
                        {
                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <div style="font-weight: var(--font-medium); color: var(--foreground);">@p.Name</div>
                                    <div style="font-size: var(--text-xs); color: var(--muted-foreground);">@p.Brand</div>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <BbBadge Variant="BadgeVariant.Secondary">@p.Category</BbBadge>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4);">
                                    <span style="color: var(--destructive); font-weight: var(--font-semibold);">@p.CurrentStock</span>
                                    <span style="color: var(--muted-foreground); font-size: var(--text-sm);"> / @p.ReorderTarget target</span>
                                </td>
                                <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small"
                                              OnClick="@(() => NavManager.NavigateTo($"/admin/orderslips?productId={p.Id}"))">
                                        Order Now
                                    </BbButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (errorMessage != null)
    {
        <div style="margin-top: var(--space-4); color: var(--destructive); background-color: var(--destructive-muted); padding: var(--space-3); border: 1px solid var(--destructive-border); border-radius: var(--radius); font-size: var(--text-sm);">
            @errorMessage
        </div>
    }
</div>

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@code {
    private DashboardDTO? data;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            data = await Http.GetFromJsonAsync<DashboardDTO>("api/dashboard/stats");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Dashboard Error: {ex.Message}");
        }
        finally
        {
            await Task.Delay(300);
            isLoading = false;
        }
    }

    public class DashboardDTO
    {
        public int TotalProducts { get; set; }
        public int LowStockCount { get; set; }
        public decimal TotalValue { get; set; }
        public int PendingOrders { get; set; }
        public List<Product> LowStockProducts { get; set; } = new();
    }
}