@page "/admin/builds"
@layout AdminLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.shared
@using StockSense.Shared
@using System.Text.Json
@using System.Globalization
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

@attribute [Authorize(Roles = "Employee, Admin")]

<PageTitle>Manage Builds</PageTitle>

<div>
    <div style="display: flex; align-items: start; margin-bottom: var(--space-6); flex-direction: column;">
        <div style="display: flex; align-items: center; gap: var(--space-2); flex-direction: row;">
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Manage Builds</h1>
            <span style="background: var(--destructive); color: white; padding: 2px 8px; border-radius: var(--radius); font-size: var(--text-xs); font-weight: bold;">
                @ActiveBuilds.Count(b => b.Status == "Pending") Pending
            </span>
        </div>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Review and manage customer build requests.</p>
    </div>

    @if (allBuilds == null)
    {
        <div style="width: 100%; display: flex; justify-content: center; align-items: center;">
            <LightSpinner Description="Loading Build Requests..." />
        </div>
    }
    else
    {
        @* --- TABS & ARCHIVE TOGGLE --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-4);">
            <div style="display: flex; gap: var(--space-2);">
                <button @onclick='() => activeTab = "Active"'
                        style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(activeTab == "Active" ? "var(--secondary)" : "transparent"); color: @(activeTab == "Active" ? "var(--foreground)" : "var(--muted-foreground)");">
                    Active (@ActiveBuilds.Count())
                </button>
                <button @onclick='() => activeTab = "History"'
                        style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(activeTab == "History" ? "var(--secondary)" : "transparent"); color: @(activeTab == "History" ? "var(--foreground)" : "var(--muted-foreground)");">
                    History (@HistoryBuilds.Count())
                </button>
            </div>

            @if (activeTab == "History")
            {
                <div style="display: flex; align-items: center; gap: 8px;">
                    <input type="checkbox" @bind="showAllHistory" id="buildArchiveToggle" />
                    <label for="buildArchiveToggle" style="font-size: var(--text-xs); color: var(--muted-foreground); cursor: pointer;">Show older than 30 days</label>
                </div>
            }
        </div>

        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius);">
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); min-width: 750px;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border); background: rgba(0,0,0,0.02);">
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Customer</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Date Received</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Items</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Total Value</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Status</th>
                            <th style="text-align: center; padding: 12px 16px; color: var(--muted-foreground);">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!DisplayBuilds.Any())
                        {
                            <tr>
                                <td colspan="6" style="text-align: center; padding: 40px; color: var(--muted-foreground);">
                                    <span>No builds found in this section.</span>
                                </td>
                            </tr>
                        }
                        @foreach (var build in DisplayBuilds)
                        {
                            var parts = ParseParts(build.SelectedPartsJson);
                            <tr style="border-bottom: 1px solid var(--border); transition: background 0.2s;">
                                <td style="padding: 12px 16px; font-weight: bold; color: var(--foreground);">@build.CustomerName</td>
                                <td style="padding: 12px 16px; color: var(--muted-foreground); font-size: var(--text-xs);">@build.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td>
                                <td style="padding: 12px 16px;">
                                    <span style="background: var(--muted); padding: 2px 8px; border-radius: 4px; font-size: var(--text-xs);">@parts.Count items</span>
                                </td>
                                <td style="padding: 12px 16px; font-weight: bold; color: var(--foreground);">
                                    ₱@parts.Sum(p => p.Price).ToString("N2")
                                </td>
                                <td style="padding: 12px 16px;">
                                    <select value="@build.Status"
                                            @onchange="@((ChangeEventArgs e) => UpdateStatus(build, e.Value?.ToString() ?? "Pending"))"
                                            style="padding: 6px 10px; border-radius: 6px; border: 1px solid var(--border); border-left: 4px solid @GetStatusColor(build.Status); background: var(--background); color: var(--foreground); font-size: var(--text-xs); cursor: pointer;">
                                        <option value="Pending">Pending</option>
                                        <option value="Confirmed">Confirmed</option>
                                        <option value="Completed">Completed</option>
                                        <option value="Cancelled">Cancelled</option>
                                    </select>
                                </td>
                                <td style="padding: 12px 16px; text-align: center;">
                                    <button @onclick="() => OpenModal(build, parts)" style="background: var(--primary); color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: var(--text-xs); font-weight: bold;">
                                        VIEW PARTS
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* --- PARTS MODAL --- *@
@if (ShowModal && CurrentParts != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.8); display: flex; justify-content: center; align-items: center; z-index: 1000; padding: 20px;">
        <div style="background: var(--card); width: 600px; max-height: 90vh; border-radius: 12px; border: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden;">

            <div style="padding: 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                <h3 style="margin: 0; color: var(--foreground);">Build Details: @CurrentBuild?.CustomerName</h3>
                <button @onclick="CloseModal" style="background: none; border: none; color: var(--muted-foreground); cursor: pointer; font-size: 1.5rem;">&times;</button>
            </div>

            <div style="padding: 20px; overflow-y: auto; flex: 1;">
                @foreach (var group in CurrentParts.GroupBy(p => p.Category))
                {
                    <div style="margin-bottom: 20px;">
                        <h4 style="font-size: 0.75rem; color: #3b82f6; text-transform: uppercase; margin-bottom: 10px; border-bottom: 1px solid var(--border); padding-bottom: 5px;">@group.Key</h4>
                        @foreach (var part in group)
                        {
                            <div style="display: flex; justify-content: space-between; background: rgba(255,255,255,0.03); padding: 8px 12px; border-radius: 6px; margin-bottom: 5px;">
                                <span style="color: var(--foreground); font-size: 0.9rem;">@part.Brand - @part.Name</span>
                                <span style="font-weight: bold; color: var(--foreground);">₱@part.Price.ToString("N2")</span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div style="padding: 20px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                <span style="font-weight: bold; font-size: 1.1rem; color: var(--foreground);">Total: ₱@CurrentParts.Sum(p => p.Price).ToString("N2")</span>
                <button @onclick="CloseModal" style="padding: 8px 20px; background: var(--secondary); color: var(--foreground); border: none; border-radius: 6px; cursor: pointer;">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private List<BuildRequest>? allBuilds;
    private string activeTab = "Active";
    private bool showAllHistory = false;

    private IEnumerable<BuildRequest> ActiveBuilds =>
        allBuilds?.Where(b => b.Status == "Pending" || b.Status == "Confirmed").OrderByDescending(b => b.CreatedAt) ?? Enumerable.Empty<BuildRequest>();

    private IEnumerable<BuildRequest> HistoryBuilds
    {
        get
        {
            if (allBuilds == null) return Enumerable.Empty<BuildRequest>();
            var query = allBuilds.Where(b => b.Status == "Completed" || b.Status == "Cancelled");
            if (!showAllHistory)
            {
                var limitDate = DateTime.Now.AddDays(-30);
                query = query.Where(b => b.CreatedAt >= limitDate);
            }
            return query.OrderByDescending(b => b.CreatedAt);
        }
    }

    private IEnumerable<BuildRequest> DisplayBuilds => activeTab == "Active" ? ActiveBuilds : HistoryBuilds;

    private bool ShowModal = false;
    private BuildRequest? CurrentBuild;
    private List<Product> CurrentParts = new();

    protected override async Task OnInitializedAsync() => await LoadBuilds();

    private async Task LoadBuilds() => allBuilds = await Http.GetFromJsonAsync<List<BuildRequest>>("api/builds/all");

    private async Task UpdateStatus(BuildRequest build, string newStatus)
    {
        await Http.PutAsJsonAsync($"api/builds/{build.Id}/status", newStatus);
        build.Status = newStatus;
    }

    private List<Product> ParseParts(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new List<Product>();
        try
        {
            return JsonSerializer.Deserialize<List<Product>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch
        {
            return new();
        }
    }

    private void OpenModal(BuildRequest build, List<Product> parts)
    {
        CurrentBuild = build;
        CurrentParts = parts;
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    private string GetStatusColor(string status) => status?.ToLower() switch
    {
        "pending" => "#f59e0b",
        "confirmed" => "#3b82f6",
        "completed" => "#10b981",
        "cancelled" => "#ef4444",
        _ => "gray"
    };
}