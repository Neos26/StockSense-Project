@page "/admin/appointments"
@layout AdminLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.shared
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http

@attribute [Authorize(Roles = "Employee, Admin")]

<PageTitle>Manage Appointments</PageTitle>

<div>
    <div style="display: flex; align-items: start; margin-bottom: var(--space-6); flex-direction: column;">
        <div style="display: flex; align-items: center; gap: var(--space-2); flex-direction: row;">
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Manage Appointments</h1>
            <span style="background: var(--destructive); color: white; padding: 2px 8px; border-radius: var(--radius); font-size: var(--text-xs); font-weight: bold;">
                @ActiveAppointments.Count(a => a.Status == "Pending") Pending
            </span>
        </div>
        <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Review and manage customer appointment requests.</p>
    </div>

    @if (allAppointments == null)
    {
        <div style="display: flex; justify-content: center; align-items: center; padding: var(--space-8); color: var(--muted-foreground); gap: var(--space-3);">
            <span>Loading appointment requests...</span>
        </div>
    }
    else
    {
        @* --- TABS & ARCHIVE TOGGLE --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-4);">
            <div style="display: flex; gap: var(--space-2);">
                <button @onclick='() => currentTab = "Active"'
                        style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(currentTab == "Active" ? "var(--secondary)" : "transparent"); color: @(currentTab == "Active" ? "var(--foreground)" : "var(--muted-foreground)");">
                    Active (@ActiveAppointments.Count())
                </button>
                <button @onclick='() => currentTab = "History"'
                        style="padding: var(--space-2) var(--space-4); border-radius: var(--radius); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; border: 1px solid var(--border); background-color: @(currentTab == "History" ? "var(--secondary)" : "transparent"); color: @(currentTab == "History" ? "var(--foreground)" : "var(--muted-foreground)");">
                    History (@HistoryAppointments.Count())
                </button>
            </div>

            @if (currentTab == "History")
            {
                <div style="display: flex; align-items: center; gap: 8px;">
                    <input type="checkbox" @bind="showAllHistory" id="archiveToggle" />
                    <label for="archiveToggle" style="font-size: var(--text-xs); color: var(--muted-foreground); cursor: pointer;">Show older than 30 days</label>
                </div>
            }
        </div>

        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius);">
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); min-width: 750px;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border); background: rgba(0,0,0,0.02);">
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Customer & Mechanic</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Schedule & Duration</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Services</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Total Value</th>
                            <th style="text-align: left; padding: 12px 16px; color: var(--muted-foreground);">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!DisplayAppointments.Any())
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 40px; color: var(--muted-foreground);">
                                    <span>No appointments found in this section.</span>
                                </td>
                            </tr>
                        }
                        @foreach (var appt in DisplayAppointments)
                        {
                            <tr style="border-bottom: 1px solid var(--border); transition: background 0.2s;" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.02)'" onmouseout="this.style.backgroundColor='transparent'">
                                <td style="padding: 12px 16px;">
                                    <div style="font-weight: bold; color: var(--foreground);">@appt.CustomerName</div>
                                    <div style="font-size: var(--text-xs); color: var(--muted-foreground); margin-top: 4px;">
                                        Mech: <span style="color: var(--foreground);">@(string.IsNullOrEmpty(appt.MechanicName) ? "Unassigned" : appt.MechanicName)</span>
                                    </div>
                                </td>
                                <td style="padding: 12px 16px;">
                                    <div style="color: var(--foreground);">@appt.AppointmentDate.ToString("MMM dd, yyyy")</div>
                                    <div style="font-size: var(--text-xs); margin-top: 2px;">
                                        <span style="color: #3b82f6; font-weight: bold;">@appt.TimeSlot</span>
                                        <span style="color: var(--muted-foreground);"> (@appt.DurationMinutes mins)</span>
                                    </div>
                                </td>
                                <td style="padding: 12px 16px;">
                                    <div style="color: var(--muted-foreground); font-size: var(--text-sm);">@appt.ServicesRequested</div>
                                    <div style="font-size: 0.65rem; color: var(--muted-foreground); font-style: italic; margin-top: 4px;">
                                        Ref: @appt.CreatedAt.ToString("MM/dd/yy HH:mm")
                                    </div>
                                </td>
                                <td style="padding: 12px 16px; font-weight: bold; color: var(--foreground);">
                                    ₱@appt.TotalAmount.ToString("N2")
                                </td>
                                <td style="padding: 12px 16px;">
                                    <select value="@appt.Status"
                                            @onchange="@(e => UpdateStatus(appt, e.Value?.ToString() ?? "Pending"))"
                                            style="padding: 6px 10px; border-radius: 6px; border: 1px solid var(--border); border-left: 4px solid @GetStatusColor(appt.Status); background: var(--background); color: var(--foreground); font-size: var(--text-xs); cursor: pointer;">
                                        <option value="Pending">Pending</option>
                                        <option value="Confirmed">Confirmed</option>
                                        <option value="Completed">Completed</option>
                                        <option value="Cancelled">Cancelled</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<Appointment>? allAppointments;
    private string currentTab = "Active";
    private bool showAllHistory = false;

    // --- LOGIC: Active vs History ---
    private IEnumerable<Appointment> ActiveAppointments =>
        allAppointments?.Where(a => a.Status == "Pending" || a.Status == "Confirmed")
        .OrderBy(a => a.AppointmentDate) ?? Enumerable.Empty<Appointment>();

    private IEnumerable<Appointment> HistoryAppointments
    {
        get
        {
            if (allAppointments == null) return Enumerable.Empty<Appointment>();

            var query = allAppointments.Where(a => a.Status == "Completed" || a.Status == "Cancelled");

            // If not showing all, filter for the last 30 days
            if (!showAllHistory)
            {
                var limitDate = DateTime.Now.AddDays(-30);
                query = query.Where(a => a.AppointmentDate >= limitDate);
            }

            return query.OrderByDescending(a => a.AppointmentDate);
        }
    }

    private IEnumerable<Appointment> DisplayAppointments => currentTab == "Active" ? ActiveAppointments : HistoryAppointments;

    protected override async Task OnInitializedAsync() => await LoadAppointments();

    private async Task LoadAppointments()
    {
        try
        {
            allAppointments = await Http.GetFromJsonAsync<List<Appointment>>("api/appointments/all");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task UpdateStatus(Appointment appt, string newStatus)
    {
        var response = await Http.PutAsJsonAsync($"api/appointments/{appt.Id}/status", newStatus);
        if (response.IsSuccessStatusCode) appt.Status = newStatus;
    }

    private string GetStatusColor(string status) => status?.ToLower() switch
    {
        "pending" => "#f59e0b",   // Amber
        "confirmed" => "#3b82f6", // Blue
        "completed" => "#10b981", // Emerald
        "cancelled" => "#ef4444", // Red
        _ => "gray"
    };
}