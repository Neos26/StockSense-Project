using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;

namespace StockSense.Controllers // Update this to match your namespace
{
    [Route("api/[controller]")]
    [ApiController]
    public class AuthController : ControllerBase
    {
        // This is the endpoint the Navbar is pinging
        [Authorize]
        [HttpGet("check")]
        public IActionResult CheckSession()
        {
            // If the user reaches here, the token is VALID.
            // If the token is EXPIRED, ASP.NET Core automatically returns 401.
            return Ok();
        }
    }
}