@page "/admin/pos"
@layout AdminLayout
@using StockSense.shared
@using StockSense.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@inject StockSense.Data.ApplicationDbContext Context
@inject TransactionService SaleService
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin, Employee")]

<div style="display: flex; gap: var(--space-6); height: calc(100vh - 8rem); overflow: hidden;">

    @* --- Product Catalog --- *@
    <div style="flex: 1; display: flex; flex-direction: column; min-width: 0; overflow: hidden; background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius);">

        <div style="flex-shrink: 0; padding: var(--space-4) var(--space-6); border-bottom: 1px solid var(--border); display: flex; flex-direction: column; gap: var(--space-3);">
            <BbInput @bind-Value="searchTerm" Placeholder="Search products..." />
            <div style="display: flex; flex-wrap: wrap; gap: var(--space-1);">
                <button type="button" @onclick="() => selectedCategory = null"
                        style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == null ? "var(--primary)" : "var(--border)"); cursor: pointer; background-color: @(selectedCategory == null ? "var(--primary)" : "transparent"); color: @(selectedCategory == null ? "var(--primary-foreground)" : "var(--foreground)");">
                    All
                </button>
                @foreach (var cat in categories)
                {
                    <button type="button" @onclick="() => selectedCategory = cat"
                            style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == cat ? "var(--primary)" : "var(--border)"); cursor: pointer; background-color: @(selectedCategory == cat ? "var(--primary)" : "transparent"); color: @(selectedCategory == cat ? "var(--primary-foreground)" : "var(--foreground)");">
                        @cat
                    </button>
                }
            </div>
        </div>

        <div style="flex: 1; overflow-y: auto; padding: var(--space-4);">
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: var(--space-3);">
                @foreach (var p in FilteredProducts)
                {
                    <div @onclick="() => AddToCart(p)"
                         style="padding: var(--space-3); border-radius: var(--radius); border: 2px solid @(cart.Any(i => i.ProductId == p.Id) ? "var(--primary)" : "var(--border)"); cursor: @(p.CurrentStock <= 0 ? "not-allowed" : "pointer"); opacity: @(p.CurrentStock <= 0 ? "0.5" : "1"); text-align: center; transition: border-color 0.15s;">
                        <div style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@p.Name</div>
                        <div style="font-size: var(--text-xs); color: var(--muted-foreground); margin: var(--space-1) 0;">@p.Brand</div>
                        <div style="font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--primary);">₱@p.Price.ToString("N2")</div>
                        <div style="font-size: var(--text-xs); color: var(--muted-foreground); margin-top: var(--space-1);">Stock: @p.CurrentStock</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* --- Cart Section --- *@
    <div style="width: 22rem; flex-shrink: 0; display: flex; flex-direction: column; overflow: hidden; background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius);">
        <div style="flex-shrink: 0; padding: var(--space-4) var(--space-6); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: var(--space-2);">
            <LucideIcon Name="shopping-cart" Size="18" />
            <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--card-foreground);">Current Order</span>
        </div>

        <div style="flex: 1; overflow-x: hidden; overflow-y: auto; padding: var(--space-4);">
            @if (!cart.Any())
            {
                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: var(--space-3); color: var(--muted-foreground);">
                    <LucideIcon Name="shopping-cart" Size="40" />
                    <p style="font-size: var(--text-sm); margin: 0;">Cart is empty</p>
                </div>
            }
            else
            {
                <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm);">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <th style="text-align: left; padding: var(--space-2) var(--space-3); color: var(--muted-foreground); font-weight: var(--font-medium);">Item</th>
                            <th style="text-align: left; padding: var(--space-2) var(--space-3); color: var(--muted-foreground); font-weight: var(--font-medium);">Qty</th>
                            <th style="text-align: right; padding: var(--space-2) var(--space-3); color: var(--muted-foreground); font-weight: var(--font-medium);">Total</th>
                            <th style="padding: var(--space-2) var(--space-3);"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in cart)
                        {
                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: var(--space-2) var(--space-3); color: var(--foreground);">@item.ProductName</td>
                                <td style="padding: var(--space-2) var(--space-3);">
                                    <input type="number" @bind="item.Quantity"
                                           style="width: 60px; padding: var(--space-1) var(--space-2); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--text-sm); box-sizing: border-box;" />
                                </td>
                                <td style="padding: var(--space-2) var(--space-3); text-align: right; color: var(--foreground);">₱@((item.Price * item.Quantity).ToString("N2"))</td>
                                <td style="padding: var(--space-2) var(--space-3);">
                                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="() => cart.Remove(item)">
                                        <LucideIcon Name="x" Size="14" />
                                    </BbButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        @if (cart.Any())
        {
            <div style="padding: var(--space-4); border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: var(--space-3); flex-shrink: 0;">
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div style="padding: var(--space-2) var(--space-3); border-radius: var(--radius); background-color: var(--success-muted); border: 1px solid var(--success-border); font-size: var(--text-sm); color: var(--success-muted-foreground);">
                        @statusMessage
                    </div>
                }
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground);">Total</span>
                    <span style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--primary);">₱@TotalAmount.ToString("N2")</span>
                </div>
                <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="Checkout" Disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <BbSpinner Size="SpinnerSize.Small" />
                        <span>Processing...</span>
                    }
                    else
                    {
                        <LucideIcon Name="check" Size="16" />
                        <span>Confirm Sale</span>
                    }
                </BbButton>
            </div>
        }
    </div>

</div>

@code {
    private List<Product> allProducts = new();
    private List<string> categories = new();
    private List<CartItem> cart = new();
    private string? selectedCategory;
    private string searchTerm = "";
    private bool isProcessing = false;
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        allProducts = await Context.Products.AsNoTracking().ToListAsync();
        // Extract unique categories from your product list
        categories = allProducts
            .Select(p => p.Category)
            .Where(c => !string.IsNullOrEmpty(c))
            .Distinct()
            .OrderBy(c => c)
            .ToList();
    }

    private IEnumerable<Product> FilteredProducts => allProducts
        .Where(p => (string.IsNullOrEmpty(selectedCategory) || p.Category == selectedCategory) &&
                    (string.IsNullOrWhiteSpace(searchTerm) ||
                     p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                     p.Brand.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));

    private decimal TotalAmount => cart.Sum(i => i.Price * i.Quantity);

    private void AddToCart(Product p)
    {
        if (p.CurrentStock <= 0) return;
        statusMessage = null;
        var existing = cart.FirstOrDefault(i => i.ProductId == p.Id);
        if (existing != null) existing.Quantity++;
        else cart.Add(new CartItem { ProductId = p.Id, ProductName = p.Name, Price = p.Price, Quantity = 1 });
    }

    private async Task Checkout()
    {
        if (!cart.Any()) return;
        isProcessing = true;
        try
        {
            await SaleService.ProcessSaleAsync(cart);
            statusMessage = "Stock Deducted!";
            cart.Clear();
            await LoadData(); // Refresh stock counts
        }
        catch (Exception ex) { statusMessage = "Error: " + ex.Message; }
        finally { isProcessing = false; }
    }
}