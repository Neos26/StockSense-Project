        }

        .forecast-table td {
            padding: 12px 10px;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
            color: var(--foreground);
        }

    .brand-item {
        margin-bottom: 0.75rem;
        padding: 12px;
        background: rgba(0,0,0,0.2);
        border: 1px solid var(--border);
        border-radius: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .brand-name {
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--foreground);
    }

    .brand-val {
        font-weight: 900;
