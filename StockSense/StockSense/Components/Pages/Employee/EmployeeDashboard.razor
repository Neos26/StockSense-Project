    }

    @@media (min-width: 1024px) {
        .analytics-main-grid {
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        }
    }

    .analytics-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.25rem;
    }

    .analytics-title {
        font-size: 0.85rem;
        font-weight: 800;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
        text-transform: uppercase;
        color: var(--muted-foreground);
    }

    .table-scroll {
        overflow-x: auto;
    }

    .forecast-table {
        width: 100%;
        border-collapse: collapse;
