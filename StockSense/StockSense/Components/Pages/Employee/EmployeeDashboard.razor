@page "/Dashboard"
@layout AdminLayout
@using StockSense.Shared
@using StockSense.shared
@using StockSense.Services
@using StockSense.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.IO
@using System.Linq
@inject ApplicationDbContext Context
@inject StockSensePredictionService PredictionService
@inject NavigationManager NavManager
@inject IJSRuntime JS
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee, Admin")]

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <div class="fixed inset-0 bg-background flex flex-col justify-center items-center z-[9999]">
        <BbSpinner Size="SpinnerSize.Large" />
        <div class="mt-5 text-center">
            <h2 class="text-primary font-extrabold tracking-[2px] m-0">STOCK SENSE AI</h2>
            <p class="text-muted-foreground text-[0.7rem] uppercase m-0 mt-1">Syncing Intelligence Models...</p>
        </div>
    </div>
}

@* --- BLAZOR ONLY TOAST --- *@
@if (!string.IsNullOrEmpty(toastMessage))
{
    <div class="fixed bottom-6 right-6 z-[10001] flex items-center gap-2 px-4 py-3 rounded-lg border shadow-md animate-[slideInUp_0.3s_ease-out]
                @(toastType == "error" ? "bg-destructive-muted border-destructive-border text-destructive-muted-foreground" : 
                  toastType == "success" ? "bg-success-muted border-success-border text-success-muted-foreground" : 
                  "bg-info-muted border-info-border text-info-muted-foreground")">
        <span class="text-sm font-semibold uppercase">@toastMessage</span>
    </div>
}

<div class="animate-[fadeIn_0.4s_ease-in] p-4 md:p-6" style="display: @(isLoading ? "none" : "block");">

    @* --- TOP HEADER --- *@
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-6 gap-4">
        <div>
            <h1 class="text-2xl font-bold text-foreground m-0">Operational Intelligence</h1>
            <p class="text-sm text-muted-foreground m-0">Real-time heuristics & ML pattern recognition</p>
        </div>

        <div class="flex flex-col sm:flex-row w-full md:w-auto gap-4 bg-card border border-border rounded-lg px-4 py-3 items-start sm:items-center">
            <div class="flex flex-col gap-1 w-full sm:w-auto">
                <label class="text-[0.65rem] font-bold text-primary uppercase tracking-wide">Target Forecast</label>
                <div class="flex items-center gap-2 w-full">
                    <input type="range" min="1" max="12" @bind="simulationMonth" @bind:event="oninput" @onchange="RunFullAnalysis" class="accent-primary w-[100px] flex-1" />
                    <span class="font-bold text-sm min-w-[70px] text-foreground">@GetMonthName(simulationMonth)</span>

                    <select value="@currentSimYear" @onchange="HandleYearChange" class="bg-background text-foreground border border-border rounded-lg py-1 px-2 font-bold text-sm cursor-pointer ml-auto">
                        <option value="2025">2025</option>
                        <option value="2026">2026</option>
                        <option value="2027">2027</option>
                    </select>
                </div>
            </div>
            <div class="hidden sm:block w-[1px] h-[30px] bg-border"></div>
            <BbButton Variant="ButtonVariant.Outline" OnClick="HandleRetrain" Disabled="@isRetraining" Class="w-full sm:w-auto justify-center">
                @if (isRetraining)
                {
                    <BbSpinner Size="SpinnerSize.Small" />
                }
                else
                {
                    <LucideIcon Name="refresh-cw" Size="14" />
                }
                <span class="ml-2">Refresh AI</span>
            </BbButton>
        </div>
    </div>

    @* --- TOP KPI LABELS --- *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        <div class="bg-card border border-border rounded-lg p-4">
            <div class="text-muted-foreground text-xs font-bold uppercase tracking-wide mb-1">Inventory Value</div>
            <div class="text-2xl font-black text-foreground">₱@totalValue.ToString("N0")</div>
        </div>

        <div class="bg-card border border-border rounded-lg p-4">
            <div class="text-primary text-xs font-bold uppercase tracking-wide mb-1">AI Coverage</div>
            <div class="text-2xl font-black text-primary">@forecastCoverage%</div>
        </div>

        <div class="bg-card border border-border rounded-lg p-4">
            <div class="text-success text-xs font-bold uppercase tracking-wide mb-1">Est. Demand</div>
            <div class="text-2xl font-black text-success">@totalPredictedUnits</div>
        </div>
    </div>

    @* --- CRITICAL INVENTORY (SINGLE ROW) --- *@
    <div class="bg-card border border-border rounded-lg mb-6 overflow-hidden">
        <div class="p-4 border-b border-border flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="bg-destructive-muted text-destructive p-2.5 rounded-lg">
                    <LucideIcon Name="triangle-alert" Size="20" />
                </div>
                <div>
                    <h3 class="text-base font-semibold m-0 text-foreground">Critical Inventory Levels</h3>
                    <p class="text-sm text-muted-foreground m-0 hidden sm:block">Stock at or below reorder threshold</p>
                </div>
            </div>
            <div class="text-right">
                <div class="text-2xl font-black text-destructive">@allLowStockProducts.Count</div>
                <div class="text-[0.65rem] text-muted-foreground font-bold uppercase">SKUs Affected</div>
            </div>
        </div>

        <div class="p-4 flex gap-4 overflow-x-auto bg-muted/50 custom-scrollbar">
            @foreach (var item in allLowStockProducts.Take(5))
            {
                <div class="flex-none w-[260px] sm:w-[280px] px-4 py-3 bg-background border border-border rounded-lg flex justify-between items-center">
                    <div class="min-w-0 flex-1 pr-3">
                        <div class="font-bold text-sm text-foreground whitespace-nowrap overflow-hidden text-ellipsis">@item.Name</div>
                        <div class="text-xs text-muted-foreground">@item.Brand</div>
                    </div>
                    <div class="text-right">
                        <div class="text-sm font-bold text-destructive">@item.CurrentStock</div>
                        <div class="text-[0.6rem] text-muted-foreground uppercase">Qty</div>
                    </div>
                </div>
            }
        </div>

        <div class="p-3 px-4 bg-muted border-t border-border flex justify-end">
            <BbButton Variant="ButtonVariant.Ghost" OnClick="() => showCriticalModal = true" Class="text-xs font-bold">
                SEE ALL & MANAGE <LucideIcon Name="chevron-right" Size="14" Class="ml-1" />
            </BbButton>
        </div>
    </div>

    @* --- MAIN ANALYTICS GRID --- *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="bg-card border border-border rounded-lg p-5 flex flex-col">
            <h3 class="text-sm font-bold mb-4 flex items-center gap-2 uppercase text-muted-foreground">
                <LucideIcon Name="trending-up" Size="18" Class="text-primary" /> Top SKU Forecast (@currentSimYear)
            </h3>
            <div class="overflow-x-auto flex-1">
                <table class="w-full border-collapse min-w-[300px]">
                    <thead>
                        <tr>
                            <th class="text-left text-muted-foreground text-xs border-b border-border uppercase p-2.5">Product</th>
                            <th class="text-center text-muted-foreground text-xs border-b border-border uppercase p-2.5">Confidence</th>
                            <th class="text-right text-muted-foreground text-xs border-b border-border uppercase p-2.5">Prediction</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (topForecasts == null || !topForecasts.Any())
                        {
                            <tr>
                                <td colspan="3" class="p-4 text-center text-sm text-muted-foreground">No forecast data available.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in topForecasts)
                            {
                                <tr>
                                    <td class="p-2.5 border-b border-border text-sm text-foreground font-bold">@p.Name</td>
                                    <td class="p-2.5 border-b border-border text-sm text-center">
                                        <span class="px-2 py-0.5 rounded text-[0.65rem] font-bold text-white @(p.Confidence > 80 ? "bg-success" : "bg-warning text-warning-foreground")">
                                            @p.Confidence%
                                        </span>
                                    </td>
                                    <td class="p-2.5 border-b border-border text-sm text-foreground text-right font-bold">
                                        @p.OrderQty <small class="text-muted-foreground font-normal">pcs</small>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="bg-card border border-border rounded-lg p-5 flex flex-col">
            <h3 class="text-sm font-bold mb-4 flex items-center gap-2 uppercase text-muted-foreground">
                <LucideIcon Name="award" Size="18" Class="text-info" /> Brand Analytics
            </h3>
            <div class="flex-1 overflow-y-auto">
                @if (brandPerformances == null || !brandPerformances.Any())
                {
                    <div class="p-4 text-center text-sm text-muted-foreground">No brand data available.</div>
                }
                else
                {
                    @foreach (var brand in brandPerformances)
                    {
                        <div class="mb-3 p-3 bg-muted/50 border border-border rounded-lg flex justify-between items-center">
                            <div>
                                <div class="font-bold text-sm text-foreground">@brand.BrandName</div>
                                <div class="text-xs text-muted-foreground">AI Demand: <strong class="text-foreground">@brand.PredictedUnits units</strong></div>
                            </div>
                            <div class="font-black text-primary">₱@brand.TotalValue.ToString("N0")</div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="bg-card border border-border rounded-lg p-5 flex flex-col">
            <h3 class="text-sm font-bold mb-4 flex items-center gap-2 uppercase text-muted-foreground">
                <LucideIcon Name="pie-chart" Size="18" Class="text-success" /> Demand by Category
            </h3>
            <div class="flex-1 overflow-y-auto">
                @if (categoryVolumes == null || !categoryVolumes.Any())
                {
                    <div class="p-4 text-center text-sm text-muted-foreground">No category data available.</div>
                }
                else
                {
                    @foreach (var cat in categoryVolumes)
                    {
                        <div class="mb-4">
                            <div class="flex justify-between text-xs mb-1.5 color-foreground">
                                <span class="text-foreground font-medium">@cat.Category</span>
                                <span class="text-muted-foreground font-bold">@cat.Percentage.ToString("F1")%</span>
                            </div>
                            <div class="bg-border h-1.5 rounded-full overflow-hidden">
                                <div class="bg-primary h-full rounded-full transition-all duration-1000 ease-out" style="width: @cat.Percentage%;"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@* --- MODAL --- *@
@if (showCriticalModal)
{
    <div class="fixed inset-0 bg-background/80 backdrop-blur-sm flex justify-center items-center z-[10000] p-4">
        <div class="bg-card border border-border w-full max-w-3xl max-h-[90vh] rounded-lg flex flex-col overflow-hidden animate-[modalIn_0.3s_ease-out] shadow-xl">
            <div class="p-4 md:p-6 border-b border-border flex justify-between items-center bg-card">
                <div>
                    <h2 class="text-xl font-bold text-foreground m-0">Critical Stock Report</h2>
                    <p class="text-sm text-muted-foreground m-0 mt-1">Full overview of items requiring immediate restock</p>
                </div>
                <button @onclick="() => showCriticalModal = false" class="bg-transparent border-none text-muted-foreground hover:text-foreground text-2xl cursor-pointer transition-colors">&times;</button>
            </div>
            
            <div class="p-4 md:p-6 overflow-y-auto flex-1 bg-muted/30">
                <div class="overflow-x-auto">
                    <table class="w-full border-collapse min-w-[400px]">
                        <thead>
                            <tr>
                                <th class="text-left text-muted-foreground text-xs border-b border-border uppercase p-2.5">Product Name</th>
                                <th class="text-left text-muted-foreground text-xs border-b border-border uppercase p-2.5">Brand</th>
                                <th class="text-center text-muted-foreground text-xs border-b border-border uppercase p-2.5">Stock</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in allLowStockProducts)
                            {
                                <tr class="hover:bg-muted/50 transition-colors">
                                    <td class="p-3 border-b border-border text-sm text-foreground font-bold">@item.Name</td>
                                    <td class="p-3 border-b border-border text-sm text-muted-foreground">@item.Brand</td>
                                    <td class="p-3 border-b border-border text-sm text-center text-destructive font-bold">@item.CurrentStock</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="p-4 md:p-6 border-t border-border flex justify-end bg-card">
                <BbButton Variant="ButtonVariant.Default" OnClick="OrderAllCritical" Class="w-full sm:w-auto">ORDER ALL CRITICAL</BbButton>
            </div>
        </div>
    </div>
}

<style>
    /* Custom scrollbar retained because Tailwind v4 doesn't support it natively without plugins */
    .custom-scrollbar::-webkit-scrollbar {
        height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: var(--muted-foreground);
    }

    /* Keyframes for animations */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes slideInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes modalIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

@code {
    private bool isLoading = true;
    private bool isRetraining = false;
    private bool showCriticalModal = false;
    private List<Product> allProductsCached = new();
    private int simulationMonth = DateTime.Now.Month;
    private int currentSimYear = 2026;
    private decimal totalValue = 0;
    private int totalPredictedUnits = 0;
    private int forecastCoverage = 0;

    // Toast States
    private string toastMessage = "";
    private string toastType = "info";

    private List<Product> allLowStockProducts = new();
    private List<TopProductForecast> topForecasts = new();
    private List<CategoryVolume> categoryVolumes = new();
    private List<BrandPerformance> brandPerformances = new();

    private string GetMonthName(int month) => new DateTime(2026, month, 1).ToString("MMMM");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            allProductsCached = await Context.Products.AsNoTracking().ToListAsync();
            isLoading = false;
            await RunFullAnalysis();
        }
        catch { isLoading = false; }
    }

    private async Task RunFullAnalysis()
    {
        totalValue = allProductsCached.Sum(p => p.Price * p.CurrentStock);
        allLowStockProducts = allProductsCached.Where(p => p.CurrentStock <= p.ReorderTarget).OrderBy(p => p.CurrentStock).ToList();

        topForecasts.Clear();
        var tempCategoryData = new Dictionary<string, int>();
        var tempBrandData = new Dictionary<string, BrandPerformanceTemp>();
        totalPredictedUnits = 0;

        int processedCount = 0;
        int totalToProcess = allProductsCached.Count;

        foreach (var chunk in allProductsCached.Chunk(25))
        {
            foreach (var p in chunk)
            {
                var ai = PredictionService.GetPredictiveOrderQty(p, simulationMonth, currentSimYear);

                var cat = p.Category ?? "General";
                var brand = p.Brand ?? "Generic";

                if (!tempBrandData.ContainsKey(brand)) tempBrandData[brand] = new BrandPerformanceTemp();
                tempBrandData[brand].TotalValue += (p.Price * p.CurrentStock);

                if (ai.FinalOrderQty > 0)
                {
                    totalPredictedUnits += ai.FinalOrderQty;
                    topForecasts.Add(new TopProductForecast { Name = p.Name, OrderQty = ai.FinalOrderQty, Confidence = (int)ai.ConfidenceScore });
                    tempCategoryData[cat] = tempCategoryData.GetValueOrDefault(cat) + ai.FinalOrderQty;
                    tempBrandData[brand].PredictedUnits += ai.FinalOrderQty;
                }
                processedCount++;
            }
            forecastCoverage = (int)((double)processedCount / totalToProcess * 100);
            UpdateAnalyticsUI(tempCategoryData, tempBrandData);
            StateHasChanged();
            await Task.Delay(1);
        }
    }

    private void UpdateAnalyticsUI(Dictionary<string, int> catData, Dictionary<string, BrandPerformanceTemp> brandData)
    {
        topForecasts = topForecasts.GroupBy(x => x.Name)
            .Select(g => new TopProductForecast { Name = g.Key, OrderQty = g.Max(x => x.OrderQty), Confidence = g.Max(x => x.Confidence) })
            .OrderByDescending(x => x.OrderQty).Take(6).ToList();

        int totalUnits = catData.Values.Sum();
        categoryVolumes = catData.Select(c => new CategoryVolume { Category = c.Key, Percentage = totalUnits > 0 ? (double)c.Value / totalUnits * 100 : 0 })
            .OrderByDescending(x => x.Percentage).Take(5).ToList();

        brandPerformances = brandData.Select(b => new BrandPerformance { BrandName = b.Key, TotalValue = b.Value.TotalValue, PredictedUnits = b.Value.PredictedUnits })
            .OrderByDescending(x => x.PredictedUnits).Take(5).ToList();
    }

    private async Task HandleRetrain()
    {
        isRetraining = true;
        toastMessage = "Syncing Intelligence Models...";
        toastType = "info";
        StateHasChanged();

        try
        {
            var history = await Context.SalesHistory.Select(s => new StockSense.MLModel.ModelInput
            {
                ProductID = s.ProductID,
                ProductName = s.ProductName,
                Brand = s.Brand,
                Category = s.Category,
                MonthNum = s.MonthNum,
                Year = s.Year,
                QtySold = s.QtySold
            }).ToListAsync();

            string path = Path.Combine(AppContext.BaseDirectory, "MLModel.mlnet");
            await Task.Run(() => MLModel.Train(path, history));
            await RunFullAnalysis();

            toastMessage = "AI Model Synchronized Successfully!";
            toastType = "success";
        }
        catch
        {
            toastMessage = "Sync Failed: Check Data Integrity";
            toastType = "error";
        }
        finally
        {
            isRetraining = false;
            StateHasChanged();

            await Task.Delay(3000);
            toastMessage = "";
            StateHasChanged();
        }
    }

    private async Task HandleYearChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int selectedYear))
        {
            currentSimYear = selectedYear;
            await RunFullAnalysis();
        }
    }

    private void OrderAllCritical() => NavManager.NavigateTo("/admin/orderslips?orderAll=true");

    public class TopProductForecast { public string Name { get; set; } = ""; public int OrderQty { get; set; } public int Confidence { get; set; } }
    public class CategoryVolume { public string Category { get; set; } = ""; public double Percentage { get; set; } }
    public class BrandPerformance { public string BrandName { get; set; } = ""; public decimal TotalValue { get; set; } public int PredictedUnits { get; set; } }
    private class BrandPerformanceTemp { public decimal TotalValue { get; set; } public int PredictedUnits { get; set; } }
}