@page "/Dashboard"
@layout AdminLayout
@using StockSense.Shared
@using StockSense.shared
@using StockSense.Services
@using StockSense.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Context
@inject StockSensePredictionService PredictionService
@inject NavigationManager NavManager
@inject IJSRuntime JS
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee, Admin")]

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: var(--background); display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 9999; gap: var(--space-4);">
        <BbSpinner Size="SpinnerSize.Large" />
        <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-1);">
            <span style="font-weight: 800; font-style: italic; font-size: 1.5rem; color: var(--primary); letter-spacing: 0.05em;">STOCK<br />SENSE</span>
            <p style="color: var(--muted-foreground); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">Analyzing AI Forecasts...</p>
        </div>
    </div>
}

<div class="dashboard-container" style="display: @(isLoading ? "none" : "block"); animation: fadeIn 0.4s ease-in;">

    @* --- HEADER & FILTERS --- *@
    <div class="header-section">
        <div class="title-block">
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Operational Intelligence</h1>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Real-time inventory heuristics and AI demand modeling.</p>
        </div>

        <div class="filter-panel">
            <BbButton Variant="ButtonVariant.Outline" OnClick="HandleRetrain" Disabled="@isRetraining" style="height: 36px;">
                @if (isRetraining)
                {
                    <BbSpinner Size="SpinnerSize.Small" />
                }
                else
                {
                    <LucideIcon Name="refresh-cw" Size="14" style="margin-right: 4px;" />
                }
                Retrain AI
            </BbButton>

            <div class="vertical-divider"></div>

            <div class="filter-item slider-item">
                <label>Target Forecast: @GetMonthName(simulationMonth)</label>
                <input type="range" min="1" max="12" @bind="simulationMonth" @bind:event="oninput" @onchange="ApplyFilters" />
            </div>

            <div class="vertical-divider"></div>

            <div class="filter-item">
                <label>Category</label>
                <select @bind="SelectedCategory" @bind:after="ApplyFilters">
                    <option value="">All Categories</option>
                    @foreach (var cat in availableCategories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>

            <div class="filter-item">
                <label>Brand</label>
                <select @bind="SelectedBrand" @bind:after="ApplyFilters">
                    <option value="">All Brands</option>
                    @foreach (var brand in availableBrands)
                    {
                        <option value="@brand">@brand</option>
                    }
                </select>
            </div>

            <BbButton Variant="ButtonVariant.Default" OnClick='() => NavManager.NavigateTo("/admin/orderslips")' Class="ordering-btn">
                <LucideIcon Name="arrow-right" Size="14" />
                Predictive Ordering
            </BbButton>
        </div>
    </div>

    @* --- KPI CARDS --- *@
    <div class="kpi-grid">
        <BbCard>
            <BbCardHeader><BbCardDescription>Inventory Value</BbCardDescription></BbCardHeader>
            <BbCardContent><span class="kpi-value">₱@totalValue.ToString("N0")</span></BbCardContent>
        </BbCard>

        <BbCard Class="card-destructive">
            <BbCardHeader>
                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                    <BbCardDescription Class="text-destructive">Critical Stock Levels</BbCardDescription>
                </div>
            </BbCardHeader>
            <BbCardContent>
                <span class="kpi-value" style="color: var(--destructive);">@allLowStockProducts.Count</span>
                <span class="kpi-subtext">For @GetMonthName(simulationMonth)</span>
            </BbCardContent>
        </BbCard>

        <BbCard>
            <BbCardHeader><BbCardDescription>Forecast Coverage</BbCardDescription></BbCardHeader>
            <BbCardContent><span class="kpi-value" style="color: var(--primary);">@forecastCoverage%</span></BbCardContent>
        </BbCard>
        <BbCard>
            <BbCardHeader><BbCardDescription>Est. Demand</BbCardDescription></BbCardHeader>
            <BbCardContent>
                <span class="kpi-value" style="color: #10b981;">@totalPredictedUnits</span>
                <span class="kpi-subtext">@GetMonthName(simulationMonth)</span>
            </BbCardContent>
        </BbCard>
    </div>

    @* --- ANALYTICS SECTIONS --- *@
    <div class="main-analytics-grid">
        <div class="analytics-card">
            <div class="card-header">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <LucideIcon Name="trending-up" Size="18" Color="var(--primary)" />
                    <h3>Top Demand: @GetMonthName(simulationMonth)</h3>
                </div>
            </div>
            <div class="table-container">
                @* UPDATED: Added wide-table class here *@
                <table class="wide-table">
                    <thead>
                        <tr>
                            <th>SKU Details</th>
                            <th style="text-align: center;">Confidence</th>
                            <th style="text-align: right;">Predicted Order</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!topForecasts.Any())
                        {
                            <tr><td colspan="3" class="empty-state">No predictions for this month.</td></tr>
                        }
                        @foreach (var p in topForecasts)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600;">@p.Name</div>
                                    <div style="font-size: 11px; color: var(--muted-foreground);">@p.Brand &bull; @p.Category</div>
                                </td>
                                <td style="text-align: center;">
                                    <span class="confidence-badge @(p.Confidence > 75 ? "high" : "med")">@p.Confidence%</span>
                                </td>
                                <td style="text-align: right; font-weight: 800;">@p.OrderQty units</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="analytics-card alert-border">
            <div class="card-header alert-bg">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <LucideIcon Name="alert-triangle" Size="18" Color="var(--destructive)" />
                    <h3 style="color: var(--destructive);">Critical Stock Levels</h3>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span class="badge-destructive">@allLowStockProducts.Count</span>
                    <button @onclick="() => showCriticalStockModal = true" style="background: none; border: none; color: var(--primary); font-size: 11px; font-weight: 700; cursor: pointer; text-decoration: underline; padding: 0;">View All</button>
                </div>
            </div>
            <div class="table-container">
                @if (!allLowStockProducts.Any())
                {
                    <div class="healthy-state">
                        <LucideIcon Name="check-circle" Size="24" Color="#10b981" />
                        <p>No shortages expected.</p>
                    </div>
                }
                @* UPDATED: Left this table WITHOUT the wide-table class so it doesn't force a scrollbar *@
                <table>
                    <tbody>
                        @foreach (var p in allLowStockProducts.Take(6))
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600;">@p.Name</div>
                                    <div style="color: var(--muted-foreground); font-size: 11px;">Stock: <span style="color: var(--destructive); font-weight: 700;">@p.CurrentStock left</span></div>
                                </td>
                                <td style="text-align: right;">
                                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="@(() => NavManager.NavigateTo($"/admin/orderslips?productId={p.Id}"))">Order</BbButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="analytics-card">
            <div class="card-header">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <LucideIcon Name="bar-chart-2" Size="18" Color="var(--primary)" />
                    <h3>Brand Analytics</h3>
                </div>
            </div>
            <div class="table-container">
                @* UPDATED: Added wide-table class here *@
                <table class="wide-table">
                    <thead>
                        <tr>
                            <th>Brand</th>
                            <th style="text-align: right;">Current Value</th>
                            <th style="text-align: right;">Demand (@GetMonthName(simulationMonth))</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!brandPerformances.Any())
                        {
                            <tr><td colspan="3" class="empty-state">No data available.</td></tr>
                        }
                        @foreach (var bp in brandPerformances)
                        {
                            <tr>
                                <td style="font-weight: 600;">@bp.BrandName</td>
                                <td style="text-align: right;">₱@bp.TotalValue.ToString("N0")</td>
                                <td style="text-align: right; color: #10b981; font-weight: 600;">@bp.PredictedUnits</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="analytics-card" style="padding: 1.5rem;">
            <h3 style="font-size: var(--text-sm); font-weight: 600; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 8px;">
                <LucideIcon Name="pie-chart" Size="18" /> Demand by Category
            </h3>
            <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                @if (!categoryVolumes.Any())
                {
                    <div class="empty-state">No data available.</div>
                }
                @foreach (var cat in categoryVolumes)
                {
                    <div>
                        <div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 6px; font-weight: 600;">
                            <span>@cat.Category</span>
                            <span style="color: var(--primary);">@cat.Units units</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: @cat.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* --- FULL CRITICAL STOCK MODAL --- *@
@if (showCriticalStockModal)
{
    <div class="modal-backdrop" @onclick="() => showCriticalStockModal = false">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>All Critical Stock Levels (@GetMonthName(simulationMonth))</h3>
                <BbButton Variant="ButtonVariant.Ghost" OnClick="() => showCriticalStockModal = false">
                    <LucideIcon Name="x" Size="20" />
                </BbButton>
            </div>
            <div class="modal-body">
                <div class="table-container">
                    <table class="modal-table wide-table">
                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th>Brand</th>
                                <th>Current Stock</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in allLowStockProducts)
                            {
                                <tr>
                                    <td>@p.Name</td>
                                    <td style="color: var(--muted-foreground);">@p.Brand</td>
                                    <td style="color: var(--destructive); font-weight: 700;">@p.CurrentStock Units</td>
                                    <td>
                                        <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" OnClick="@(() => NavManager.NavigateTo($"/admin/orderslips?productId={p.Id}"))">Create Order</BbButton>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@* --- TOAST NOTIFICATION COMPONENT --- *@
@if (isToastVisible)
{
    <div class="custom-toast @(isToastError ? "toast-error" : "toast-success")">
        <LucideIcon Name="@(isToastError ? "alert-circle" : "check-circle")" Size="18" />
        <span>@toastMessage</span>
    </div>
}

<style>
    /* ... RESPONSIVE GRID UPDATES ... */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .main-analytics-grid {
        display: grid;
        gap: 1.5rem;
    }

    /* Desktop View */
    @@media (min-width: 1024px) {
        .main-analytics-grid {
            grid-template-columns: 2fr 1fr;
        }
    }

    /* Tablet and Mobile View */
    @@media (max-width: 1023px) {
        .main-analytics-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ... TABLE RESPONSIVENESS UPDATES ... */
    .table-container {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
    }

        .table-container::-webkit-scrollbar {
            height: 6px;
        }

        .table-container::-webkit-scrollbar-track {
            background: transparent;
        }

        .table-container::-webkit-scrollbar-thumb {
            background-color: var(--border);
            border-radius: 10px;
        }

        .table-container.scrollable {
            max-height: 350px;
            overflow-y: auto;
        }

    table {
        width: 100%;
        /* UPDATED: Removed min-width from here so smaller tables fit naturally */
        border-collapse: collapse;
        font-size: var(--text-sm);
    }

    /* UPDATED: Created a specific class for tables that need horizontal sliding */
    .wide-table {
        min-width: 550px;
    }

    th {
        text-align: left;
        padding: 12px 16px;
        color: var(--muted-foreground);
        border-bottom: 1px solid var(--border);
        font-weight: 500;
        white-space: nowrap;
    }

    td {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }

    /* ... EXISTING STYLES BELOW ... */
    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .filter-panel {
        display: flex;
        align-items: center;
        gap: 1rem;
        background-color: var(--card);
        padding: 10px 20px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        flex-wrap: wrap;
        width: auto;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

        .filter-item label {
            font-size: 11px;
            font-weight: 600;
            color: var(--muted-foreground);
            text-transform: uppercase;
        }

        .filter-item select {
            padding: 6px 10px;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            background-color: var(--background);
            color: var(--foreground);
            font-size: var(--text-sm);
            outline: none;
            min-width: 140px;
        }

    .slider-item label {
        color: var(--primary);
        font-weight: 800;
    }

    .slider-item input {
        width: 100%;
        cursor: pointer;
        accent-color: var(--primary);
    }

    .analytics-card {
        background-color: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .card-header {
        padding: 1rem;
        border-bottom: 1px solid var(--border);
        background-color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .card-header h3 {
            font-size: var(--text-sm);
            font-weight: 600;
            margin: 0;
        }

    .kpi-value {
        font-size: var(--text-2xl);
        font-weight: 800;
        color: var(--foreground);
