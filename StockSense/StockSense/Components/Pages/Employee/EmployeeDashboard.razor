        border-radius: 99px;
    }

    .healthy-state {
        padding: 2rem;
        text-align: center;
        color: var(--muted-foreground);
        font-size: var(--text-sm);
    }

    .empty-state {
        padding: 16px;
        text-align: center;
        color: var(--muted-foreground);
    }

    .vertical-divider {
        width: 1px;
        height: 32px;
        background-color: var(--border);
    }

    .badge-destructive {
        background-color: var(--destructive);
        color: white;
        border-radius: 99px;
        padding: 2px 8px;
        font-size: 11px;
        font-weight: 800;
    }

    /* Modal Styles */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        z-index: 10000;
        display: flex;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(4px);
    }

    .modal-content {
        background: var(--card);
        width: 90%;
        max-width: 800px;
        max-height: 80vh;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-lg);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .modal-header {
        padding: 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header h3 {
            margin: 0;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--foreground);
        }

    .modal-body {
        padding: 0;
        overflow-y: auto;
        flex: 1;
    }

    .modal-table th {
        background: var(--muted);
        position: sticky;
        top: 0;
    }

    /* Custom Toast Styles */
    .custom-toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        padding: 12px 20px;
        border-radius: var(--radius);
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: 12px;
        z-index: 10500;
        animation: slideInUp 0.3s ease-out;
        font-size: var(--text-sm);
        font-weight: 600;
        color: white;
    }

    .toast-success {
        background-color: #10b981;
    }

    .toast-error {
        background-color: var(--destructive);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideInUp {
        from {
            transform: translateY(100%);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>

@code {
    private bool isLoading = true;
    private bool isRetraining = false;
    private bool showCriticalStockModal = false;

    // Toast Variables
    private bool isToastVisible = false;
    private string toastMessage = "";
    private bool isToastError = false;

    private List<Product> allProductsCached = new();
    private string SelectedCategory { get; set; } = "";
    private string SelectedBrand { get; set; } = "";
    private int simulationMonth = DateTime.Now.Month;
    private List<string> availableCategories = new();
    private List<string> availableBrands = new();
    private string GetMonthName(int month) => new DateTime(2026, month, 1).ToString("MMMM");

    private decimal totalValue = 0;
    private int totalPredictedUnits = 0;
    private int forecastCoverage = 0;

    private List<Product> allLowStockProducts = new();
    private List<TopProductForecast> topForecasts = new();
    private List<CategoryVolume> categoryVolumes = new();
    private List<BrandPerformance> brandPerformances = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            allProductsCached = await Context.Products.AsNoTracking().ToListAsync();
            availableCategories = allProductsCached.Where(p => !string.IsNullOrEmpty(p.Category)).Select(p => p.Category).Distinct().OrderBy(c => c).ToList();
            availableBrands = allProductsCached.Where(p => !string.IsNullOrEmpty(p.Brand)).Select(p => p.Brand).Distinct().OrderBy(b => b).ToList();
            ApplyFilters();
        }
        catch (Exception ex) { Console.WriteLine($"Dashboard Error: {ex.Message}"); }
        finally { isLoading = false; }
    }

    // Custom Toast Handler
    private async Task ShowToast(string message, bool isError = false)
    {
        toastMessage = message;
        isToastError = isError;
        isToastVisible = true;
        StateHasChanged();

        await Task.Delay(4000); // Hide after 4 seconds

        isToastVisible = false;
        StateHasChanged();
    }

    private async Task HandleRetrain()
    {
        try
        {
            isRetraining = true;
            StateHasChanged();
            var dbData = await Context.SalesHistory
                .Select(s => new MLModel.ModelInput { ProductID = s.ProductID, ProductName = s.ProductName, Brand = s.Brand, Category = s.Category, QtySold = s.QtySold, MonthNum = s.MonthNum })
                .ToListAsync();

            if (!dbData.Any())
            {
                await ShowToast("No historical data found in database.", true);
                return;
            }

            await Task.Run(() =>
            {
                string modelPath = Path.Combine(AppContext.BaseDirectory, "MLModel.mlnet");
                MLModel.Train(modelPath, dbData);
            });

            ApplyFilters();
            await ShowToast("AI Intelligence refreshed successfully.", false);
        }
        catch (Exception ex)
        {
            await ShowToast($"Error: {ex.Message}", true);
        }
        finally
        {
            isRetraining = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        var filteredQuery = allProductsCached.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(SelectedCategory)) filteredQuery = filteredQuery.Where(p => p.Category == SelectedCategory);
        if (!string.IsNullOrWhiteSpace(SelectedBrand)) filteredQuery = filteredQuery.Where(p => p.Brand == SelectedBrand);
        var filteredProducts = filteredQuery.ToList();

        totalPredictedUnits = 0;
        topForecasts.Clear();
        categoryVolumes.Clear();
        brandPerformances.Clear();
        totalValue = filteredProducts.Sum(p => p.Price * p.CurrentStock);

        allLowStockProducts = filteredProducts.Where(p =>
        {
            var ai = PredictionService.GetPredictiveOrderQty(p, simulationMonth, OrderStrategy.Normal);
            return p.CurrentStock <= (ai.PredictedDemand * 0.25) || p.CurrentStock <= 2;
        }).OrderBy(p => p.CurrentStock).ToList();

        int forecastedCount = 0;
        var tempCategoryUnits = new Dictionary<string, int>();
        var tempBrandData = new Dictionary<string, BrandPerformanceTemp>();

        foreach (var product in filteredProducts)
        {
            var ai = PredictionService.GetPredictiveOrderQty(product, simulationMonth, OrderStrategy.Normal);
            var cat = string.IsNullOrWhiteSpace(product.Category) ? "Other" : product.Category;
            var brand = string.IsNullOrWhiteSpace(product.Brand) ? "Unknown" : product.Brand;

            if (!tempBrandData.ContainsKey(brand)) tempBrandData[brand] = new BrandPerformanceTemp();
            tempBrandData[brand].TotalInventoryValue += (product.Price * product.CurrentStock);

            if (ai.FinalOrderQty > 0)
            {
                forecastedCount++;
                totalPredictedUnits += ai.FinalOrderQty;
                topForecasts.Add(new TopProductForecast { Name = product.Name, Brand = product.Brand, Category = product.Category, OrderQty = ai.FinalOrderQty, Confidence = (int)ai.ConfidenceScore });
                if (!tempCategoryUnits.ContainsKey(cat)) tempCategoryUnits[cat] = 0;
                tempCategoryUnits[cat] += ai.FinalOrderQty;
                tempBrandData[brand].PredictedUnits += ai.FinalOrderQty;
            }
        }

        forecastCoverage = filteredProducts.Count > 0 ? (int)((double)forecastedCount / filteredProducts.Count * 100) : 0;
        topForecasts = topForecasts.OrderByDescending(x => x.OrderQty).Take(5).ToList();

        int totalUnitsAcrossCategories = tempCategoryUnits.Values.Sum();
        if (totalUnitsAcrossCategories > 0)
        {
            foreach (var entry in tempCategoryUnits.OrderByDescending(x => x.Value).Take(5))
            {
                categoryVolumes.Add(new CategoryVolume { Category = entry.Key, Units = entry.Value, Percentage = (double)entry.Value / totalUnitsAcrossCategories * 100 });
            }
        }

        foreach (var brand in tempBrandData.OrderByDescending(b => b.Value.PredictedUnits).Take(5))
        {
            brandPerformances.Add(new BrandPerformance { BrandName = brand.Key, TotalValue = brand.Value.TotalInventoryValue, PredictedUnits = brand.Value.PredictedUnits });
        }
    }

    public class TopProductForecast { public string Name { get; set; } = ""; public string Brand { get; set; } = ""; public string Category { get; set; } = ""; public int OrderQty { get; set; } public int Confidence { get; set; } }
    public class CategoryVolume { public string Category { get; set; } = ""; public int Units { get; set; } public double Percentage { get; set; } }
    public class BrandPerformance { public string BrandName { get; set; } = ""; public decimal TotalValue { get; set; } public int PredictedUnits { get; set; } }
    private class BrandPerformanceTemp { public decimal TotalInventoryValue { get; set; } public int PredictedUnits { get; set; } }
}