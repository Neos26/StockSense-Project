    @@keyframes modalIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

@code {
    private bool isLoading = true;
    private bool isRetraining = false;
    private bool showCriticalModal = false;
    private List<Product> allProductsCached = new();
    private int simulationMonth = DateTime.Now.Month;
    private int currentSimYear = 2026;
    private decimal totalValue = 0;
    private int totalPredictedUnits = 0;
    private int forecastCoverage = 0;

    // Toast States
    private string toastMessage = "";
    private string toastType = "info";

    private List<Product> allLowStockProducts = new();
    private List<TopProductForecast> topForecasts = new();
    private List<CategoryVolume> categoryVolumes = new();
    private List<BrandPerformance> brandPerformances = new();

    private string GetMonthName(int month) => new DateTime(2026, month, 1).ToString("MMMM");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            allProductsCached = await Context.Products.AsNoTracking().ToListAsync();
            isLoading = false;
            await RunFullAnalysis();
        }
        catch { isLoading = false; }
    }

    private async Task RunFullAnalysis()
    {
        totalValue = allProductsCached.Sum(p => p.Price * p.CurrentStock);
        allLowStockProducts = allProductsCached.Where(p => p.CurrentStock <= p.ReorderTarget).OrderBy(p => p.CurrentStock).ToList();

        topForecasts.Clear();
        var tempCategoryData = new Dictionary<string, int>();
        var tempBrandData = new Dictionary<string, BrandPerformanceTemp>();
        totalPredictedUnits = 0;

        int processedCount = 0;
        int totalToProcess = allProductsCached.Count;

        foreach (var chunk in allProductsCached.Chunk(25))
        {
            foreach (var p in chunk)
            {
                var ai = PredictionService.GetPredictiveOrderQty(p, simulationMonth, currentSimYear);

                var cat = p.Category ?? "General";
                var brand = p.Brand ?? "Generic";

                if (!tempBrandData.ContainsKey(brand)) tempBrandData[brand] = new BrandPerformanceTemp();
                tempBrandData[brand].TotalValue += (p.Price * p.CurrentStock);

                if (ai.FinalOrderQty > 0)
                {
                    totalPredictedUnits += ai.FinalOrderQty;
                    topForecasts.Add(new TopProductForecast { Name = p.Name, OrderQty = ai.FinalOrderQty, Confidence = (int)ai.ConfidenceScore });
                    tempCategoryData[cat] = tempCategoryData.GetValueOrDefault(cat) + ai.FinalOrderQty;
                    tempBrandData[brand].PredictedUnits += ai.FinalOrderQty;
                }
                processedCount++;
            }
            forecastCoverage = (int)((double)processedCount / totalToProcess * 100);
            UpdateAnalyticsUI(tempCategoryData, tempBrandData);
            StateHasChanged();
            await Task.Delay(1);
        }
    }

    private void UpdateAnalyticsUI(Dictionary<string, int> catData, Dictionary<string, BrandPerformanceTemp> brandData)
    {
        topForecasts = topForecasts.GroupBy(x => x.Name)
            .Select(g => new TopProductForecast { Name = g.Key, OrderQty = g.Max(x => x.OrderQty), Confidence = g.Max(x => x.Confidence) })
            .OrderByDescending(x => x.OrderQty).Take(6).ToList();

        int totalUnits = catData.Values.Sum();
        categoryVolumes = catData.Select(c => new CategoryVolume { Category = c.Key, Percentage = totalUnits > 0 ? (double)c.Value / totalUnits * 100 : 0 })
            .OrderByDescending(x => x.Percentage).Take(5).ToList();

        brandPerformances = brandData.Select(b => new BrandPerformance { BrandName = b.Key, TotalValue = b.Value.TotalValue, PredictedUnits = b.Value.PredictedUnits })
            .OrderByDescending(x => x.PredictedUnits).Take(5).ToList();
    }

    private async Task HandleRetrain()
    {
        isRetraining = true;
        toastMessage = "Syncing Intelligence Models...";
        toastType = "info";
        StateHasChanged();

        try
        {
            var history = await Context.SalesHistory.Select(s => new StockSense.MLModel.ModelInput
            {
                ProductID = s.ProductID,
                ProductName = s.ProductName,
                Brand = s.Brand,
                Category = s.Category,
                MonthNum = s.MonthNum,
                Year = s.Year,
                QtySold = s.QtySold
            }).ToListAsync();

            string path = Path.Combine(AppContext.BaseDirectory, "MLModel.mlnet");
            await Task.Run(() => MLModel.Train(path, history));
            await RunFullAnalysis();

            toastMessage = "AI Model Synchronized Successfully!";
            toastType = "success";
        }
        catch
        {
            toastMessage = "Sync Failed: Check Data Integrity";
            toastType = "error";
        }
        finally
        {
            isRetraining = false;
            StateHasChanged();

            // Auto-hide after 3 seconds
            await Task.Delay(3000);
            toastMessage = "";
            StateHasChanged();
        }
    }

    private async Task HandleYearChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int selectedYear))
        {
            currentSimYear = selectedYear;
            await RunFullAnalysis();
        }
    }

