    }

    .critical-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .critical-title-group {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .icon-container-danger {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        padding: 10px;
        border-radius: 10px;
    }

    .stat-number {
        font-size: 1.5rem;
        font-weight: 900;
        color: #ef4444;
    }

    .stat-label {
        font-size: 0.6rem;
        color: var(--muted-foreground);
        font-weight: 700;
        text-transform: uppercase;
    }

    .critical-row-scroller {
