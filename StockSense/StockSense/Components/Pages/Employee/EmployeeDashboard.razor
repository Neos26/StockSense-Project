        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .kpi-value {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--foreground);
    }

    /* Critical Scroller */
    .critical-section {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        margin-bottom: 2.5rem;
