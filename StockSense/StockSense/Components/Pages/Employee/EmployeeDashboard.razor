@page "/Dashboard"
@layout AdminLayout
@using StockSense.Shared
@using StockSense.shared
@using StockSense.Services
@using StockSense.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.IO
@using System.Linq
@inject ApplicationDbContext Context
@inject StockSensePredictionService PredictionService
@inject NavigationManager NavManager
@inject IJSRuntime JS
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee, Admin")]

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <div class="loading-overlay">
        <BbSpinner Size="SpinnerSize.Large" />
        <div style="margin-top: 20px; text-align: center;">
            <h2 class="brand-title">STOCK SENSE AI</h2>
            <p class="loading-sub">Syncing Intelligence Models...</p>
        </div>
    </div>
}

@* --- BLAZOR ONLY TOAST --- *@
@if (!string.IsNullOrEmpty(toastMessage))
{
    <div class="custom-toast toast-@toastType">
        @toastMessage
    </div>
}

<div class="dashboard-container" style="display: @(isLoading ? "none" : "block");">

    @* --- HEADER SECTION --- *@
    <div class="header-section">
        <div class="title-group">
            <h1 class="main-title">Operational Intelligence</h1>
            <p class="subtitle">Real-time heuristics & ML pattern recognition</p>
        </div>

        <div class="control-card">
            <div class="forecast-controls">
                <label class="control-label">Target Forecast</label>
                <div class="control-inputs">
                    <input type="range" min="1" max="12" @bind="simulationMonth" @bind:event="oninput" @onchange="RunFullAnalysis" class="month-slider" />
                    <span class="month-display">@GetMonthName(simulationMonth)</span>

                    <select value="@currentSimYear" @onchange="HandleYearChange" class="year-select">
                        <option value="2025">2025</option>
                        <option value="2026">2026</option>
                        <option value="2027">2027</option>
                    </select>
                </div>
            </div>
            <div class="divider"></div>
            <BbButton Variant="ButtonVariant.Outline" OnClick="HandleRetrain" Disabled="@isRetraining" class="retrain-btn">
                @if (isRetraining)
                {
                    <BbSpinner Size="SpinnerSize.Small" />
                }
                else
                {
                    <LucideIcon Name="refresh-cw" Size="14" />
                }
                <span style="margin-left: 8px;">Refresh AI</span>
            </BbButton>
        </div>
    </div>

    @* --- TOP KPI LABELS --- *@
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-label">Inventory Value</div>
            <div class="kpi-value">₱@totalValue.ToString("N0")</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-label highlight">AI Coverage</div>
            <div class="kpi-value highlight">@forecastCoverage%</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-label success">Est. Demand</div>
            <div class="kpi-value success">@totalPredictedUnits</div>
        </div>
    </div>

    @* --- CRITICAL INVENTORY (SINGLE ROW) --- *@
    <div class="critical-section">
        <div class="critical-header">
            <div class="critical-title-group">
                <div class="icon-container-danger">
                </div>
                <div>
                    <h3 class="section-title">Critical Inventory Levels</h3>
                    <p class="section-subtitle">Stock at or below reorder threshold</p>
                </div>
            </div>
            <div class="critical-stats">
                <div class="stat-number">@allLowStockProducts.Count</div>
                <div class="stat-label">SKUs Affected</div>
            </div>
        </div>

        <div class="critical-row-scroller">
            @foreach (var item in allLowStockProducts.Take(5))
            {
                <div class="critical-item-card-row">
                    <div class="item-info">
                        <div class="item-name">@item.Name</div>
                        <div class="item-brand">@item.Brand</div>
                    </div>
                    <div class="item-qty">
                        <div class="qty-num">@item.CurrentStock</div>
                        <div class="qty-label">Qty</div>
                    </div>
                </div>
            }
        </div>

        <div class="critical-footer">
            <BbButton Variant="ButtonVariant.Ghost" OnClick="() => showCriticalModal = true" class="footer-btn">
                SEE ALL & MANAGE <LucideIcon Name="chevron-right" Size="14" style="margin-left: 5px;" />
            </BbButton>
        </div>
    </div>

    @* --- MAIN ANALYTICS GRID --- *@
    <div class="analytics-main-grid">

        <div class="analytics-card">
            <h3 class="analytics-title">
                <LucideIcon Name="trending-up" Size="18" Color="var(--primary)" /> Top SKU Forecast (@currentSimYear)
            </h3>
            <div class="table-scroll">
                <table class="forecast-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="center">Confidence</th>
                            <th class="right">Prediction</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in topForecasts)
                        {
                            <tr>
                                <td class="bold">@p.Name</td>
                                <td class="center">
                                    <span class="badge @(p.Confidence > 80 ? "badge-success" : "badge-warn")">@p.Confidence%</span>
                                </td>
                                <td class="right bold">@p.OrderQty <small class="muted">pcs</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="analytics-card">
            <h3 class="analytics-title">
                <LucideIcon Name="award" Size="18" Color="#3b82f6" /> Brand Analytics
            </h3>
            @foreach (var brand in brandPerformances)
            {
                <div class="brand-item">
                    <div>
                        <div class="brand-name">@brand.BrandName</div>
                        <div class="brand-sub">AI Demand: <strong>@brand.PredictedUnits units</strong></div>
                    </div>
                    <div class="brand-val">₱@brand.TotalValue.ToString("N0")</div>
                </div>
            }
        </div>

        <div class="analytics-card">
            <h3 class="analytics-title">
                <LucideIcon Name="pie-chart" Size="18" Color="#10b981" /> Demand by Category
            </h3>
            @foreach (var cat in categoryVolumes)
            {
                <div class="cat-item">
                    <div class="cat-label-row">
                        <span class="cat-name">@cat.Category</span>
                        <span class="cat-pct">@cat.Percentage.ToString("F1")%</span>
                    </div>
                    <div class="progress-bg">
                        <div class="progress-fill" style="width: @cat.Percentage%;"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* --- MODAL --- *@
@if (showCriticalModal)
{
    <div class="modal-backdrop">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h2 class="modal-title">Critical Stock Report</h2>
                    <p class="modal-subtitle">Full overview of items requiring immediate restock</p>
                </div>
                <button @onclick="() => showCriticalModal = false" class="close-btn">&times;</button>
            </div>
            <div class="modal-body">
                <table class="modal-table">
                    <thead>
                        <tr>
                            <th>Product Name</th>
                            <th>Brand</th>
                            <th class="center">Stock</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in allLowStockProducts)
                        {
                            <tr>
                                <td class="bold">@item.Name</td>
                                <td class="muted">@item.Brand</td>
                                <td class="center danger bold">@item.CurrentStock</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <BbButton Variant="ButtonVariant.Default" OnClick="OrderAllCritical" class="action-btn">ORDER ALL CRITICAL</BbButton>
            </div>
        </div>
    </div>
}

<style>
