@page "/admin/pos"
@layout AdminLayout
@using StockSense.shared
@using StockSense.Services
@using StockSense.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@inject ApplicationDbContext Context
@inject TransactionService SaleService
@inject IJSRuntime JS
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin, Employee")]

<PageTitle>Point of Sale</PageTitle>

@* Added the 'no-print' class so this entire section hides when generating the PDF/Print *@
<div class="pos-wrapper no-print">

    @* --- PRODUCT CATALOG --- *@
    <div class="pos-catalog">
        <div style="flex-shrink: 0; padding: var(--space-4) var(--space-4); border-bottom: 1px solid var(--border); display: flex; flex-direction: column; gap: var(--space-3);">
            <BbInput @bind-Value="searchTerm" @bind-Value:event="oninput" Placeholder="Search products or brands..." />

            <div style="display: flex; flex-wrap: nowrap; gap: var(--space-1); overflow-x: auto; padding-bottom: var(--space-1);">
                <button type="button" @onclick="() => selectedCategory = null"
                        style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == null ? "var(--primary)" : "var(--border)"); cursor: pointer; background-color: @(selectedCategory == null ? "var(--primary)" : "transparent"); color: @(selectedCategory == null ? "var(--primary-foreground)" : "var(--foreground)"); white-space: nowrap; flex-shrink: 0;">
                    All
                </button>
                @foreach (var cat in categories)
                {
                    <button type="button" @onclick="() => selectedCategory = cat"
                            style="padding: var(--space-1) var(--space-3); border-radius: 9999px; font-size: var(--text-xs); font-weight: var(--font-medium); border: 1px solid @(selectedCategory == cat ? "var(--primary)" : "var(--border)"); cursor: pointer; background-color: @(selectedCategory == cat ? "var(--primary)" : "transparent"); color: @(selectedCategory == cat ? "var(--primary-foreground)" : "var(--foreground)"); white-space: nowrap; flex-shrink: 0;">
                        @cat
                    </button>
                }
            </div>
        </div>

        <div style="flex: 1; overflow-y: auto; padding: var(--space-4);">
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: var(--space-3);">
                @foreach (var p in FilteredProducts)
                {
                    <div @onclick="() => AddToCart(p)"
                         style="padding: var(--space-3); border-radius: var(--radius); border: 2px solid @(cart.Any(i => i.ProductId == p.Id) ? "var(--primary)" : "var(--border)"); background-color: @(cart.Any(i => i.ProductId == p.Id) ? "var(--accent)" : "var(--background)"); cursor: @(p.CurrentStock <= 0 ? "not-allowed" : "pointer"); opacity: @(p.CurrentStock <= 0 ? "0.5" : "1"); text-align: center; transition: border-color 0.15s;">
                        <div style="font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--foreground); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@p.Name">@p.Name</div>
                        <div style="font-size: var(--text-xs); color: var(--muted-foreground); margin: var(--space-1) 0;">@p.Brand</div>
                        <div style="font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--primary);">₱@p.Price.ToString("N2")</div>
                        <div style="display: flex; align-items: center; justify-content: center; gap: var(--space-1); margin-top: var(--space-1);">
                            <span style="width: 8px; height: 8px; border-radius: 9999px; flex-shrink: 0; background-color: @GetStockColor(p);"></span>
                            <span style="font-size: var(--text-xs); color: var(--muted-foreground);">Stock: @p.CurrentStock</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* --- DESKTOP CART --- *@
    <div class="pos-cart-desktop">
        <div style="flex-shrink: 0; padding: var(--space-4) var(--space-6); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: var(--space-2);">
            <LucideIcon Name="shopping-cart" Size="18" />
            <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--card-foreground);">Current Order</span>
        </div>

        <div style="flex: 1; overflow-x: hidden; overflow-y: auto; padding: var(--space-4);">
            @if (!cart.Any())
            {
                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: var(--space-3); color: var(--muted-foreground);">
                    <LucideIcon Name="shopping-cart" Size="40" />
                    <p style="font-size: var(--text-sm); margin: 0;">Cart is empty</p>
                </div>
            }
            else
            {
                @CartTable()
            }
        </div>

        @CartFooter()
    </div>

    @* --- MOBILE CART DRAWER --- *@
    @if (cartOpen && cart.Any())
    {
        <div @onclick="() => cartOpen = false"
             style="position: fixed; inset: 0; background-color: rgba(0,0,0,0.5); z-index: 40; display: none;"
             class="pos-mobile-backdrop">
        </div>
    }

    <div class="pos-cart-mobile @(cartOpen ? "pos-cart-mobile-open" : "")">
        <div @onclick="() => cartOpen = !cartOpen"
             style="padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; cursor: pointer;">
            <div style="display: flex; align-items: center; gap: var(--space-2);">
                <LucideIcon Name="shopping-cart" Size="18" />
                <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--card-foreground);">
                    Order (@cart.Count items)
                </span>
                @if (cart.Any())
                {
                    <span style="background-color: var(--primary); color: var(--primary-foreground); border-radius: 9999px; padding: 0 var(--space-2); font-size: var(--text-xs); font-weight: var(--font-bold);">
                        @cart.Sum(i => i.Quantity)
                    </span>
                }
            </div>
            <div style="display: flex; align-items: center; gap: var(--space-3);">
                <span style="font-size: var(--text-base); font-weight: var(--font-bold); color: var(--primary);">₱@TotalAmount.ToString("N2")</span>
                <LucideIcon Name="@(cartOpen ? "chevron-down" : "chevron-up")" Size="18" />
            </div>
        </div>

        @if (cartOpen)
        {
            <div style="flex: 1; overflow-y: auto; padding: var(--space-4);">
                @if (!cart.Any())
                {
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: var(--space-8); gap: var(--space-3); color: var(--muted-foreground);">
                        <LucideIcon Name="shopping-cart" Size="32" />
                        <p style="font-size: var(--text-sm); margin: 0;">Cart is empty</p>
                    </div>
                }
                else
                {
                    @CartTable()
                }
            </div>
        }

        <div style="padding: var(--space-4); border-top: 1px solid var(--border); flex-shrink: 0;">
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div style="margin-bottom: var(--space-3); padding: var(--space-2) var(--space-3); border-radius: var(--radius); background-color: var(--success-muted); border: 1px solid var(--success-border); font-size: var(--text-sm); color: var(--success-muted-foreground);">
                    @statusMessage
                </div>
            }
            <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="Checkout" Disabled="@(isProcessing || !cart.Any())">
                @if (isProcessing)
                {
                    <BbSpinner Size="SpinnerSize.Small" />
                    <span>Processing...</span>
                }
                else
                {
                    <LucideIcon Name="check" Size="16" />
                    <span>Confirm Sale — ₱@TotalAmount.ToString("N2")</span>
                }
            </BbButton>
        </div>
    </div>
</div>

@* --- E-RECEIPT MODAL --- *@
@if (showReceiptModal && completedTransaction != null)
{
    <div class="receipt-backdrop no-print"></div>
    <div class="receipt-modal">
        <div id="printableReceipt" class="receipt-content">

            <div class="receipt-header">
                <h2>SAPSHOP MOTORCYCLE PARTS AND ACCESSORIES SHOP</h2>
                <p>CHIA D. CUNANAN - Prop.</p>
                <p>NON VAT REG. TIN 483-627-084-00000</p>
                <p>B1, L70, Model Community, Pio, 2008 Porac, Pampanga</p>
                <h3 style="margin-top: 15px; text-decoration: underline;">SALES INVOICE</h3>
            </div>

            <div class="receipt-meta">
                <div><strong>Date:</strong> @completedTransaction.TransactionDate.ToString("MM/dd/yyyy HH:mm")</div>
                <div><strong>Invoice No:</strong> @completedTransaction.InvoiceNumber</div>
            </div>

            <table class="receipt-table">
                <thead>
                    <tr>
                        <th style="text-align: left;">Item Description</th>
                        <th style="text-align: center;">Qty</th>
                        <th style="text-align: right;">Unit Price</th>
                        <th style="text-align: right;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in completedTransaction.Items)
                    {
                        <tr>
                            <td style="text-align: left;">@item.ProductName</td>
                            <td style="text-align: center;">@item.Quantity</td>
                            <td style="text-align: right;">@item.UnitPrice.ToString("N2")</td>
                            <td style="text-align: right;">@((item.UnitPrice * item.Quantity).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="receipt-summary">
                <div class="summary-row">
                    <span>Total Sales:</span>
                    <span>@completedTransaction.TotalAmount.ToString("N2")</span>
                </div>
                <div class="summary-row">
                    <span>Less: Discount:</span>
                    <span>0.00</span>
                </div>
                <div class="summary-row" style="font-weight: bold; border-top: 1px dashed #000; padding-top: 5px; margin-top: 5px;">
                    <span>TOTAL AMOUNT DUE:</span>
                    <span>₱@completedTransaction.TotalAmount.ToString("N2")</span>
                </div>
            </div>

            <div class="receipt-footer">
                <p>"THIS DOCUMENT IS NOT VALID FOR CLAIM OF INPUT TAX"</p>
                <p style="margin-top: 10px; font-style: italic;">Generated by StockSense Inventory System</p>
            </div>
        </div>

        <div class="receipt-actions no-print">
            <BbButton Variant="ButtonVariant.Outline" OnClick="CloseReceipt">Close</BbButton>
            <BbButton Variant="ButtonVariant.Default" OnClick="PrintReceipt">
                <LucideIcon Name="printer" Size="16" /> Print / Save PDF
            </BbButton>
        </div>
    </div>
}

@code {
    private RenderFragment CartTable() =>
        @<table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm);">
    <thead>
        <tr style="border-bottom: 1px solid var(--border);">
            <th style="text-align: left; padding: var(--space-2) var(--space-2); color: var(--muted-foreground); font-weight: var(--font-medium);">Item</th>
            <th style="text-align: left; padding: var(--space-2) var(--space-2); color: var(--muted-foreground); font-weight: var(--font-medium);">Qty</th>
            <th style="text-align: right; padding: var(--space-2) var(--space-2); color: var(--muted-foreground); font-weight: var(--font-medium);">Total</th>
            <th style="padding: var(--space-2) var(--space-2);"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in cart)
                {
        <tr style="border-bottom: 1px solid var(--border);">
            <td style="padding: var(--space-2) var(--space-2); color: var(--foreground);">@item.ProductName</td>
            <td style="padding: var(--space-2) var(--space-2);">
                <input type="number"
                       value="@item.Quantity"
                       @onchange="@(e => UpdateCartQuantity(item, e))"
                       min="1"
                       style="width: 56px; padding: var(--space-1) var(--space-2); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--text-sm); box-sizing: border-box;" />
            </td>
            <td style="padding: var(--space-2) var(--space-2); text-align: right; color: var(--foreground);">₱@((item.Price * item.Quantity).ToString("N2"))</td>
            <td style="padding: var(--space-2) var(--space-2);">
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="() => cart.Remove(item)">
                    <LucideIcon Name="x" Size="14" />
                </BbButton>
            </td>
        </tr>
                }
    </tbody>
</table>;

    private RenderFragment CartFooter() =>
        @<div>
@if (cart.Any())
    {
    <div style="padding: var(--space-4); border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: var(--space-3); flex-shrink: 0;">
        @if (!string.IsNullOrEmpty(statusMessage))
                {
        <div style="padding: var(--space-2) var(--space-3); border-radius: var(--radius); background-color: var(--success-muted); border: 1px solid var(--success-border); font-size: var(--text-sm); color: var(--success-muted-foreground);">
            @statusMessage
        </div>
                }
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground);">Total</span>
            <span style="font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--primary);">₱@TotalAmount.ToString("N2")</span>
        </div>
        <BbButton Variant="ButtonVariant.Default" Class="w-full" OnClick="Checkout" Disabled="@isProcessing">
            @if (isProcessing)
                        {
            <BbSpinner Size="SpinnerSize.Small" />
            <span>Processing...</span>
                        }
                        else
            {
                <LucideIcon Name="check" Size="16" />
                <span>Confirm Sale</span>
            }
        </BbButton>
    </div>
    }
</div>;

    private List<Product> allProducts = new();
private List<string> categories = new();
private List<CartItem> cart = new();
private string? selectedCategory;
private string searchTerm = "";
private bool isProcessing = false;
private string? statusMessage;
private bool cartOpen = false;


private string GetStockColor(Product p) =>
p.CurrentStock <= 2       ? "#ef4444" :   // red   — critical / out of stock
p.CurrentStock < p.ReorderTarget ? "#eab308" :   // yellow — below reorder target
"#22c55e";

// --- RECEIPT VARIABLES ---
private bool showReceiptModal = false;
private Transaction? completedTransaction;

protected override async Task OnInitializedAsync() => await LoadData();

private async Task LoadData()
{
    allProducts = await Context.Products.AsNoTracking().ToListAsync();
    categories = allProducts
        .Select(p => p.Category)
        .Where(c => !string.IsNullOrEmpty(c))
        .Distinct()
        .OrderBy(c => c)
        .ToList();
}

private IEnumerable<Product> FilteredProducts => allProducts
    .Where(p => (string.IsNullOrEmpty(selectedCategory) || p.Category == selectedCategory) &&
                (string.IsNullOrWhiteSpace(searchTerm) ||
                 p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                 p.Brand.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));

private decimal TotalAmount => cart.Sum(i => i.Price * i.Quantity);

private void AddToCart(Product p)
{
    if (p.CurrentStock <= 0) return;
    statusMessage = null;

    var existing = cart.FirstOrDefault(i => i.ProductId == p.Id);

    if (existing != null)
    {
        if (existing.Quantity < p.CurrentStock) existing.Quantity++;
        else statusMessage = $"Limit reached: Only {p.CurrentStock} of {p.Name} in stock.";
    }
    else
    {
        cart.Add(new CartItem { ProductId = p.Id, ProductName = p.Name, Price = p.Price, Quantity = 1 });
    }

    cartOpen = true;
}

private void UpdateCartQuantity(CartItem item, ChangeEventArgs e)
{
    if (int.TryParse(e.Value?.ToString(), out int newQty))
    {
        var product = allProducts.FirstOrDefault(p => p.Id == item.ProductId);
        if (product != null)
        {
            if (newQty > product.CurrentStock)
            {
                item.Quantity = product.CurrentStock;
                statusMessage = $"Adjusted to max stock ({product.CurrentStock}) for {item.ProductName}.";
            }
            else if (newQty <= 0) cart.Remove(item);
            else item.Quantity = newQty;
        }
    }
}

private async Task Checkout()
{
    if (!cart.Any()) return;
    isProcessing = true;
    try
    {
        // Call the updated TransactionService which returns the saved Transaction
        completedTransaction = await SaleService.ProcessSaleAsync(cart);

        statusMessage = "Sale complete! E-Receipt generated.";

        // Trigger the E-Receipt Modal
        showReceiptModal = true;

        cart.Clear();
        cartOpen = false;

        await LoadData();
    }
    catch (Exception ex)
    {
        statusMessage = "Error: " + ex.Message;
    }
    finally
    {
        isProcessing = false;
    }
}

// --- RECEIPT METHODS ---
private async Task PrintReceipt()
{
    // Triggers the browser's native print dialog
    await JS.InvokeVoidAsync("window.print");
}

private void CloseReceipt()
{
    showReceiptModal = false;
    completedTransaction = null;
}
}

<style>
    /* UI STYLES */
    .pos-wrapper {
        display: flex;
        gap: var(--space-6);
        height: calc(100vh - 8rem);
        overflow: hidden;
        position: relative;
    }

    .pos-catalog {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
        background-color: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }

    .pos-cart-desktop {
        width: 24rem;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background-color: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }

    .pos-cart-mobile {
        display: none;
    }

    .pos-mobile-backdrop {
        display: none;
    }

    @@media (max-width: 767px) {
        .pos-wrapper {
            height: calc(100vh - 4rem);
            gap: 0;
        }

        .pos-cart-desktop {
            display: none;
        }

        .pos-cart-mobile {
            display: flex;
            flex-direction: column;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background-color: var(--card);
            border-top: 1px solid var(--border);
            border-radius: var(--radius) var(--radius) 0 0;
            z-index: 50;
            max-height: 30vh;
            transition: max-height 0.3s ease;
            box-shadow: 0 -2px 8px rgba(0,0,0,0.05);
        }

        .pos-cart-mobile-open {
            max-height: 50vh;
            overflow: auto;
        }

        .pos-mobile-backdrop {
            display: block;
        }

        .pos-catalog {
            margin-bottom: 5rem;
            border-radius: var(--radius);
        }
    }

    /* E-RECEIPT MODAL STYLES */
    .receipt-backdrop {
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.6);
        z-index: 100;
    }

    .receipt-modal {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        z-index: 101;
        width: 400px;
        max-width: 90vw;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .receipt-content {
        overflow-y: auto;
        color: #000;
        font-family: 'Courier New', Courier, monospace;
        padding-bottom: 20px;
    }

    .receipt-header {
        text-align: center;
        margin-bottom: 15px;
    }

        .receipt-header h2 {
            font-size: 16px;
            margin: 0 0 5px 0;
            font-weight: bold;
        }

        .receipt-header p {
            margin: 2px 0;
            font-size: 12px;
        }

    .receipt-meta {
        font-size: 12px;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
    }

    .receipt-table {
        width: 100%;
        font-size: 12px;
        border-top: 1px dashed #000;
        border-bottom: 1px dashed #000;
        margin-bottom: 15px;
    }

        .receipt-table th, .receipt-table td {
            padding: 5px 2px;
        }

    .receipt-summary {
        font-size: 12px;
        margin-bottom: 20px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 3px;
    }

    .receipt-footer {
        text-align: center;
        font-size: 10px;
        border-top: 1px dashed #000;
        padding-top: 10px;
    }

    .receipt-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 15px;
        border-top: 1px solid #ccc;
        padding-top: 15px;
    }

    /* PRINT STYLES - Crucial for hiding POS and showing only receipt */
    @@media print {
        body * {
            visibility: hidden;
        }

        .no-print {
            display: none !important;
        }

        #printableReceipt, #printableReceipt * {
            visibility: visible;
        }

        #printableReceipt {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            margin: 0;
            padding: 0;
        }
    }
</style>