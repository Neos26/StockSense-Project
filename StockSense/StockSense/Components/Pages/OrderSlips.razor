@page "/admin/orderslips"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using StockSense.shared
@using StockSense.Shared
@using StockSense.Services
@using Microsoft.EntityFrameworkCore
@inject OrderSlipService OrderService
@inject StockSense.Data.ApplicationDbContext Context
@inject IJSRuntime JS
@inject NavigationManager NavManager
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin, Employee")]

<PageTitle>Order Slips</PageTitle>

<div>

    @* ── Page Header ── *@
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-6); flex-wrap: wrap; gap: var(--space-3);">
        <div>
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Order Slips</h1>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Manage and generate supplier order slips.</p>
        </div>
        <div style="display: flex; gap: var(--space-2); flex-wrap: wrap;">
            <BbButton Variant="ButtonVariant.Outline" OnClick='() => NavManager.NavigateTo("/admin/order-history")'>
                <LucideIcon Name="clock" Size="16" />
                View History
            </BbButton>
            <BbButton Variant="ButtonVariant.Default" OnClick="() => isManualSelecting = true">
                <LucideIcon Name="clipboard-plus" Size="16" />
                Create New Order
            </BbButton>
            <BbButton Variant="ButtonVariant.Default" OnClick="GenerateSlips" Disabled="@isLoading">
                @if (isLoading)
                {
                    <BbSpinner Size="SpinnerSize.Small" />
                }
                <LucideIcon Name="cpu" Size="16" />
                Predictive Scan (Scan All)
            </BbButton>
        </div>
    </div>

    @* ── Manual Supplier Selection ── *@
    @if (isManualSelecting)
    {
        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--card-padding); margin-bottom: var(--space-6);">
            <h3 style="font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-4) 0; display: flex; align-items: center; gap: var(--space-2);">
                <LucideIcon Name="truck" Size="16" />
                Select Supplier for New Order
            </h3>
            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
                <select @bind="selectedSupplierIdForManual"
                        style="flex: 1; min-width: 200px; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size);">
                    <option value="0">-- Choose Supplier --</option>
                    @foreach (var s in allSuppliers)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
                <BbButton Variant="ButtonVariant.Default" OnClick="StartManualOrder">Create Empty Slip</BbButton>
                <BbButton Variant="ButtonVariant.Outline" OnClick="() => isManualSelecting = false">Cancel</BbButton>
            </div>
        </div>
    }

    @* ── Empty State ── *@
    @if (slips == null || !slips.Any())
    {
        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-8); text-align: center; color: var(--muted-foreground);">
            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-2);">
                <LucideIcon Name="info" Size="32" />
                <span style="font-size: var(--text-sm);">No active order slips. Click AI Analysis or use the Dashboard to generate suggestions.</span>
            </div>
        </div>
    }
    else
    {
        @foreach (var slip in slips)
        {
            <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: var(--space-6); overflow: hidden;">

                @* ── Slip Header ── *@
                <div style="padding: var(--space-4) var(--card-padding); background-color: var(--primary); color: var(--primary-foreground); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-2);">
                    <div>
                        <h2 style="font-size: var(--text-base); font-weight: var(--font-semibold); margin: 0;">Supplier: @slip.Supplier?.Name</h2>
                        <p style="font-size: var(--text-xs); margin: 0; opacity: 0.75;">Draft: @slip.SlipNumber</p>
                    </div>
                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small" OnClick="() => slips.Remove(slip)"
                              style="color: var(--primary-foreground); background-color: rgba(255,255,255,0.15); white-space: nowrap;">
                        <LucideIcon Name="trash" Size="14" />
                        Cancel Slip
                    </BbButton>
                </div>

                <div style="padding: var(--card-padding);">

                    @* ── Add Item Panels ── *@
                    <div style="display: flex; flex-wrap: wrap; gap: var(--space-4); margin-bottom: var(--space-4);">

                        @* Add Existing Item *@
                        <div style="flex: 1; min-width: 260px; background-color: var(--background); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-4);">
                            <label style="display: block; font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--muted-foreground); margin-bottom: var(--space-2);">Add Existing Item</label>
                            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
                                <select @bind="selectedProductId"
                                        style="flex: 1; min-width: 160px; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size);">
                                    <option value="0">-- Select Product --</option>
                                    @foreach (var p in allProducts.Where(x => x.SupplierId == slip.SupplierId))
                                    {
                                        <option value="@p.Id">@p.Name (@p.Brand)</option>
                                    }
                                </select>
                                <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="() => ManuallyAddItem(slip)">Add</BbButton>
                            </div>
                        </div>

                        @* Add New Unlisted Item *@
                        <div style="flex: 1; min-width: 260px; background-color: var(--background); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-4);">
                            <label style="display: block; font-size: var(--text-sm); font-weight: var(--font-medium); color: var(--muted-foreground); margin-bottom: var(--space-2);">Order New Arrival / New Version</label>
                            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
                                <input type="text" placeholder="Name" @bind="newProductName"
                                       style="flex: 2; min-width: 120px; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size); box-sizing: border-box;" />
                                <select @bind="newProductBrand"
                                        style="flex: 1; min-width: 100px; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size);">
                                    <option value="">-- Brand --</option>
                                    @foreach (var brand in distinctBrands)
                                    {
                                        <option value="@brand">@brand</option>
                                    }
                                </select>
                                <select @bind="newProductCategory"
                                        style="flex: 1; min-width: 100px; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--input); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size);">
                                    <option value="">-- Category --</option>
                                    @foreach (var cat in distinctCategories)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </select>
                                <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" OnClick="() => AddNewUnlistedItem(slip)">Add</BbButton>
                            </div>
                        </div>

                    </div>

                    @* ── Items Table (horizontally scrollable on mobile) ── *@
                    <div style="width: 100%; overflow-x: auto; margin-bottom: var(--space-4);">
                        <table style="width: 100%; min-width: 520px; border-collapse: collapse; font-size: var(--text-sm);">
                            <thead>
                                <tr style="border-bottom: 1px solid var(--border); background-color: var(--muted);">
                                    <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Product Details</th>
                                    <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); white-space: nowrap;">Stock</th>
                                    <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); white-space: nowrap;">Target</th>
                                    <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 130px; white-space: nowrap;">Order Qty</th>
                                    <th style="width: 44px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!slip.Items.Any())
                                {
                                    <tr>
                                        <td colspan="5" style="text-align: center; padding: var(--space-8); color: var(--muted-foreground);">
                                            No items added to this slip. Add items using the section above.
                                        </td>
                                    </tr>
                                }
                                @foreach (var item in slip.Items)
                                {
                                    var isNewItem = !allProducts.Any(p => p.Name == item.ProductName && p.Brand == item.Brand);
                                    <tr style="border-bottom: 1px solid var(--border);">
                                        <td style="padding: var(--space-3) var(--space-4);">
                                            <div style="display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap;">
                                                <span style="font-weight: var(--font-medium); color: var(--foreground);">@item.ProductName</span>
                                                @if (isNewItem)
                                                {
                                                    <BbBadge Variant="BadgeVariant.Default">New Arrival</BbBadge>
                                                }
                                            </div>
                                            <div style="font-size: var(--text-xs); color: var(--muted-foreground); margin-top: var(--space-1);">@item.Brand · @item.Category</div>
                                        </td>
                                        <td style="padding: var(--space-3) var(--space-4); text-align: center; color: var(--foreground);">@item.CurrentStock</td>
                                        <td style="padding: var(--space-3) var(--space-4); text-align: center; color: var(--muted-foreground);">@item.ReorderTarget</td>
                                        <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                            <input type="number" @bind="item.Quantity" min="1"
                                                   style="width: 100%; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--primary); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size); text-align: center; font-weight: var(--font-bold); box-sizing: border-box;" />
                                        </td>
                                        <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon"
                                                      OnClick="() => slip.Items.Remove(item)"
                                                      style="color: var(--destructive);">
                                                <LucideIcon Name="trash" Size="14" />
                                            </BbButton>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* ── Slip Actions ── *@
                    <div style="display: flex; justify-content: flex-end; flex-wrap: wrap; gap: var(--space-2);">
                        <BbButton Variant="ButtonVariant.Outline" OnClick="() => DownloadPdf(slip)">
                            <LucideIcon Name="file-text" Size="16" />
                            Preview PDF
                        </BbButton>
                        <BbButton Variant="ButtonVariant.Default" OnClick="() => SendEmailAndSave(slip)"
                                  Disabled="@(isSaving || !slip.Items.Any())">
                            @if (isSaving)
                            {
                                <BbSpinner Size="SpinnerSize.Small" />
                            }
                            <LucideIcon Name="mail-check" Size="16" />
                            Email Supplier &amp; Move to History
                        </BbButton>
                    </div>

                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter, SupplyParameterFromQuery] public int? productId { get; set; }
    [Parameter, SupplyParameterFromQuery] public bool? orderAll { get; set; }

    private List<OrderSlip>? slips = new();
    private List<Product> allProducts = new();
    private List<Supplier> allSuppliers = new();
    private List<string> distinctBrands = new();
    private List<string> distinctCategories = new();

    private int selectedProductId;
    private int selectedSupplierIdForManual;
    private bool isManualSelecting;
    private string newProductName = "", newProductBrand = "", newProductCategory = "";
    private bool isLoading, isSaving;

    protected override async Task OnInitializedAsync()
    {
        allProducts = await Context.Products.AsNoTracking().ToListAsync();
        allSuppliers = await Context.Suppliers.AsNoTracking().ToListAsync();
        distinctBrands = allProducts.Select(p => p.Brand).Where(b => !string.IsNullOrEmpty(b)).Distinct().OrderBy(b => b).ToList();
        distinctCategories = allProducts.Select(p => p.Category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c).ToList();

        if (orderAll == true) { await GenerateSlips(); }
        else if (productId > 0) { slips = await OrderService.GenerateSingleProductSlipAsync(productId.Value); }
    }

    private async Task GenerateSlips()
    {
        isLoading = true;
        slips = await OrderService.GenerateSuggestedOrderSlipsAsync();
        isLoading = false;
    }

    private void StartManualOrder()
    {
        if (selectedSupplierIdForManual == 0) return;

        var supplier = allSuppliers.FirstOrDefault(s => s.Id == selectedSupplierIdForManual);
        if (supplier == null) return;

        var newSlip = new OrderSlip
        {
            SlipNumber = $"MAN-{DateTime.Now:yyyyMMdd}-{Guid.NewGuid().ToString().Substring(0, 4).ToUpper()}",
            SupplierId = supplier.Id,
            Supplier = supplier,
            DateGenerated = DateTime.Now,
            Items = new List<OrderSlipItem>(),
            IsReceived = false
        };

        slips ??= new List<OrderSlip>();
        slips.Insert(0, newSlip);
        isManualSelecting = false;
        selectedSupplierIdForManual = 0;
    }

    private async Task SendEmailAndSave(OrderSlip slip)
    {
        if (string.IsNullOrEmpty(slip.Supplier?.Email))
        {
            await JS.InvokeVoidAsync("alert", "Error: Supplier has no email address. Update supplier details first.");
            return;
        }

        isSaving = true;
        try
        {
            var bytes = await OrderService.GeneratePdfBytesAsync(slip);
            await OrderService.SendEmailAsync(slip.Supplier.Email, bytes, slip.SlipNumber);
            await OrderService.SaveOrderSlipToDbAsync(slip);
            slips?.Remove(slip);
            await JS.InvokeVoidAsync("alert", "Order sent successfully and recorded in history.");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Email Error: " + ex.Message);
        }
        finally { isSaving = false; }
    }

    private async Task DownloadPdf(OrderSlip slip)
    {
        var bytes = await OrderService.GeneratePdfBytesAsync(slip);
        await JS.InvokeVoidAsync("downloadFile", $"Preview_{slip.SlipNumber}.pdf", Convert.ToBase64String(bytes));
    }

    private void ManuallyAddItem(OrderSlip slip)
    {
        if (selectedProductId == 0) return;
        var product = allProducts.FirstOrDefault(p => p.Id == selectedProductId);
        if (product != null && !slip.Items.Any(i => i.ProductName == product.Name && i.Brand == product.Brand))
        {
            slip.Items.Add(new OrderSlipItem
            {
                ProductName = product.Name,
                Brand = product.Brand,
                Category = product.Category,
                CurrentStock = product.CurrentStock,
                ReorderTarget = product.ReorderTarget,
                Quantity = 1
            });
        }
        selectedProductId = 0;
    }

    private void AddNewUnlistedItem(OrderSlip slip)
    {
        if (string.IsNullOrWhiteSpace(newProductName) || string.IsNullOrWhiteSpace(newProductBrand)) return;
        slip.Items.Add(new OrderSlipItem
        {
            ProductName = newProductName,
            Brand = newProductBrand,
            Category = newProductCategory,
            CurrentStock = 0,
            ReorderTarget = 10,
            Quantity = 1
        });
        newProductName = ""; newProductBrand = ""; newProductCategory = "";
    }
}
