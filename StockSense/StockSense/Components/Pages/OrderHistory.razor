@page "/admin/order-history"
@layout AdminLayout
@using StockSense.shared
@using StockSense.Services
@using Microsoft.AspNetCore.Authorization
@inject OrderSlipService OrderService
@inject NavigationManager NavManager
@inject DialogService DialogService
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin")]
@if (confirmModal.IsOpen)
{
    <div @onclick="() => confirmModal = ConfirmState.Closed" style="position: fixed; inset: 0; background-color: rgba(0,0,0,0.7); display: flex; justify-content: center; align-items: center; z-index: 1000;">
        <div @onclick:stopPropagation style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--card-padding); width: 400px; max-width: 90%; box-shadow: var(--shadow-lg);">
            <h3 style="font-size: var(--text-lg); font-weight: var(--font-semibold); color: var(--foreground); margin: 0 0 var(--space-2) 0;">@confirmModal.Title</h3>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0 0 var(--space-6) 0;">@confirmModal.Message</p>
            <div style="display: flex; justify-content: flex-end; gap: var(--space-2);">
                <BbButton Variant="ButtonVariant.Outline" OnClick="() => confirmModal = ConfirmState.Closed">Cancel</BbButton>
                <BbButton Variant="@(confirmModal.Destructive? ButtonVariant.Destructive: ButtonVariant.Default)" OnClick="ConfirmAction">
                    @confirmModal.ConfirmText
                </BbButton>
            </div>
        </div>
    </div>
}
<PageTitle>Order History</PageTitle>

<div>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-6); flex-wrap: wrap; gap: var(--space-3);">
        <div>
            <h1 style="font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--foreground); margin: 0;">Order History</h1>
            <p style="font-size: var(--text-sm); color: var(--muted-foreground); margin: 0;">Review and receive supplier order slips.</p>
        </div>
        <BbButton Variant="ButtonVariant.Default" OnClick='() => NavManager.NavigateTo("/admin/orderslips")'>
            <LucideIcon Name="plus" Size="16" />
            Create New Order
        </BbButton>
    </div>

    @if (savedSlips == null)
    {
        <div style="display: flex; justify-content: center; align-items: center; padding: var(--space-8); color: var(--muted-foreground); gap: var(--space-3);">
            <BbSpinner Size="SpinnerSize.Small" />
            <span>Loading history...</span>
        </div>
    }
    else if (!savedSlips.Any())
    {
        <div style="background-color: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-8); text-align: center; color: var(--muted-foreground);">
            <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-2);">
                <LucideIcon Name="clock" Size="32" />
                <span style="font-size: var(--text-sm);">No order history found.</span>
            </div>
        </div>
    }
    else
    {
        @foreach (var slip in savedSlips)
        {
            <div style="background-color: var(--card); border: 1px solid @(slip.IsReceived ? "var(--success)" : "var(--warning)"); border-radius: var(--radius); margin-bottom: var(--space-6); overflow: hidden;">

                @* Slip Header *@
                <div style="padding: var(--space-4) var(--card-padding); background-color: @(slip.IsReceived ? "var(--success)" : "var(--warning)"); display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: var(--space-3);">
                        <span style="font-weight: var(--font-semibold); color: var(--foreground); font-size: var(--text-sm);">@slip.SlipNumber</span>
                        <span style="color: var(--muted-foreground); font-size: var(--text-sm);">·</span>
                        <span style="font-size: var(--text-sm); color: var(--foreground);">@slip.Supplier?.Name</span>
                    </div>
                    <BbBadge Variant="@(slip.IsReceived? BadgeVariant.Default: BadgeVariant.Secondary)">
                        @(slip.IsReceived ? "Completed" : "Pending")
                    </BbBadge>
                </div>

                <div style="padding: var(--card-padding);">
                    <div style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse; font-size: var(--text-sm); min-width: 500px;">
                            <thead>
                                <tr style="border-bottom: 1px solid var(--border);">
                                    <th style="text-align: left; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Product Details</th>
                                    <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium);">Qty Ordered</th>
                                    <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 180px;">Qty Received</th>
                                    <th style="text-align: center; padding: var(--space-3) var(--space-4); color: var(--muted-foreground); font-weight: var(--font-medium); width: 120px;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in slip.Items)
                                {
                                    <tr style="border-bottom: 1px solid var(--border);">
                                        <td style="padding: var(--space-3) var(--space-4);">
                                            <div style="font-weight: var(--font-medium); color: var(--foreground);">@item.ProductName</div>
                                            <div style="font-size: var(--text-xs); color: var(--muted-foreground);">@item.Brand</div>
                                        </td>
                                        <td style="padding: var(--space-3) var(--space-4); text-align: center; font-weight: var(--font-semibold); color: var(--foreground);">@item.Quantity</td>
                                        <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                            @if (slip.IsReceived)
                                            {
                                                <span style="font-weight: var(--font-semibold); color: var(--foreground);">@item.ReceivedQuantity</span>
                                            }
                                            else
                                            {
                                                <input type="number" @bind="item.ReceivedQuantity" min="0"
                                                       style="width: 100%; padding: var(--input-padding-y) var(--input-padding-x); border-radius: var(--radius); border: 1px solid var(--primary); background-color: var(--background); color: var(--foreground); font-size: var(--input-font-size); text-align: center; font-weight: var(--font-bold); box-sizing: border-box;" />
                                            }
                                        </td>
                                        <td style="padding: var(--space-3) var(--space-4); text-align: center;">
                                            @if (!slip.IsReceived)
                                            {
                                                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon"
                                                          OnClick="() => RemoveProduct(item.Id)"
                                                          style="color: var(--destructive);">
                                                    <LucideIcon Name="trash" Size="14" />
                                                </BbButton>
                                            }
                                            else
                                            {
                                                <span style="font-size: var(--text-xs); font-weight: var(--font-medium); color: var(--foreground); display: flex; align-items: center; justify-content: center; gap: var(--space-1);">
                                                    <LucideIcon Name="check-circle" Size="14" />
                                                    Stocked
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!slip.IsReceived)
                    {
                        <div style="display: flex; justify-content: flex-end; gap: var(--space-2); margin-top: var(--space-4);">
                            <BbButton Variant="ButtonVariant.Outline" OnClick="() => DeleteSlip(slip.Id)"
                                      style="color: var(--destructive); border-color: var(--destructive);">
                                <LucideIcon Name="trash-2" Size="16" />
                                Delete Slip
                            </BbButton>
                            <BbButton Variant="ButtonVariant.Default" OnClick="() => ConfirmStockIn(slip)">
                                <LucideIcon Name="package" Size="16" />
                                Confirm Stock In
                            </BbButton>
                        </div>
                    }
                </div>

            </div>
        }
    }
</div>

@code {
    private ConfirmState confirmModal = ConfirmState.Closed;
    private Func<Task>? pendingAction;

    private record ConfirmState(bool IsOpen, string Title, string Message, string ConfirmText, bool Destructive)
    {
        public static ConfirmState Closed => new(false, "", "", "", false);
    }

    private void ShowConfirm(string title, string message, string confirmText, bool destructive, Func<Task> action)
    {
        confirmModal = new ConfirmState(true, title, message, confirmText, destructive);
        pendingAction = action;
    }

    private async Task ConfirmAction()
    {
        confirmModal = ConfirmState.Closed;
        if (pendingAction != null)
            await pendingAction();
    }

    private List<OrderSlip>? savedSlips;

    protected override async Task OnInitializedAsync() => await LoadHistory();

    private async Task LoadHistory()
    {
        savedSlips = await OrderService.GetSavedOrderSlipsAsync();
        if (savedSlips != null)
        {
            foreach (var slip in savedSlips.Where(s => !s.IsReceived))
                foreach (var item in slip.Items)
                    if (item.ReceivedQuantity == 0)
                        item.ReceivedQuantity = item.Quantity;
        }
    }

    private void RemoveProduct(int itemId) =>
        ShowConfirm("Remove Product", "Remove this product from the slip?", "Remove", true,
            async () =>
            {
                await OrderService.RemoveItemFromSlipAsync(itemId);
                await LoadHistory();
            });

    private void ConfirmStockIn(OrderSlip slip) =>
        ShowConfirm("Confirm Stock In", "Update inventory with these received amounts? This cannot be undone.", "Confirm", false,
            async () =>
            {
                await OrderService.MarkAsReceivedAsync(slip);
                await LoadHistory();
            });

    private void DeleteSlip(int id) =>
        ShowConfirm("Delete Slip", "Delete this entire slip? All items will be removed from history.", "Delete", true,
            async () =>
            {
                await OrderService.DeleteOrderSlipAsync(id);
                await LoadHistory();
            });

}