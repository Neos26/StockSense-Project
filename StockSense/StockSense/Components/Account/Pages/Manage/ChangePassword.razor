@page "/Account/Manage/ChangePassword"
@layout SettingsLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using StockSense.Data
@using StockSense.Components.Account

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityUserAccessor UserAccessor
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ChangePassword> Logger

<PageTitle>Change password</PageTitle>

<h1 class="text-2xl font-semibold text-foreground m-0">Password</h1>
<h2 class="text-base font-normal text-muted-foreground m-0">Update your account password.</h2>
<div class="border-t border-border my-3"></div>

@* --- CUSTOM STATUS MESSAGE (Replaces StatusMessage component) --- *@
@if (!string.IsNullOrEmpty(message))
{
    var isError = message.StartsWith("Error");
    
    <div class="mb-6 p-3 rounded-lg border flex items-center gap-2 text-sm
                @(isError ? "bg-destructive-muted border-destructive-border text-destructive-muted-foreground" 
                          : "bg-success-muted border-success-border text-success-muted-foreground")" role="alert">
        
        @if (isError)
        {
            <LucideIcon Name="triangle-alert" Size="18" Class="flex-shrink-0" />
        }
        else
        {
            <LucideIcon Name="check" Size="18" Class="flex-shrink-0" />
        }
        <span class="font-medium">@message</span>
    </div>
}

<EditForm Model="Input" FormName="change-password" OnValidSubmit="OnValidSubmitAsync" method="post">
    <DataAnnotationsValidator />
    
    @* --- VALIDATION SUMMARY --- *@
    <ValidationSummary class="mb-6 text-sm text-destructive bg-destructive-muted p-3 border border-destructive-border rounded-lg list-inside" role="alert" />

    <div class="flex flex-col gap-4">

        <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-foreground">Current password</label>
            <InputText type="password" @bind-Value="Input.OldPassword" autocomplete="current-password" aria-required="true"
                       class="w-full py-2 px-3 rounded-lg border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-shadow" />
            <ValidationMessage For="() => Input.OldPassword" class="text-sm text-destructive" />
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-foreground">New password</label>
            <InputText type="password" @bind-Value="Input.NewPassword" autocomplete="new-password" aria-required="true"
                       class="w-full py-2 px-3 rounded-lg border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-shadow" />
            <ValidationMessage For="() => Input.NewPassword" class="text-sm text-destructive" />
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-sm font-medium text-foreground">Confirm new password</label>
            <InputText type="password" @bind-Value="Input.ConfirmPassword" autocomplete="new-password" aria-required="true"
                       class="w-full py-2 px-3 rounded-lg border border-input bg-background text-foreground text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-shadow" />
            <ValidationMessage For="() => Input.ConfirmPassword" class="text-sm text-destructive" />
        </div>

        <button type="submit"
                class="w-full mt-2 py-2.5 px-4 rounded-lg bg-primary hover:opacity-90 text-primary-foreground text-sm font-medium border-none cursor-pointer transition-opacity">
            Update password
        </button>

    </div>
</EditForm>
@code {
    private string? message;
    private ApplicationUser user = default!;
    private bool hasPassword;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    // Read the message from the cookie
    protected override async Task OnInitializedAsync()
    {
        user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        hasPassword = await UserManager.HasPasswordAsync(user);
        
        if (!hasPassword)
        {
            RedirectManager.RedirectTo("Account/Manage/SetPassword");
        }

        var messageFromCookie = HttpContext.Request.Cookies[IdentityRedirectManager.StatusCookieName];
        if (messageFromCookie is not null)
        {
            message = messageFromCookie;
            HttpContext.Response.Cookies.Delete(IdentityRedirectManager.StatusCookieName);
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var changePasswordResult = await UserManager.ChangePasswordAsync(user, Input.OldPassword, Input.NewPassword);
        if (!changePasswordResult.Succeeded)
        {
            message = $"Error: {string.Join(",", changePasswordResult.Errors.Select(error => error.Description))}";
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        Logger.LogInformation("User changed their password successfully.");
        
        // This will reload the page and add ?statusMessage=Your... to the URL
        RedirectManager.RedirectToCurrentPageWithStatus("Your password has been changed", HttpContext);
    }

    private sealed class InputModel
    {
        [Required]
        [DataType(DataType.Password)]
        [Display(Name = "Current password")]
        public string OldPassword { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        [Display(Name = "New password")]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm new password")]
        [Compare("NewPassword", ErrorMessage = "The new password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}